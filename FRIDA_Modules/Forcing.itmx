				<inflow>HFC134a_eq_into_atmosphere</inflow>
				<outflow>HFC134a_eq_out_of_atmosphere</outflow>
				<units>kt</units>
			</stock>
			<flow name="HFC134a eq into atmosphere">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>HFC134a_emissions</eqn>
				<units>kt/Year</units>
			</flow>
			<flow name="HFC134a eq out of atmosphere">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>HFC134a_eq_in_atmosphere/(Baseline_HFC134a_eq_Lifetime)</eqn>
				<units>kt/Year</units>
			</flow>
