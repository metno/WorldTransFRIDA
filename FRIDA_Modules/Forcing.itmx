			<aux name="Efficacy of Effective Radiative\nForcing from Volcanoes">
				<eqn>0.6</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="Effective Radiative\nForcing from Solar\nOutput Variations" access="output">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Baseline_Effective_Radiative_Forcing_from_Solar_Output_Variations*Amplitude_of_Effective_Radiative_Forcing_from_Solar_Output_Variations[selected_climate_case_3[Run]] + Linear_trend_in_Effective_Radiative_Forcing_from_Solar_Output_Variations[selected_climate_case_3[Run]]*Contribution_of_Effective_Radiative_Forcing_from_Solar_Output_Variations</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="Effective Radiative\nForcing from Volcanoes">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Baseline_Effective_Radiative_Forcing_from_Volcanoes*Calibration_scaling_of_Volcano_forcing[selected_climate_case_2[Run]]</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="Efficacy Adjusted Effective Radiative\nForcing from Volcanoes" access="output">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Effective_Radiative_Forcing_from_Volcanoes*Efficacy_of_Effective_Radiative_Forcing_from_Volcanoes</eqn>
				<units>W/metre^2</units>
			</aux>
			<aux name="Effective Radiative\nForcing from Natural Sources" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Effective_Radiative_Forcing_from_Solar_Output_Variations[Run] + Efficacy_Adjusted_Effective_Radiative_Forcing_from_Volcanoes[Run]</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="selected climate case 2" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>5</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="selected climate case 3" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>5</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Baseline Effective Radiative\nForcing from Solar\nOutput Variations" access="output" isee:autocreated="true">
				<eqn>NAN</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="Contribution of Effective Radiative\nForcing from Solar\nOutput Variations" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>TIME</eqn>
				<gf>
