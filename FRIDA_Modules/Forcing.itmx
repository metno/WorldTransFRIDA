	<model name="Ozone_Forcing">
		<variables>
			<aux name="Reduction in Ozone Effective Radiative\nForcing per unit\ntemperature change">
				<eqn>-0.037</eqn>
				<units>W/metre^2/K</units>
			</aux>
			<aux name="Ozone Effective\nRadiative Forcing" access="output">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Ozone_Effective_Radiative_Forcing_without_Temperature_effect + Reduction_in_Ozone_Effective_Radiative_Forcing_per_unit_temperature_change*Surface_Temperature</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="Surface Temperature" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<units>K</units>
			</aux>
			<aux name="Montreal gases\nequivalent effective\nstratospheric chlorine" access="output" isee:autocreated="true">
				<eqn>NAN</eqn>
				<units>CFC11eq</units>
			</aux>
			<aux name="Atmospheric CH4 Concentration" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>ppb</units>
			</aux>
			<aux name="Atmospheric N2O Concentration" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>ppb</units>
			</aux>
			<aux name="Atmospheric CH4\nConcentration 1750" access="input">
				<eqn>729.2</eqn>
				<units>ppb</units>
			</aux>
			<aux name="Atmospheric N2O\nConcentration 1750" access="input">
				<eqn>270.1</eqn>
