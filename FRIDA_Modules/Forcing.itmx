	<model name="BC_on_Snow_Forcing">
		<variables>
			<aux name="Effective\nRadiative Forcing of Black Carbon\non Snow per unit SO2 Emissions">
				<eqn>0.000379459</eqn>
				<units>(W/(metre^2))/(MtSO2/yr)</units>
			</aux>
			<aux name="Effective\nRadiative Forcing of Black Carbon\non Snow" access="output">
				<doc>${External Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Effective_Radiative_Forcing_of_Black_Carbon_on_Snow_per_unit_SO2_Emissions*(DELAY(Total_SO2_Emissions_1,  0.5) - SO2_Baseline_Emissions_1) + Effective_Radiative_Forcing_of_Black_Carbon_on_Snow_per_unit_CO2_AFOLU_Emissions*(DELAY(CO2_Emissions_from_Food_and_Land_Use,  0.5)-CO2_AFOLU_Baseline_Emissions)*UNIT_MtCO2_to_GtCO2_1)*Calibration_scaling_of_Black_Carbon_on_Snow_forcing[selected_climate_case_1[Run]]</eqn>
				<units>W/(metre^2)</units>
			</aux>
			<aux name="Effective\nRadiative Forcing of Black Carbon on Snow per unit CO2\nAFOLU Emissions">
				<eqn>0.00000160879</eqn>
