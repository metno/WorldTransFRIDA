			<aux name="Total CH4 Emissions 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>MtCH4/Year</units>
			</aux>
			<aux name="CH4 Baseline Emissions" access="input">
				<eqn>19.0197831178</eqn>
				<units>MtCH4/yr</units>
			</aux>
			<aux name="Molecular Weight of Air 1" access="input">
				<eqn>28.97</eqn>
				<units>g/mol</units>
			</aux>
			<aux name="Mass of the Atmosphere" access="input">
				<eqn>5135200000000000000</eqn>
				<units>kilogram</units>
			</aux>
			<aux name="UNIT fraction to ppm" access="input">
				<eqn>1000000</eqn>
				<units>ppm</units>
			</aux>
			<aux name="UNIT ppm to ppb" access="input">
				<eqn>1000</eqn>
				<units>ppb/ppm</units>
			</aux>
			<aux name="selected climate case 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>5</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="CH4 lifetime factor from emissions">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>LN(1 + (VOC_emissions - Baseline_VOC_emissions)*Sensitivity_of_CH4_lifetime_to_VOC_emissions) + 
LN(1 + (Total_NOx_emissions - Baseline_NOx_Emissions_1)*Sensitivity_of_CH4_lifetime_to_NOx_emissions)</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="CH4 lifetime factor\nfrom concentrations">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>LN(1 + (Atmospheric_CH4_Concentration - Atmospheric_CH4_Concentration_1750)*Sensitivity_of_CH4_lifetime_to_CH4_concentrations)  + 
LN(1 + (Atmospheric_N2O_Concentration - Atmospheric_N2O_Concentration_1750)*Sensitivity_of_CH4_lifetime_to_N2O_concentrations) +
LN(1 + (Montreal_gases_equivalent_effective_stratospheric_chlorine - Montreal_gases_equivalent_effective_stratospheric_chlorine_1750)*Sensitivity_of_CH4_lifetime_to_Equivalent_effective_stratospheric_chlorine_concentrations)</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="CH4 lifetime factor\nfrom temperature">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>LN(1 + Surface_Temperature_1*Sensitivity_of_CH4_lifetime_to_temperature)</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="Baseline CH4 lifetime">
				<eqn>9.99789418</eqn>
				<units>years</units>
			</aux>
			<aux name="Sensitivity of CH4 lifetime to CH4 concentrations">
				<eqn>0.000254099</eqn>
				<units>1/ppb</units>
			</aux>
			<aux name="Sensitivity of CH4 lifetime\nto N2O concentrations">
				<eqn>-0.000722665</eqn>
				<units>1/ppb</units>
			</aux>
			<aux name="Sensitivity of CH4 lifetime\nto Equivalent effective stratospheric\nchlorine concentrations">
				<eqn>-0.00000532738</eqn>
				<units>1/CFC11eq</units>
			</aux>
			<aux name="Sensitivity of CH4 lifetime\nto VOC emissions">
				<eqn>0.001619264</eqn>
				<units>1/(Mt VOC/yr)</units>
			</aux>
			<aux name="Sensitivity of CH4 lifetime\nto NOx emissions">
				<eqn>-0.002511067</eqn>
				<units>1/(Mt NOx/yr)</units>
			</aux>
			<aux name="Sensitivity of CH4 lifetime\nto temperature">
				<eqn>-0.0408</eqn>
				<units>1/K</units>
			</aux>
			<aux name="Surface Temperature 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>K</units>
			</aux>
			<aux name="VOC emissions" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>Mt VOC/yr</units>
			</aux>
			<aux name="Baseline VOC emissions" access="input">
				<eqn>60.02182622</eqn>
				<units>Mt VOC/yr</units>
			</aux>
			<aux name="Atmospheric N2O Concentration" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>ppb</units>
			</aux>
			<aux name="Atmospheric N2O\nConcentration 1750" access="input">
				<eqn>270.1</eqn>
				<units>ppb</units>
			</aux>
			<aux name="Scale factor for CH4 lifetime">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>EXP(CH4_lifetime_factor_from_concentrations + CH4_lifetime_factor_from_emissions + CH4_lifetime_factor_from_temperature)</eqn>
				<units>Dimensionless</units>
			</aux>
			<aux name="Montreal gases\nequivalent effective\nstratospheric chlorine" access="input">
				<eqn>TIME</eqn>
				<units>CFC11eq</units>
			</aux>
			<aux name="Montreal gases\nequivalent effective\nstratospheric chlorine 1750" access="input">
				<eqn>344.3627591</eqn>
				<units>CFC11eq</units>
			</aux>
			<aux name="selected climate case" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>5</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Total NOx emissions" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>Mt NOx/yr</units>
			</aux>
			<aux name="Baseline NOx Emissions 1" access="input">
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>Mt NOx/yr</units>
			</aux>
			<stock name="CH4 in atmosphere">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Initial_CH4_in_atmosphere[selected_climate_case[Run]]</eqn>
				<inflow>CH4_into_atmosphere</inflow>
				<outflow>CH4_out_of_atmosphere</outflow>
				<units>MtCH4</units>
			</stock>
			<flow name="CH4 into atmosphere">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Total_CH4_Emissions_1 - CH4_Baseline_Emissions</eqn>
				<units>MtCH4/Year</units>
			</flow>
			<flow name="CH4 out of atmosphere">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>CH4_in_atmosphere/(Baseline_CH4_lifetime*Scale_factor_for_CH4_lifetime)</eqn>
				<units>MtCH4/Year</units>
			</flow>
		</variables>
