			<aux name="Effective Radiative Forcing\nfrom Aerosol Cloud Interactions" access="output">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Scaling_Aerosol_Cloud_Interactions_Effective_Radiative_Forcing_scaling_factor[selected_climate_case[Run]]*LN(1 + Logarithmic_Aerosol_Cloud_Interactions_Effective_Radiative_Forcing_scaling_factor[selected_climate_case[Run]]*DELAY(Total_SO2_Emissions, 1)) - Scaling_Aerosol_Cloud_Interactions_Effective_Radiative_Forcing_scaling_factor[selected_climate_case[Run]]*LN(1 + Logarithmic_Aerosol_Cloud_Interactions_Effective_Radiative_Forcing_scaling_factor[selected_climate_case[Run]]*SO2_Baseline_Emissions)</eqn>
				<units>W/(metre^2)</units>
