				<units>c$/(kWh/Years)</units>
			</isee:placeholder>
			<isee:placeholder name="renewable capacity placeholder" isee:derived_units="true">
				<eqn>Government_Regulations.tax_rate_on_newly_installed_solar_energy_capacity{Solar} + Government_Regulations.tax_rate_on_newly_installed_wind_energy_capacity{Wind} + Government_Regulations.tax_rate_on_newly_installed_hydropower_capacity{Hydropower} + Government_Regulations.tax_rate_on_newly_installed_nuclear_energy_capacity{Nuclear} + Government_Regulations.tax_rate_on_newly_installed_bio_energy_capacity{Bio Energy}</eqn>
				<units>c$/(kWh/Years)</units>
			</isee:placeholder>
			<isee:placeholder name="rate of decommissioning\nextraction capital" isee:derived_units="true">
				<eqn>Government_Regulations.rate_of_decommissioning_coal_fossil_fuel_extraction_capital{Coal} + Government_Regulations.rate_of_decommissioning_oil_fossil_fuel_extraction_capital{Oil} + Government_Regulations.rate_of_decommissioning_gas_fossil_fuel_extraction_capital{Gas}</eqn>
				<units>1/year</units>
			</isee:placeholder>
			<isee:placeholder name="share of emissions stored" isee:derived_units="true">
				<eqn>Government_Regulations.share_of_coal_emissions_stored{Coal} + Government_Regulations.share_of_oil_emissions_stored{Oil} + Government_Regulations.share_of_gas_emissions_stored{Gas} + Government_Regulations.share_of_biofuel_emissions_stored{Biofuel}</eqn>
				<units>dmnl</units>
			</isee:placeholder>
			<aux name="wage tax policy" access="output" isee:autocreated="true">
				<doc>${Policy}
</doc>
				<eqn>.218</eqn>
				<range min="0.05" max="0.5"/>
				<units>dmnl</units>
			</aux>
			<aux name="switch wage tax policy" access="output" isee:autocreated="true">
				<doc>${Policy}
</doc>
				<eqn>0</eqn>
				<format precision="1"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="profit tax policy" access="output" isee:autocreated="true">
				<doc>${Policy}
</doc>
				<eqn>0.327</eqn>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="time to implement\nwage tax policy" access="output" isee:autocreated="true">
				<doc>${Policy}
</doc>
				<eqn>5</eqn>
				<range min="5" max="75"/>
				<units>years</units>
			</aux>
			<aux name="wage tax policy start year" access="output">
				<doc>${Policy}
</doc>
				<eqn>2025</eqn>
				<format precision="1"/>
				<range min="2025" max="2100"/>
				<units>Year</units>
			</aux>
			<aux name="Residential and Service\nbuildings longevity policy" access="output" isee:autocreated="true">
				<doc>${Policy}
This policy lever simulates stricter/looser building standards for concrete structures. This can be used to explore scenarios where the service life of concrete structures is extended/reduced due to policy decisions.</doc>
				<eqn>TIME</eqn>
				<format precision="0.1"/>
				<gf>
					<xscale min="2020" max="2100"/>
					<yscale min="0.5" max="1.5"/>
					<ypts>1,1,1,1,1,1,1,1,1</ypts>
				</gf>
				<units>dmnl</units>
			</aux>
			<aux name="Infrastructure\nbuildings longevity policy" access="output" isee:autocreated="true">
				<doc>${Policy}
This policy lever simulates stricter/looser building standards for concrete structures. This can be used to explore scenarios where the service life of concrete structures is extended/reduced due to policy decisions.</doc>
				<eqn>TIME</eqn>
				<format precision="0.1"/>
				<gf>
					<xscale min="1980" max="2100"/>
					<yscale min="0.5" max="1.5"/>
					<ypts>1,1,1,1,1,1,1,1,1</ypts>
				</gf>
				<units>dmnl</units>
			</aux>
			<aux name="wealth tax policy" access="output" isee:autocreated="true">
				<doc>${Policy}
</doc>
				<eqn>0</eqn>
				<format precision="0.001"/>
				<range min="0" max="0.02"/>
				<units>1/year</units>
			</aux>
			<aux name="government debt to\nGDP ratio target">
				<doc>${Policy}
</doc>
				<eqn>1.2</eqn>
				<format precision="0.01"/>
				<range min="0.5" max="2"/>
				<units>year</units>
			</aux>
			<aux name="minimum percentage of\ntaxes spent by government" access="output" isee:autocreated="true">
				<doc>${Policy}
</doc>
				<eqn>0.9</eqn>
				<format precision="0.01"/>
				<range min="0.5" max="1"/>
				<units>dmnl</units>
			</aux>
			<isee:placeholder name="concrete policy" isee:derived_units="true">
				<eqn>Government_Regulations.concrete_residential_and_service_maintenance_policy{Residential and Service Maintenance Fraction} + Government_Regulations.concrete_infrastructure_maintenance_policy{Infrastructure Maintenance Fraction} + Government_Regulations.Residential_and_Service_buildings_longevity_policy{Residential and Service Longevity Multiplier} + Government_Regulations.Infrastructure_buildings_longevity_policy{Infrastructure Longevity Multiplier}</eqn>
				<units>dmnl</units>
			</isee:placeholder>
			<aux name="No SLR adaptation strategy" access="output" isee:autocreated="true">
				<doc>${Policy}
</doc>
				<eqn>1</eqn>
				<units>1</units>
			</aux>
			<aux name="Protection as SLR\nadaptation strategy" access="output" isee:autocreated="true">
				<doc>${Policy}
</doc>
				<eqn>0</eqn>
				<units>1</units>
			</aux>
			<aux name="Retreat as SLR adaptation strategy" access="output" isee:autocreated="true">
				<doc>${Policy}
</doc>
				<eqn>0</eqn>
				<units>1</units>
			</aux>
			<aux name="additional transfers policy" access="output" isee:autocreated="true">
				<doc>${Policy}
</doc>
				<eqn>TIME</eqn>
				<gf>
					<xscale min="2020" max="2100"/>
					<yscale min="-0.15" max="0.15"/>
					<ypts>0,0,0,0,0,0,0,0,0</ypts>
				</gf>
				<units>dmnl</units>
			</aux>
			<aux name="time for government to change\nthe debt to GDP ratio target">
				<doc>${Policy}
</doc>
				<eqn>10</eqn>
				<range min="5" max="50"/>
				<units>years</units>
			</aux>
			<aux name="computed government debt to GDP ratio target" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>calibration_period_government_debt_to_GDP_ratio_target+
RAMP((government_debt_to_GDP_ratio_target-calibration_period_government_debt_to_GDP_ratio_target)/time_for_government_to_change_the_debt_to_GDP_ratio_target, debt_to_gdp_level_start_year, debt_to_gdp_level_start_year+time_for_government_to_change_the_debt_to_GDP_ratio_target)</eqn>
				<units>year</units>
			</aux>
			<aux name="calibration period\ngovernment debt to GDP ratio target">
				<doc>${Assumption}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1.2</eqn>
				<range min="1" max="1.5"/>
				<units>year</units>
			</aux>
			<aux name="time to start\ncentral bank inflation\npolicy">
				<doc>${Policy}
</doc>
				<eqn>2025</eqn>
				<format precision="1"/>
				<range min="2025" max="2075"/>
				<units>Year</units>
			</aux>
			<aux name="max change per year in inflation">
				<doc>${Policy}
</doc>
				<eqn>.001</eqn>
				<format precision="0.0001"/>
				<range min="0.0001" max="0.02"/>
				<units>1/year^2</units>
			</aux>
			<aux name="max change per year\nin unemployment">
				<doc>${Policy}
</doc>
				<eqn>.001</eqn>
				<format precision="0.0001"/>
				<range min="0.0001" max="0.02"/>
				<units>1/year</units>
			</aux>
			<aux name="actual inflation goal" access="output">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>historical_inflation_goal+RAMP(SIGN(inflation_goal_policy-historical_inflation_goal)*max_change_per_year_in_inflation, time_to_start_central_bank_inflation_policy, time_to_start_central_bank_inflation_policy + ABS(historical_inflation_goal-inflation_goal_policy)/max_change_per_year_in_inflation )</eqn>
				<units>1/year</units>
			</aux>
			<aux name="historical inflation goal">
				<doc>${Assumption}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.02</eqn>
				<range min="0.01" max="0.04"/>
				<units>1/year</units>
			</aux>
			<aux name="actual unemployment goal" access="output">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>historical_unemployment_goal+RAMP(SIGN(unemployment_goal_policy-historical_unemployment_goal)*max_change_per_year_in_unemployment, time_to_start_central_bank_unemployment_policy, time_to_start_central_bank_unemployment_policy + ABS(historical_unemployment_goal-unemployment_goal_policy)/max_change_per_year_in_unemployment )</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="historical unemployment goal">
				<doc>${Assumption}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.05</eqn>
				<range min="0.02" max="0.08"/>
				<units>dmnl</units>
			</aux>
			<aux name="tax rate on newly installed\nsolar\nenergy capacity" access="output" isee:autocreated="true">
				<doc>${Policy}
</doc>
				<eqn>TIME</eqn>
				<gf>
					<xscale min="2020" max="2100"/>
					<yscale min="-0.75" max="1"/>
					<ypts>0,0,0,0,0,0,0,0,0</ypts>
				</gf>
				<units>dmnl</units>
			</aux>
			<aux name="tax rate on newly installed\nwind\nenergy capacity" access="output" isee:autocreated="true">
				<doc>${Policy}
</doc>
				<eqn>TIME</eqn>
				<gf>
					<xscale min="2020" max="2100"/>
					<yscale min="-0.75" max="1"/>
					<ypts>0,0,0,0,0,0,0,0,0</ypts>
				</gf>
				<units>dmnl</units>
			</aux>
			<aux name="SLR adaptation start year" access="output">
				<doc>${Policy}
</doc>
				<eqn>2025</eqn>
				<format precision="1"/>
				<range min="2025" max="2100"/>
				<units>Year</units>
			</aux>
			<aux name="time to start\ncentral bank unemployment\npolicy">
				<doc>${Policy}
</doc>
				<eqn>2025</eqn>
				<format precision="1"/>
				<range min="2025" max="2075"/>
				<units>Year</units>
			</aux>
			<aux name="debt to gdp level start year">
				<doc>${Policy}
</doc>
				<eqn>2025</eqn>
				<format precision="1"/>
				<range min="2025" max="2100"/>
				<units>Year</units>
			</aux>
			<aux name="switch profit tax policy" access="output" isee:autocreated="true">
				<doc>${Policy}
</doc>
				<eqn>0</eqn>
				<format precision="1"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="time to implement\nprofit tax policy" access="output" isee:autocreated="true">
				<doc>${Policy}
</doc>
				<eqn>5</eqn>
				<range min="5" max="75"/>
				<units>years</units>
			</aux>
			<aux name="profit tax policy start year" access="output">
				<doc>${Policy}
</doc>
				<eqn>2025</eqn>
				<format precision="1"/>
				<range min="2025" max="2100"/>
				<units>Year</units>
			</aux>
			<aux name="time to implement\nwealth tax policy" access="output" isee:autocreated="true">
				<doc>${Policy}
</doc>
				<eqn>5</eqn>
				<range min="5" max="75"/>
				<units>years</units>
			</aux>
			<aux name="wealth tax policy start year" access="output">
				<doc>${Policy}
</doc>
				<eqn>2025</eqn>
				<format precision="1"/>
				<range min="2025" max="2100"/>
				<units>Year</units>
			</aux>
			<aux name="central bank led investment\npolicy start year" access="output" isee:autocreated="true">
				<doc>${Policy}
</doc>
				<eqn>2175</eqn>
				<units>year</units>
			</aux>
			<group name="Climate-driven default\npublic investment policy" run="false">
				<format scale_by="auto"/>
				<entity name="central_bank_led_investment_policy_start_year"/>
				<entity name="fraction_of_public_investments_financed_by_taxation"/>
				<entity name="government_run_investment_policy_start_year"/>
				<entity name="growth_rate_target_for_government_public_investments"/>
				<entity name="share_of_public_investments_financed_by_profit_taxation"/>
				<entity name="share_of_public_investments_financed_by_rent_taxation"/>
				<entity name="share_of_public_investments_financed_by_wage_taxation"/>
				<entity name="share_of_public_investments_financed_by_wealth_taxation"/>
				<entity name="sum_of_public_investment_tax_share"/>
			</group>
			<aux name="government run investment\npolicy start year" access="output" isee:autocreated="true">
				<doc>${Policy}
</doc>
				<eqn>2175</eqn>
				<units>year</units>
			</aux>
			<aux name="fraction of public investments\nfinanced by taxation" access="output" isee:autocreated="true">
				<doc>${Policy}
This variable is to address what share of gov run public investment is paid by taxes.</doc>
				<eqn>0.8</eqn>
				<format precision="0.01"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="share of public investments\nfinanced by wage taxation" access="output" isee:autocreated="true">
				<doc>${Policy}
The purpose is to understand how government split the burden of different tax to fund the public investment, especially how much % of policy carried by wage taxation </doc>
				<eqn>0.25</eqn>
				<format precision="0.01"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="share of public investments\nfinanced by profit taxation" access="output" isee:autocreated="true">
				<doc>${Policy}
The purpose is to understand how government split the burden of different tax to fund the public investment, especially how much % of policy carried by profit taxation </doc>
				<eqn>0.25</eqn>
				<format precision="0.01"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="share of public investments\nfinanced by rent taxation" access="output" isee:autocreated="true">
				<doc>${Policy}
The purpose is to understand how government split the burden of different tax to fund the public investment, especially how much % of policy carried by rent taxation </doc>
				<eqn>0.25</eqn>
				<format precision="0.01"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="share of public investments\nfinanced by wealth taxation" access="output" isee:autocreated="true">
				<doc>${Policy}
The purpose is to understand how government split the burden of different tax to fund the public investment, especially how much % of policy carried by wealth taxation </doc>
				<eqn>0.25</eqn>
				<format precision="0.01"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="sum of public\ninvestment tax share">
				<eqn>share_of_public_investments_financed_by_rent_taxation+
share_of_public_investments_financed_by_profit_taxation+
share_of_public_investments_financed_by_wage_taxation+
share_of_public_investments_financed_by_wealth_taxation</eqn>
				<units>dmnl</units>
				<event_poster>
					<threshold direction="increasing" value="1" repeat="each">
						<event sim_action="stop" isee:kind="model_only">
							<isee:navigate_to>
								<entity name="sum of public investment tax share"/>
							</isee:navigate_to>
							<text_box>Warning! Sum of public investment tax share is more than 1</text_box>
						</event>
					</threshold>
				</event_poster>
			</aux>
			<aux name="growth rate target for\ngovernment public investments" access="output" isee:autocreated="true">
				<doc>${Policy}
This is the desired annual real GDP growth rate the policy tries to support.</doc>
				<eqn>0.04</eqn>
				<format precision="0.001"/>
				<range min="0" max="0.1"/>
				<units>1/year</units>
			</aux>
			<group name="Climate-driven default\ninsurance policy" run="false">
				<format scale_by="auto"/>
				<entity name="decision_fraction_of_default_covered_by_central_bank_insurance"/>
				<entity name="decision_fraction_of_default_covered_by_government_insurance"/>
				<entity name="decision_fraction_of_default_covered_by_private_insurance"/>
				<entity name="fraction_of_default_covered_by_central_bank_insurance"/>
				<entity name="fraction_of_default_covered_by_government_insurance"/>
				<entity name="fraction_of_default_covered_by_private_insurance"/>
				<entity name="fraction_of_loans_insured"/>
				<entity name="insurance_coverage_level"/>
				<entity name="insurance_coverage_start_year"/>
				<entity name="insurance_coverage_time_to_implement"/>
				<entity name="total_insurance_coverage"/>
			</group>
			<aux name="fraction of loans insured" access="output" isee:autocreated="true">
				<eqn>RAMP(insurance_coverage_level / insurance_coverage_time_to_implement,
insurance_coverage_start_year,
insurance_coverage_start_year + insurance_coverage_time_to_implement)
/ 100</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="insurance coverage time\nto implement">
				<doc>${Policy}
A policy parameter sets how long (duration) it takes to ramp from 0 to first-level coverage</doc>
				<eqn>1</eqn>
				<format precision="0.01"/>
				<units>Year</units>
			</aux>
			<aux name="insurance coverage\nstart year">
				<doc>${Policy}
A policy parameter sets the year the insurance policy starts.</doc>
				<eqn>2035.26</eqn>
				<format precision="1"/>
				<units>Year</units>
			</aux>
			<aux name="insurance coverage level">
				<doc>${Policy}
A policy parameter sets how much the first target coverage level, in percent</doc>
				<eqn>70</eqn>
				<format precision="0.01"/>
				<range min="0" max="100"/>
				<units>dmnl</units>
			</aux>
			<aux name="decision fraction of default\ncovered by government insurance">
				<doc>${Policy}
A policy parameter sets how much of climate-caused risky defaults  absorbed or funded by government  insurance absorbs.</doc>
				<eqn>0</eqn>
				<format precision="0.01"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="decision fraction of default\ncovered by central\nbank insurance">
				<doc>${Policy}
A policy parameter sets how much of climate-caused risky defaults  absorbed or funded by central bank insurance.</doc>
				<eqn>0</eqn>
				<format precision="0.01"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="decision fraction of default\ncovered by private insurance">
				<doc>${Policy}
A policy parameter sets how much of climate-caused risky defaults absorbed or funded by private insurance.</doc>
				<eqn>0</eqn>
				<format precision="0.01"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="total insurance coverage">
				<doc>This variable is the total of funding-share decisions.
</doc>
				<eqn>decision_fraction_of_default_covered_by_private_insurance + decision_fraction_of_default_covered_by_central_bank_insurance + decision_fraction_of_default_covered_by_government_insurance</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="fraction of default\ncovered by private insurance" access="output" isee:autocreated="true">
				<doc>${Policy}
A policy parameter sets how much of climate-caused risky defaults private insurance absorbs.</doc>
				<eqn>decision_fraction_of_default_covered_by_private_insurance//total_insurance_coverage*fraction_of_loans_insured</eqn>
				<format precision="0.01"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="fraction of default covered\nby central bank insurance" access="output" isee:autocreated="true">
				<doc>${Policy}
This parameter specifies the share of climate-caused risky defaults that the central bank agrees to cover through its insurance intervention.</doc>
				<eqn>decision_fraction_of_default_covered_by_central_bank_insurance//total_insurance_coverage*fraction_of_loans_insured</eqn>
				<format precision="0.01"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="fraction of default covered\nby government insurance" access="output" isee:autocreated="true">
				<doc>${Policy}
This parameter determines the share of climate-caused risky defaults that the government agrees to absorb.</doc>
				<eqn>decision_fraction_of_default_covered_by_government_insurance//total_insurance_coverage*fraction_of_loans_insured</eqn>
				<format precision="0.01"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<group name="Energy Policy" run="false">
				<format scale_by="auto"/>
				<entity name="biofuels_CO2e_emissions_tax_reduction_share"/>
				<entity name="biofuels_SO2_emissions_tax_reduction_share"/>
				<entity name="fossil_extraction_capacity_placeholder"/>
				<entity name="fossil_production_capacity_placeholder"/>
				<entity name="Max_Share_of_GDP_expended_for_Bio_Energy_Subsidies"/>
				<entity name="Max_Share_of_GDP_expended_for_Coal_Energy_Conversion_Capital"/>
				<entity name="Max_Share_of_GDP_expended_for_Coal_Extraction_Subsidies"/>
				<entity name="Max_Share_of_GDP_expended_for_Gas_Energy_Conversion_Capital"/>
				<entity name="Max_Share_of_GDP_expended_for_Gas_Extraction_Subsidies"/>
				<entity name="Max_Share_of_GDP_expended_for_Hydro_Energy_Subsidies"/>
				<entity name="Max_Share_of_GDP_expended_for_Nuclear_Energy_Subsidies"/>
				<entity name="Max_Share_of_GDP_expended_for_Oil_Energy_Conversion_Capital"/>
				<entity name="Max_Share_of_GDP_expended_for_Oil_Extraction_Subsidies"/>
				<entity name="Max_Share_of_GDP_expended_for_Solar_Energy_Subsidies"/>
				<entity name="Max_Share_of_GDP_expended_for_Wind_Energy_Subsidies"/>
				<entity name="Moratorium_on_fossil_energy_year"/>
				<entity name="rate_of_decommissioning_coal_fossil_fuel_extraction_capital"/>
				<entity name="rate_of_decommissioning_extraction_capital"/>
				<entity name="rate_of_decommissioning_gas_fossil_fuel_extraction_capital"/>
				<entity name="rate_of_decommissioning_oil_fossil_fuel_extraction_capital"/>
				<entity name="renewable_capacity_placeholder"/>
				<entity name="share_of_biofuel_emissions_stored"/>
				<entity name="share_of_coal_emissions_stored"/>
				<entity name="share_of_emissions_stored"/>
