			<aux name="Ocean overturning strength">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Reference_overturning_strength_in_Sv[selected_climate_case_1[Run]]*from_Sv_to_cubic_metre_per_year</eqn>
				<format precision="full"/>
				<units>metre^3/year</units>
			</aux>
			<aux name="from Sv to\ncubic metre per year">
				<eqn>UNIT_Sv_to_Cubic_metre*UNIT_Seconds_per_year_1</eqn>
				<units>metre^3/year/Sv</units>
			</aux>
			<aux name="Intermediate to warm surface ocean mixing strength">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
