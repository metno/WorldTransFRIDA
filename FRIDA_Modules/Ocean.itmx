				<format precision="full"/>
				<range min="28000" max="31000"/>
				<units>GtC</units>
			</aux>
			<stock name="Deep ocean\nocean carbon reservoir">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Initial_Deep_ocean_ocean_carbon_reservoir[selected_climate_case[Run]]</eqn>
				<format precision="full"/>
				<inflow>Downward_transport_of_carbon_via_the_overturning_circulation</inflow>
				<inflow>Convective_mixing_of_carbon_between_polar_surface_ocean_and_deep_ocean</inflow>
				<inflow>Biological_carbon_pump_C_export_to_the_deep_ocean</inflow>
				<outflow>Upward_transport_of_carbon_from_the_deep_ocean_via_the_overturning_circulation</outflow>
				<units>GtC</units>
			</stock>
			<flow name="Downward transport of carbon via the overturning circulation">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Ocean_overturning_strength*Cold_surface_ocean_carbon_reservoir/Volume_of_cold_surface_ocean_reservoir</eqn>
				<format precision="full"/>
				<units>GtC/Year</units>
			</flow>
			<flow name="Convective mixing of carbon between polar surface ocean and deep ocean">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Cold_surface_to_deep_ocean_mixing_strength * (Cold_surface_ocean_carbon_reservoir/Volume_of_cold_surface_ocean_reservoir-Deep_ocean_ocean_carbon_reservoir/Volume_of_deep_ocean_reservoir)</eqn>
				<format precision="full"/>
				<units>GtC/Year</units>
			</flow>
			<flow name="Low latitude ocean air\nsea carbon uptake">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Air_sea_gas_exchange_coefficient*Ocean_surface_area*Warm_surface_ocean_area_fraction*(Atmospheric_CO2_Concentration-Warm_surface_ocean_pCO2) / UNIT_GtC_to_kmol</eqn>
				<format precision="full"/>
				<units>GtC/Year</units>
			</flow>
			<flow name="High latitude ocean air\nsea carbon uptake">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Air_sea_gas_exchange_coefficient*Ocean_surface_area*(1.0 - Warm_surface_ocean_area_fraction) * (Atmospheric_CO2_Concentration - Cold_surface_ocean_pCO2) / UNIT_GtC_to_kmol_1</eqn>
				<format precision="full"/>
				<units>GtC/Year</units>
			</flow>
			<flow name="Upward transport of carbon from the deep ocean via the overturning circulation">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Ocean_overturning_strength*Deep_ocean_ocean_carbon_reservoir/Volume_of_deep_ocean_reservoir</eqn>
				<format precision="full"/>
				<units>GtC/Year</units>
			</flow>
			<flow name="Mixing of carbon from intermediate\ndepth to the warm surface ocean">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Intermediate_to_warm_surface_ocean_mixing_strength * (Intermediate_depth_ocean_carbon_reservoir/Volume_of_intermediate_ocean_reservoir - Warm_surface_ocean_carbon_reservoir/Volume_of_warm_surface_ocean_reservoir)</eqn>
				<format precision="full"/>
				<units>GtC/Year</units>
			</flow>
