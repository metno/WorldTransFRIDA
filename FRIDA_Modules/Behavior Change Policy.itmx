	<model name="Behavior_Change_Policy">
		<variables>
			<aux name="APD value shift policy\neffect multiplier">
				<doc>${Policy}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.3</eqn>
				<range min="0.2" max="0.4"/>
				<units>dmnl</units>
			</aux>
			<aux name="value shift policy\ntime to fully take effect">
				<doc>${Policy}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>10</eqn>
				<range min="10" max="20"/>
				<units>years</units>
			</aux>
			<aux name="value shift policy\nstart year">
				<doc>${Policy}
</doc>
				<eqn>2030</eqn>
				<units>year</units>
			</aux>
			<aux name="value shift policy\nswitch">
				<doc>${Policy}
</doc>
				<eqn>0</eqn>
				<format precision="1"/>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="APD value shift policy" access="output">
				<doc>${Policy}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF value_shift_policy_switch AND TIME &gt; value_shift_policy_start_year
THEN
1 - SMTH3(STEP(APD_value_shift_policy_effect_multiplier, value_shift_policy_start_year),  value_shift_policy_time_to_fully_take_effect)
ELSE 
1</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="TFD value shift policy" access="output">
				<doc>${Policy}
</doc>
				<dimensions>
