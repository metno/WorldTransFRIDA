THEN
1 - SMTH3(STEP(TFD_value_shift_policy_effect_multiplier, value_shift_policy_start_year),  value_shift_policy_time_to_fully_take_effect)
ELSE 
1</eqn>
				<units>dmnl</units>
			</aux>
