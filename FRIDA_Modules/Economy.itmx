				<alias color="black" background="white" font_style="italic" font_weight="bold" font_color="black" uid="47" x="1192.87" y="422.276" width="18" height="18">
					<of>safe_interest</of>
				</alias>
			</view>
		</views>
	</model>
	<model name="Circular_Flow">
		<variables>
			<stock name="Firms\nChecking\nAccounts" access="output" isee:autocreated="true">
				<doc>Represents the firms&apos; liquid assets in its checking account, which can be readily used for payments such as wages, consumption, or other immediate expenses. It increases with 

</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>initial_firms_checking_accounts</eqn>
				<inflow>owner_consumption</inflow>
				<inflow>government_spending</inflow>
				<inflow>private_investment</inflow>
				<inflow>Central_Bank_public_investment</inflow>
				<inflow>worker_consumption</inflow>
				<outflow>non_bank_profits</outflow>
				<outflow>wages</outflow>
				<outflow>firms_paying_interest</outflow>
				<outflow>rent</outflow>
				<outflow>firms_taxes</outflow>
				<units>b$</units>
			</stock>
			<flow name="owner consumption" access="output" isee:autocreated="true">
				<doc>Forced climate-related relocation spending is treated as owner consumption expenditure.
Even though it is not voluntary consumption (like food, leisure, electronics), it is still a HHs expense that reduces their savings and affects their ability to consume other goods. Additionally, Owner households represent the wealthy asset-owning segment.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>actual_owner_consumption+Actual_people_retreat_cost_from_SLR

{MAX(smoothed_owner_net_income*minimum_fraction_of_income_to_consumption;
(smoothed_owner_net_income*fraction_of_owner_income_to_consumption)*(1+Inflation.inflation)-annual_owner_savings_to_reach_goal)

{MAX (adjusted_owner_consumption; net_owner_income*minimum_fraction_of_owner_income_to_consumption)</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<flow name="non bank profits" access="output">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Firms_Checking_Accounts/time_to_pay_out_profits</eqn>
				<units>b$/year</units>
			</flow>
			<stock name="owner\nsavings" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>initial_owner_savings</eqn>
				<inflow>non_bank_profits</inflow>
				<inflow>owner_savings_interest</inflow>
				<inflow>bank_profits</inflow>
				<inflow>rent</inflow>
				<outflow>owner_consumption</outflow>
				<outflow>profit_tax</outflow>
				<outflow>rent_tax</outflow>
				<outflow>wealth_tax</outflow>
				<outflow>insurance_taxation</outflow>
				<units>b$</units>
			</stock>
			<aux name="desired savings\nas multiple of\nprofits">
				<doc>${Internal Calibration Parameter}
This means owners want to hold financial wealth equal to about 12 times their net annual income. E.g., If a owners earns 1 B$ per year, their desired wealth ≈ 12 B$.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>12.0061535532014</eqn>
				</element>
				<range min="2" max="20"/>
				<units>Years</units>
			</aux>
			<aux name="owner savings\ngoal shortfall">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>desired_owner_savings-owner_savings</eqn>
				<units>b$</units>
			</aux>
			<aux name="desired owner\nsavings">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{SMTH1((net_owner_income*desired_savings_as_multiple_of_profits); time_to_consider_desired_savings)}

SMTH1(net_owner_income*desired_savings_as_multiple_of_profits, time_to_consider_desired_savings)</eqn>
				<isee:delay_aux/>
				<units>b$</units>
			</aux>
			<aux name="time to consider\ndesired savings">
				<doc>${Internal Calibration Parameter}
Workers or owners do not update their desired savings instantly when income changes. Instead, they consider and adjust their target savings gradually over ~2.4 years.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>2.37308188895326</eqn>
				</element>
				<range min="1" max="10"/>
				<units>Years</units>
			</aux>
			<aux name="time to reach\nsavings goal">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>4.98074684444826</eqn>
				</element>
				<range min="1" max="5"/>
				<units>year</units>
			</aux>
			<aux name="annual\nowner savings\nto reach goal">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>owner_savings_goal_shortfall/time_to_reach_savings_goal</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="minimum\nfraction of income\nto consumption">
				<doc>${Assumption,Internal Calibration Parameter}
Regardless of savings goals, households must allocate at least 35% of income to consumption.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.35</eqn>
				<range min="0.25" max="0.45"/>
				<units>dmnl</units>
			</aux>
			<stock name="Worker\nSavings" access="output" isee:autocreated="true">
				<doc>A stock representing the accumulated financial assets held by workers.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>initial_worker_savings</eqn>
				<inflow>wages</inflow>
				<inflow>worker_savings_interest</inflow>
				<inflow>transfers</inflow>
				<outflow>worker_consumption</outflow>
				<outflow>wage_tax</outflow>
				<units>b$</units>
			</stock>
			<flow name="wages" access="output">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>annual_aggregate_wages</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<flow name="worker consumption" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>actual_worker_consumption</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="annual\nworker savings\nto reach goal">
				<doc>yearly portion of shortfall in saving compared to desired</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>worker_savings_goal_shortfall/time_to_reach_savings_goal</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="worker savings\ngoal shortfall">
				<doc>How much the gap between actual saving to the desired saving (desired - actual).</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>desired_worker_savings-Worker_Savings</eqn>
				<units>b$</units>
			</aux>
			<aux name="desired worker\nsavings">
				<doc>It is the target level of savings that workers want to have, based on their income.

Workers want to hold savings proportional to their income.
They adjust their actual savings toward this target gradually, not instantly. This reflects real-world economic behavior where households have desired saving goals tied to income and adjust slowly.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{SMTH1((net_worker_income*desired_savings_as_multiple_of_wages); time_to_consider_desired_savings)}

SMTH1((net_worker_income*desired_savings_as_multiple_of_wages), time_to_consider_desired_savings)</eqn>
				<isee:delay_aux/>
				<units>b$</units>
			</aux>
			<aux name="desired savings\nas multiple of\nwages">
				<doc>${Internal Calibration Parameter}
This means workers want to hold financial wealth equal to about 1.1976 times their net annual income. E.g., If a worker earns 1 B$ per year, their desired wealth ≈ 1.2 B$.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>1.19760938234432</eqn>
				</element>
				<range min="1" max="5"/>
				<units>Years</units>
			</aux>
			<flow name="firms paying\ninterest" access="output" isee:autocreated="true">
				<doc>Firms have borrowed money from banks (bank assets = firm liabilities).</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(risky_bank_assets*risky_interest_1)
+ (safe_bank_assets*average_private_debt_interest)
+(exploratory_bank_assets*exploratory_interest)
+ Central_Bank_interest_payment</eqn>
				<units>B$/year</units>
			</flow>
			<flow name="worker savings\ninterest">
				<doc>Workers earn interest income on their savings. Households deposit their savings in banks. Banks pay them a safe interest rate on these deposits.

The worker savings earn interest equal to the average safe private debt interest rate, because:
- Banks pay a lower, stable interest on deposits.
- Deposits are considered safe liabilities.
- A smoother, slow-moving rate prevents unrealistic volatility in household income.

Thus, worker interest income reflects a delayed and damped response to monetary policy.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Worker_Savings*average_private_debt_interest</eqn>
				<units>B$/year</units>
			</flow>
			<flow name="owner savings interest">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>owner_savings*average_private_debt_interest</eqn>
				<units>B$/year</units>
			</flow>
			<flow name="bank profits" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>bank_profit_payment_1</eqn>
				<non_negative/>
				<units>B$/year</units>
			</flow>
			<flow name="wage tax" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>wages
* actual_wage_tax_rate</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="wage tax rate">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.213245509607868</eqn>
				</element>
				<range min="0.1" max="0.3"/>
				<units>dmnl</units>
			</aux>
			<flow name="profit tax" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MAX(0, (non_bank_profits+bank_profits))*actual_profit_tax_rate</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="initial owner savings">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>46357.0465153</eqn>
				<range min="30000" max="60000"/>
				<units>b$</units>
			</aux>
			<aux name="initial firms\nchecking accounts">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>5003.53414951</eqn>
				<range min="4000" max="10000"/>
				<units>b$</units>
			</aux>
			<aux name="initial worker savings">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>22209.0362704</eqn>
				<range min="20000" max="30000"/>
				<units>b$</units>
			</aux>
			<flow name="government\nspending">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>government_consumption+public_investment_1+sum_of_subsidies_spent</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<flow name="private investment" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>private_investment_1</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="private consumption" isee:derived_units="true" access="output" isee:autocreated="true">
				<doc>${Calibrated Output}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>owner_consumption+worker_consumption</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="time to pay out profits">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>2.52172418404836</eqn>
				</element>
				<range min="1" max="5"/>
				<units>year</units>
			</aux>
			<flow name="rent" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>rent_3</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<flow name="rent tax" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>rent*actual_rent_tax_rate</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="net worker income">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>gross_worker_income
-wage_tax
{wages
+transfers
+bank_wages
+worker_savings_interest
-wage_tax</eqn>
				<units>b$/year</units>
			</aux>
			<flow name="transfers">
				<doc>Transfers represent public payments to households (workers) that support income: unemployment benefits, retirement support, child support, etc.
In macroeconomics, transfers are a redistribution from government to households but not payment for production.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>government_transfers_1</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="net owner income">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>gross_owner_income
-rent_tax
-profit_tax</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="government\nconsumption" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="public\ninvestment 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="government\ntransfers 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="safe bank assets" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$</units>
			</aux>
			<aux name="risky bank assets" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$</units>
			</aux>
			<aux name="risky\ninterest 1" access="output" throughput="true" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>1/year</units>
			</aux>
			<aux name="fraction of income to consumption">
				<doc>${Assumption,Internal Calibration Parameter}
Workers normally want to consume a larger share of income. This represents “habitual” or “normal” consumption patterns.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.75</eqn>
				</element>
				<range min="0.65" max="0.85"/>
				<units>dmnl</units>
			</aux>
			<aux name="fraction of\nowner income\nto consumption">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.75</eqn>
				</element>
				<range min="0.65" max="0.85"/>
				<units>dmnl</units>
			</aux>
			<aux name="consumption habits\nadjustment time">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>1.464111314</eqn>
				</element>
				<range min="0.5" max="2.5"/>
				<units>years</units>
			</aux>
			<aux name="rent 3" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="annual\naggregate wages" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="indicated owner\nconsumption">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MAX(net_owner_income*minimum_fraction_of_income_to_consumption,
net_owner_income*fraction_of_owner_income_to_consumption-annual_owner_savings_to_reach_goal)</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="actual owner\nconsumption">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(indicated_owner_consumption, consumption_habits_adjustment_time)*(1+inflation_effect_on_consumption)</eqn>
				<isee:delay_aux/>
				<units>b$/year</units>
			</aux>
			<aux name="actual percentage of owner income to consumption">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>owner_consumption//net_owner_income*100</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="actual worker\nconsumption">
				<doc>Workers do not instantly consume the amount they indicate they want to. They adjust gradually over time (over roughly 1.46 years after calibration).

It is multiplied by (1 + inflation effect on consumption) because inflation influence how much they actually consume. Inflation here acts like a behavioral modifier rather than a pure addition or subtraction.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(indicated_worker_consumption, consumption_habits_adjustment_time)*(1+inflation_effect_on_consumption)</eqn>
				<isee:delay_aux/>
				<units>b$/year</units>
			</aux>
			<aux name="indicated worker\nconsumption">
				<doc>This is the raw consumption desire before the smoothing that creates actual worker consumption.
This equation defines how much workers want to consume given their income, their minimum required consumption, and their savings goal.


net_worker_income*fraction_of_income_to_consumption-annual_worker_savings_to_reach_goal --&gt; How much workers normally want to spend minus
how much they need to save each year to catch up to their savings goal.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MAX(net_worker_income*minimum_fraction_of_income_to_consumption,
net_worker_income*fraction_of_income_to_consumption-annual_worker_savings_to_reach_goal)</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="actual percentage of worker income to consumption">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>worker_consumption/net_worker_income*100</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="ratio of profits\nto wages">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>non_bank_profits/wages</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="exploratory\nbank assets" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$</units>
			</aux>
			<aux name="exploratory\ninterest" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>1/year</units>
			</aux>
			<aux name="bank profit\npayment 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="inflation effect\non consumption">
				<doc>This expresses how inflation influences how much workers actually consume, while the time here is the responsiveness parameter</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Inflation_Rate*time_for_inflation_to_change_consumption</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="time for inflation to change\nconsumption">
				<doc>${Internal Calibration Parameter,Unit}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1</eqn>
				<range min="0.5" max="2"/>
				<units>year</units>
			</aux>
			<stock name="Inflation Rate" access="output" throughput="true" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.13</eqn>
				<units>1/year</units>
			</stock>
			<aux name="firms cash net flow">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Firms_cash_inflow-firms_cash_outflow</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="firms cash outflow">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>non_bank_profits + wages + firms_paying_interest + rent</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Firms cash inflow">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>worker_consumption + owner_consumption + government_spending + private_investment</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="real private consumption 2021c$" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>private_consumption/&quot;inflation_adjustment_b$_per_bc$&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="sum of energy taxes" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<flow name="firms taxes">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>sum_of_energy_taxes</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="sum of subsidies spent" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="income inequality">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>net_owner_income/net_worker_income</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="inflation adjustment b$ per bc$" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/bc$</units>
			</aux>
			<aux name="Actual people\nretreat cost from SLR">
				<doc>${Assumption}
SLR costs are assumed to be paid quickly.

It means how much money the economy actually pays each year for relocating people due to sea-level rise.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(Total_nominal_people_retreat_costs, Time_to_pay_for_SLR_retreat_costs,  Initial_actual_people_retreat_cost_from_SLR)</eqn>
				<isee:delay_aux/>
				<units>b$/year</units>
			</aux>
			<aux name="Time to pay for\nSLR retreat costs">
				<doc>${Assumption}
Assume SLR retreat costs are paid quickly</doc>
				<eqn>1</eqn>
				<units>year</units>
			</aux>
			<aux name="Initial actual people\nretreat cost from SLR">
				<doc>${Assumption}
Assuming no one is migrating in 1980 b/c of SLR</doc>
				<eqn>0</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Total nominal people\nretreat costs" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="wage tax policy" access="input">
				<eqn>.1</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="start year" access="input">
				<eqn>2025</eqn>
				<units>Year</units>
			</aux>
			<aux name="actual wage tax policy">
				<doc>If the government turns on the wage-tax policy, then slowly adjust the wage tax rate from its old level to the new policy level over a chosen number of years. If the policy is not turned on, keep the old tax rate.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF TIME &gt; start_year AND switch_tax_policy = 1 
THEN wage_tax_rate[Run] + RAMP((wage_tax_policy-wage_tax_rate[Run])/time_to_implement_wage_tax_policy, start_year, start_year+ time_to_implement_wage_tax_policy) 
ELSE wage_tax_rate[Run]</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="switch tax policy" access="input">
				<eqn>0</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="profit tax rate policy" access="input">
				<eqn>.22</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="actual profit tax policy">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF TIME &gt; profit_tax_policy_start_year AND switch_profit_tax_policy = 1 THEN profit_tax_rate[Run] + RAMP((profit_tax_rate_policy-profit_tax_rate[Run])/time_to_implement_profit_tax_policy, profit_tax_policy_start_year, profit_tax_policy_start_year+ time_to_implement_profit_tax_policy) ELSE profit_tax_rate[Run]</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="profit tax rate">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.334795866407069</eqn>
				</element>
				<range min="0" max="0.4"/>
				<units>dmnl</units>
			</aux>
			<aux name="wealth taxation rate" access="input">
				<eqn>0</eqn>
				<units>1/year</units>
			</aux>
			<flow name="wealth tax" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>owner_savings
* actual_wealth_tax_rate</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="actual wealth tax policy">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>RAMP((wealth_taxation_rate)/time_to_implement_wealth_tax_policy, wealth_tax_policy_start_year, wealth_tax_policy_start_year+ time_to_implement_wealth_tax_policy)</eqn>
				<units>1/year</units>
			</aux>
			<aux name="gross worker income">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>wages+worker_savings_interest+transfers</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="gross owner income">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>non_bank_profits
+rent
+owner_savings_interest
+bank_profits</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="gross income">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>gross_owner_income+gross_worker_income</eqn>
				<format precision="full"/>
				<units>b$/year</units>
			</aux>
			<aux name="share of gross income from non bank profits">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>non_bank_profits/gross_income</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="share of gross income from rent">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>rent/gross_income</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="share of gross income from bank profits">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>bank_profits/gross_income</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="share of gross income from owner savings interest">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>owner_savings_interest/gross_income</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="share of gross income from transfers">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>transfers/gross_income</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="share of gross income from worker savings\ninterest">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>worker_savings_interest/gross_income</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="share of gross income from wages">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>wages/gross_income</eqn>
				<units>1</units>
			</aux>
			<aux name="inflation adjustment b$ per bc$ 1" access="output" throughput="true" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/bc$</units>
			</aux>
			<aux name="non bank profits in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>non_bank_profits/&quot;inflation_adjustment_b$_per_bc$_1&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="rent in in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>rent/&quot;inflation_adjustment_b$_per_bc$_1&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="bank profits in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>bank_profits/&quot;inflation_adjustment_b$_per_bc$_1&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="owner savings interest in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>owner_savings_interest/&quot;inflation_adjustment_b$_per_bc$_1&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="transfers in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>transfers/&quot;inflation_adjustment_b$_per_bc$_1&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="worker savings interest in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>worker_savings_interest/&quot;inflation_adjustment_b$_per_bc$_1&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="wages in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>wages/&quot;inflation_adjustment_b$_per_bc$_1&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="wage tax in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>wage_tax/&quot;inflation_adjustment_b$_per_bc$_1&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="rent tax in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>rent_tax/&quot;inflation_adjustment_b$_per_bc$_1&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="profit tax in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>profit_tax/&quot;inflation_adjustment_b$_per_bc$_1&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="net worker income in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>net_worker_income/&quot;inflation_adjustment_b$_per_bc$_1&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="net owner income in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>net_owner_income/&quot;inflation_adjustment_b$_per_bc$_1&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="wages after tax in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>&quot;wages_in_2021c$&quot;-&quot;wage_tax_in_2021c$&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="non bank profits\nafter tax in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>&quot;non_bank_profits_in_2021c$&quot;*(1-actual_profit_tax_policy)</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="bank profits after tax in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>&quot;bank_profits_in_2021c$&quot;*(1-actual_profit_tax_policy)</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="rent after tax in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>&quot;rent_in_in_2021c$&quot;-&quot;rent_tax_in_2021c$&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="net income">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>net_owner_income+net_worker_income</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="worker share of net income">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>net_worker_income/net_income*UNIT_Percent</eqn>
				<units>%</units>
			</aux>
			<aux name="UNIT Percent" access="input">
				<eqn>100</eqn>
				<units>%</units>
			</aux>
			<aux name="average private debt interest" access="output" throughput="true" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>1/year</units>
			</aux>
			<aux name="private investment 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Nominal GDP" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Labour share of GDP">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>wages/Nominal_GDP</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="gross income in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>gross_income/&quot;inflation_adjustment_b$_per_bc$_1&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="bottom 40\nshare of wages">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(normal_bottom_40_wages*effect_of_productivity_growth_on_bottom_40_share_of_wages, time_for_bottom_40_to_be_affected)</eqn>
				<isee:delay_aux/>
				<units>dmnl</units>
			</aux>
			<aux name="bottom 40\nincome">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>&quot;wages_in_2021c$&quot;*bottom_40_share_of_wages</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="bottom 40\nshare of real income">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>bottom_40_income/&quot;gross_income_in_2021c$&quot;</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="realised\nproductivity\ngrowth" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>dmnl/Year</units>
			</aux>
			<aux name="normal bottom\n40 wages">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.115583999962909</eqn>
				<range min="0.05" max="0.15"/>
				<units>dmnl</units>
			</aux>
			<aux name="relative productivity growth">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>realised_productivity_growth/INIT(realised_productivity_growth)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="time for bottom\n40 to be affected">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>2.71713962769918</eqn>
				<range min="1" max="20"/>
				<units>years</units>
			</aux>
			<aux name="effect of productivity growth\non bottom 40 share of wages">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>LOGISTICBOUND(yfrom, yto, relative_productivity_growth, xmiddle,xspeed,  xstart, xfinish)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="yfrom">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1.67205935445357</eqn>
				<range min="1.1" max="2"/>
				<units>dmnl</units>
			</aux>
			<aux name="yto">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.579171144362919</eqn>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="xmiddle">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.7433791877887</eqn>
				<range min="0.5" max="1.5"/>
				<units>dmnl</units>
			</aux>
			<aux name="xspeed">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>14.6643169927886</eqn>
				<range min="1" max="50"/>
				<units>dmnl</units>
			</aux>
			<aux name="xstart">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.0366895585426691</eqn>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="xfinish">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1.46654779942244</eqn>
				<range min="1" max="2"/>
				<units>dmnl</units>
			</aux>
			<aux name="UNIT forty percent">
				<doc>${Unit}
</doc>
				<eqn>0.4</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="forty percent\nof population">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Population_1*UNIT_forty_percent</eqn>
				<units>Mp</units>
			</aux>
			<aux name="bottom 40 income\nper capita">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(bottom_40_income*UNIT_dollars_per_billion/forty_percent_of_population)/UNIT_persons_per_million_people</eqn>
				<units>c$/person/year</units>
			</aux>
			<aux name="growth rates of income per capita\namong the bottom 40 per cent\nof the total population">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>TREND(bottom_40_income_per_capita, 1)</eqn>
				<units>1/year</units>
			</aux>
			<aux name="UNIT dollars per billion">
				<doc>${Unit}
</doc>
				<eqn>1000000000</eqn>
				<units>c$/Bc$</units>
			</aux>
			<aux name="UNIT persons per\nmillion people">
				<doc>${Unit}
</doc>
				<eqn>1000000</eqn>
				<units>p/Mp</units>
			</aux>
			<aux name="Population 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>Mp</units>
			</aux>
			<aux name="real transfers per capita">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>&quot;transfers_in_2021c$&quot;/Population_1</eqn>
				<units>bc$/Mp/year</units>
			</aux>
			<aux name="Redistributive impact\nof fiscal policy">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>transfers/net_worker_income</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="time to implement\nprofit tax policy" access="input">
				<eqn>5</eqn>
				<units>years</units>
			</aux>
			<aux name="time to implement\nwage tax policy" access="input">
				<eqn>5</eqn>
				<units>years</units>
			</aux>
			<aux name="switch profit tax policy" access="input">
				<eqn>0</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="profit tax policy start year" access="input">
				<eqn>2025</eqn>
				<units>Year</units>
			</aux>
			<aux name="time to implement\nwealth tax policy" access="input">
				<eqn>5</eqn>
				<units>years</units>
			</aux>
			<aux name="wealth tax policy start year" access="input">
				<eqn>2025</eqn>
				<units>Year</units>
			</aux>
			<flow name="insurance taxation" access="output" isee:autocreated="true">
				<doc>Insurance taxation takes a small percentage of owner wealth each year (after the policy starts) to fund government-backed climate insurance, reducing financial instability. This means the tax is levied as a percentage of owner wealth after the policy starts, and is zero before then. The model includes it because owners hold most wealth and much of the exposed asset base, so they are treated as the main contributors to the insurance scheme.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF TIME &gt;= government_insurance_policy_start_year
THEN government_insurance_taxation_rate_1*owner_savings
ELSE 0</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="government insurance\npolicy start year" access="input">
				<eqn>2175</eqn>
				<units>year</units>
			</aux>
			<stock name="government\ninsurance taxation rate 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0</eqn>
				<units>1/year</units>
			</stock>
			<flow name="Central Bank public\ninvestment" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>central_bank_investment_1</eqn>
				<init_eqn>0</init_eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="Central Bank\ninterest payment" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="central bank investment 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="actual wealth tax rate">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>actual_wealth_tax_policy + additional_Wealth_Tax_Rate_for_public_investments_policy</eqn>
				<units>1/year</units>
			</aux>
			<aux name="actual profit tax rate">
				<doc>This new policy are meant to be permanent policy regimes, not temporary stimulus programs</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>actual_profit_tax_policy + additional_Profit_Tax_Rate_for_public_investments_policy</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="actual rent tax rate">
				<doc>This new policy are meant to be permanent policy regimes, not temporary stimulus programs</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>actual_profit_tax_policy + additional_Rent_Tax_Rate_for_public_investments_policy</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="actual wage tax rate">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>actual_wage_tax_policy + additional_Wage_Tax_Rate_for_public_investments_policy</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="additional wage tax percentage target for public\ninvestments policy">
				<doc>extra wage tax rate needed to raise the desired wage-tax revenue</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF TIME &gt;= government_run_investment_policy_start_year_4
THEN
desired_wage_taxation_revenue_for_public_investments_policy /
MAX(wages, 1e-6)
ELSE 0</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="desired wage taxation revenue\nfor public investments policy" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="additional profit tax percentage\ntarget for public\ninvestments policy">
				<doc>extra wage tax rate needed to raise the desired wage-tax revenue</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF TIME &gt;= government_run_investment_policy_start_year
THEN
desired_profit_taxation_revenue_for_public_investments_policy /
MAX(MAX(0, (non_bank_profits+bank_profits)), 1e-6)
ELSE 0</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="desired profit taxation revenue for public investments policy" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="additional rent tax percentage target for public investments policy">
				<doc>extra wage tax rate needed to raise the desired wage-tax revenue</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF TIME &gt;= government_run_investment_policy_start_year_3
THEN
desired_rent_taxation_revenue_for_public_investments_policy /
MAX(rent, 1e-6)
ELSE 0</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="desired rent taxation revenue\nfor public investments policy" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="additional wealth tax percentage\ntarget for public\ninvestments policy">
				<doc>extra wage tax rate needed to raise the desired wage-tax revenue</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF TIME &gt;= government_run_investment_policy_start_year_2
THEN
desired_wealth_taxation_revenue_for_public_investments_policy /
MAX(owner_savings, 1e-6)
ELSE 0</eqn>
				<units>1/year</units>
			</aux>
			<aux name="desired wealth taxation revenue\nfor public investments policy" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="time to adjust government\npublic investment tax rate">
				<eqn>5</eqn>
				<units>year</units>
			</aux>
			<stock name="additional Wage Tax Rate\nfor public investments policy">
				<doc>implemented extra wage tax rate actually applied</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0</eqn>
				<inflow>change_in_additional_wage_tax_rate_for_policy</inflow>
				<units>dmnl</units>
			</stock>
			<flow name="change in additional wage tax rate for policy">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(additional_wage_tax_percentage_target_for_public_investments_policy-additional_Wage_Tax_Rate_for_public_investments_policy)/time_to_adjust_government_public_investment_tax_rate</eqn>
				<units>1/year</units>
			</flow>
			<stock name="additional Profit Tax Rate\nfor public investments policy">
				<doc>implemented extra profit tax rate actually applied</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0</eqn>
				<inflow>change_in_additional_profit_tax_rate_for_policy</inflow>
				<units>dmnl</units>
			</stock>
			<flow name="change in additional profit\ntax rate for policy">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(additional_profit_tax_percentage_target_for_public_investments_policy-additional_Profit_Tax_Rate_for_public_investments_policy)/time_to_adjust_government_public_investment_tax_rate</eqn>
				<units>1/year</units>
			</flow>
			<stock name="additional Rent Tax Rate\nfor public investments policy">
				<doc>implemented extra rent tax rate actually applied</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0</eqn>
				<inflow>change_in_additional_rent_tax_rate_for_policy</inflow>
				<units>dmnl</units>
			</stock>
			<flow name="change in additional rent\ntax rate for policy">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(additional_rent_tax_percentage_target_for_public_investments_policy-additional_Rent_Tax_Rate_for_public_investments_policy)/time_to_adjust_government_public_investment_tax_rate</eqn>
				<units>1/year</units>
			</flow>
			<stock name="additional Wealth Tax Rate\nfor public investments policy">
				<doc>implemented extra wealth tax rate actually applied</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0</eqn>
				<inflow>change_in_additional_wealth_tax_rate_for_policy</inflow>
				<units>1/year</units>
			</stock>
			<flow name="change in additional wealth\ntax rate for policy">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(additional_wealth_tax_percentage_target_for_public_investments_policy-additional_Wealth_Tax_Rate_for_public_investments_policy)/time_to_adjust_government_public_investment_tax_rate</eqn>
				<units>1/year^2</units>
			</flow>
			<aux name="government run investment\npolicy start year" access="input">
				<eqn>2175</eqn>
				<units>year</units>
			</aux>
			<aux name="government run investment\npolicy start year 2" access="input">
				<eqn>2175</eqn>
				<units>year</units>
			</aux>
			<aux name="government run investment\npolicy start year 3" access="input">
				<eqn>2175</eqn>
				<units>year</units>
			</aux>
			<group name="Government Public Investment\nTaxation from\nProfit, Rent, Wealth" run="false">
				<format scale_by="auto"/>
				<entity name="actual_profit_tax_rate"/>
				<entity name="actual_rent_tax_rate"/>
				<entity name="actual_wealth_tax_rate"/>
				<entity name="additional_profit_tax_percentage_target_for_public_investments_policy"/>
				<entity name="additional_Profit_Tax_Rate_for_public_investments_policy"/>
				<entity name="additional_rent_tax_percentage_target_for_public_investments_policy"/>
				<entity name="additional_Rent_Tax_Rate_for_public_investments_policy"/>
				<entity name="additional_wealth_tax_percentage_target_for_public_investments_policy"/>
				<entity name="additional_Wealth_Tax_Rate_for_public_investments_policy"/>
				<entity name="change_in_additional_profit_tax_rate_for_policy"/>
				<entity name="change_in_additional_rent_tax_rate_for_policy"/>
				<entity name="change_in_additional_wealth_tax_rate_for_policy"/>
				<entity name="desired_profit_taxation_revenue_for_public_investments_policy"/>
				<entity name="desired_rent_taxation_revenue_for_public_investments_policy"/>
				<entity name="desired_wealth_taxation_revenue_for_public_investments_policy"/>
				<entity name="government_run_investment_policy_start_year"/>
				<entity name="government_run_investment_policy_start_year_2"/>
				<entity name="government_run_investment_policy_start_year_3"/>
			</group>
			<aux name="government run investment\npolicy start year 4" access="input">
				<eqn>2175</eqn>
				<units>year</units>
			</aux>
			<group name="Government Public Investment\nTaxation from Wage" run="false">
				<format scale_by="auto"/>
				<entity name="additional_wage_tax_percentage_target_for_public_investments_policy"/>
				<entity name="additional_Wage_Tax_Rate_for_public_investments_policy"/>
				<entity name="change_in_additional_wage_tax_rate_for_policy"/>
				<entity name="desired_wage_taxation_revenue_for_public_investments_policy"/>
				<entity name="government_run_investment_policy_start_year_4"/>
				<entity name="time_to_adjust_government_public_investment_tax_rate"/>
			</group>
		</variables>
		<views>
			<style color="black" background="white" font_style="normal" font_weight="normal" text_decoration="none" text_align="center" vertical_text_align="center" font_color="black" font_family="Arial" font_size="10pt" padding="2" border_color="black" border_width="thin" border_style="none">
				<text_box color="black" background="white" text_align="left" vertical_text_align="top" font_size="12pt"/>
				<isee:loop_indicator color="black" background="white" text_align="left" vertical_text_align="top" font_size="12pt"/>
				<numeric_display color="white" background="white" font_size="12pt" border_width="thin" border_style="solid" isee:transparent="false" isee:show_divider="true" isee:show_bounding_box="true" label_side="left"/>
				<graph color="black" background="white" font_size="12pt" axis_color="#666666" grid_color="#C8C8C8" isee:graph_area_color="white" legend_position="bottom" isee:transparent="false" isee:hide_border="false" axis_title_font_style="normal" axis_title_font_weight="normal" axis_title_text_decoration="none" axis_title_text_align="center" axis_title_vertical_text_align="center" axis_title_font_color="black" axis_title_font_family="Arial" axis_title_font_size="12pt" axis_title_text_padding="2" axis_title_text_border_color="black" axis_title_text_border_width="thin" axis_title_text_border_style="none" axis_label_font_style="normal" axis_label_font_weight="normal" axis_label_text_decoration="none" axis_label_text_align="center" axis_label_vertical_text_align="center" axis_label_font_color="black" axis_label_font_family="Arial" axis_label_font_size="9pt" axis_label_text_padding="2" axis_label_text_border_color="black" axis_label_text_border_width="thin" axis_label_text_border_style="none">
					<isee:series_styles>
						<isee:series_style color="blue" thickness="1"/>
						<isee:series_style color="red" thickness="1" pen_style="dot_dashed"/>
						<isee:series_style color="fuchsia" thickness="1" pen_style="dotted"/>
						<isee:series_style color="#008F44" thickness="1" pen_style="dashed"/>
						<isee:series_style color="#FF7F00" thickness="1"/>
						<isee:series_style color="#7F00FF" thickness="1" pen_style="dot_dashed"/>
						<isee:series_style color="#0CA0FF" thickness="1" pen_style="dotted"/>
						<isee:series_style color="lime" thickness="1" pen_style="dashed"/>
						<isee:series_style color="#FF007F" thickness="1"/>
						<isee:series_style color="aqua" thickness="1" pen_style="dot_dashed"/>
						<isee:series_style color="#F586FF" thickness="1" pen_style="dotted"/>
						<isee:series_style color="black" thickness="1" pen_style="dashed"/>
						<isee:series_style color="#C8C8C8" thickness="1"/>
					</isee:series_styles>
				</graph>
				<table color="black" background="#E0E0E0" text_align="right" font_size="12pt" orientation="vertical" wrap_text="false" isee:auto_fit="true" isee:use_alternate_row_colors="false" isee:unlimited_table_length="false" blank_column_width="80" column_width="160" interval="1" report_balances="beginning" report_flows="instantaneous" header_font_style="normal" header_font_weight="normal" header_text_decoration="none" header_text_align="center" header_vertical_text_align="center" header_font_color="black" header_font_family="Arial" header_font_size="12pt" header_text_padding="2" header_text_border_color="black" header_text_border_width="thin" header_text_border_style="none"/>
				<button color="black" background="#E0E0E0" font_size="12pt" border_width="thin" border_style="solid" transparent="false" corner_radius="0" isee:flat="false" icon_side="top" isee:highlight_on_hover="false" isee:highlight_color="#959595"/>
				<isee:annotation color="black" background="#E0E0E0" font_size="12pt" border_width="thin" border_style="solid" transparent="false" corner_radius="0" isee:flat="false" icon_side="top" isee:highlight_on_hover="false" isee:highlight_color="#959595" popup_corner_radius="0" popup_background_color="#FFFECF"/>
				<slider color="#0075FF" background="#E0E0E0" font_size="12pt" num_ticks="3" label_side="top" wrap_title="true" vertical="false" isee:fancy_appearance="false" isee:show_hover_tip="when_deciding" input_expands="true" input_width="100"/>
				<isee:stacked_container color="black" background="white" text_align="left" vertical_text_align="top" font_size="12pt" padding="6 8" border_color="#999999" border_width="thin" border_style="solid" item_spacing="0" corner_radius="4" selected_item_color="black" selected_item_background="white" item_background="#DDDDDD" transparent_bg="false"/>
				<isee:dual_slider color="#66CC66" background="silver" font_size="12pt" num_ticks="3" label_side="top" wrap_title="true" isee:show_hover_tip="when_deciding" input_expands="true" input_width="100"/>
