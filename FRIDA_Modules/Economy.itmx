	<model name="Innovation">
		<variables>
			<stock name="Firms\nChecking\nAccounts 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$</units>
			</stock>
			<stock name="Firms Innovation Orientation" access="output" isee:autocreated="true">
				<doc>This is a demand-side signal.

It represents:
- how innovation-oriented firms currently are,
- how strong the demand is for innovation financing,
- how attractive innovation projects look to banks.
- If firms are not innovating, banks cannot redirect loans toward innovation, even if they want to.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1</eqn>
				<inflow>change_in_firms_innovation_orientation</inflow>
				<units>dmnl</units>
			</stock>
			<flow name="change in firms\ninnovation\norientation">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(indicated_firms_innovation_orientation-Firms_Innovation_Orientation)/time_for_firms_to_adjust_innovation_orientation</eqn>
				<units>dmnl/year</units>
			</flow>
			<aux name="indicated firms innovation orientation">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>reference_firms_innovation_orientation*effect_of_cash_reserve_growth_rate_on_firms_innovation_orientation</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="time for firms to\nadjust innovation\norientation">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>3.00465422052076</eqn>
				<range min="2" max="5"/>
				<units>years</units>
			</aux>
			<aux name="effect of cash reserve\ngrowth rate on firms\ninnovation orientation">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1+sensitivity_of_effect_of_cash_reserve_growth_rate_on_firms_innovation_orientation*(relative_cash_reserve_growth_rate-1)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="sensitivity of effect of cash reserve\ngrowth rate on firms\ninnovation orientation">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>-0.114483522217129</eqn>
				<range min="-0.3" max="-0.01"/>
				<units>dmnl</units>
			</aux>
			<aux name="reference cash\nreserve growth rate">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.0486965577383913</eqn>
				<range min="0.03" max="0.08"/>
				<units>1/year</units>
			</aux>
			<aux name="relative cash reserve growth rate">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>cash_reserve_growth_rate/reference_cash_reserve_growth_rate</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="cash reserve growth\nrate">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>TREND(Firms_Checking_Accounts_1, 1)</eqn>
				<units>1/year</units>
			</aux>
			<aux name="reference firms\ninnovation orientation">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(Firms_Innovation_Orientation, firms_reference_formation_time)</eqn>
				<isee:delay_aux/>
				<units>dmnl</units>
			</aux>
			<aux name="firms reference formation time">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>79.3879038397535</eqn>
				<range min="40" max="100"/>
				<units>years</units>
			</aux>
		</variables>
		<views>
			<style color="black" background="white" font_style="normal" font_weight="normal" text_decoration="none" text_align="center" vertical_text_align="center" font_color="black" font_family="Arial" font_size="10pt" padding="2" border_color="black" border_width="thin" border_style="none">
				<text_box color="black" background="white" text_align="left" vertical_text_align="top" font_size="12pt"/>
