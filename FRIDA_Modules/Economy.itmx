	<model name="Government">
		<variables>
			<aux name="safe\ninterest" access="output">
				<doc>It representing the economy’s safe interest rate. </doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Central_Bank_Safe_Interest</eqn>
				<units>1/year</units>
			</aux>
			<aux name="smoothed total\npublic tax income">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(total_public_tax_income, averaging_time_to_adjust_tax_based_on_income, initial_smoothed_total_public_tax_income)</eqn>
				<isee:delay_aux/>
				<units>b$/year</units>
			</aux>
			<aux name="proportion of taxes\nto public spending">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(effect_of_debt_to_GDP_ratio_on_government_spending, time_for_government_spending_to_change)</eqn>
				<isee:delay_aux/>
				<units>dmnl</units>
			</aux>
			<flow name="government\ntaking up debt">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>public_expenditure - total_public_tax_income</eqn>
				<units>b$/year</units>
			</flow>
			<stock name="Government\nDebt" access="output" isee:autocreated="true">
				<doc>It is the stock of accumulated public debt.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>initial_government_debt</eqn>
				<inflow>government_taking_up_debt</inflow>
				<inflow>government_insurance_payout</inflow>
				<inflow>bailouts</inflow>
				<outflow>insurance_tax_redemption</outflow>
				<units>B$</units>
			</stock>
			<aux name="government\ninterest payments" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Government_Debt*average_government_debt_interest_rate</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="debt to\nGDP ratio">
				<doc>${Calibrated Output}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Government_Debt/measured_GDP</eqn>
				<units>year</units>
			</aux>
			<aux name="initial government\ndebt" access="output" isee:autocreated="true">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>9712.9001009413</eqn>
				</element>
				<range min="0" max="25000"/>
				<units>B$</units>
			</aux>
			<aux name="government\nconsumption" access="output">
				<doc>${Calibrated Output}
government consumption as the sum of three separate components, each representing a different type of spending.
(1) STA driven government consumption, consumption that increases because of climate damages, specifically those driven by Surface Temperature Anomaly (STA), e.g., emergency response, reconstruction, adaptation, public services, etc.
(2) non climate driven government consumption, normal government consumption that would exist even without climate change, including education, heatlhcare, administration, defense, etc.
(3) Paid total nominal SLR protection cost, these are the nominal (not inflation-adjusted) costs the government must pay for Sea-Level-Rise (SLR) protection, e.g., sea walls, coastal defense infrastrucutre, land elevation, etc.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>STA_driven_government_consumption+non_climate_driven_government_consumption+Paid_Total_Nominal_SLR_protection_cost</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="measured GDP">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(GDP,  GDP_measuring_time,  initial_measured_GDP)</eqn>
				<isee:delay_aux/>
				<units>b$/year</units>
			</aux>
			<aux name="initial\nmeasured GDP">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>20970.4</eqn>
				<range min="20000" max="22000"/>
				<units>b$/year</units>
			</aux>
			<aux name="GDP\nmeasuring time">
				<doc>${Assumption}
1 year to measure GDP</doc>
				<eqn>1</eqn>
				<units>Years</units>
			</aux>
			<aux name="GDP" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="government\ntransfers" access="output">
				<doc>The government cannot spend unlimited money on transfers.
Transfers = the smaller of what government can afford and what society needs.

This means, if needs exceed the budget, transfers are rationed. If budget exceeds needs, only actual needs are paid.
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MIN(public_expenditure_before_subsidies_and_interest_payments*maximum_percentage_of_government_budget_to_transfer_payments, (transfer_payments_for_children+transfer_payments_for_retirees+transfer_payments_for_unemployed)/&quot;UNIT_$_per_B$&quot;)</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="public\ninvestment" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>public_expenditure_available_for_investment_and_consumption
-non_climate_driven_government_consumption
+ government_run_public_investment</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="profit tax 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="wage tax 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="rent tax 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="total public tax income" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>rent_tax_1 + profit_tax_1 + wage_tax_1+sum_of_energy_taxes_in_nominal_terms+wealth_tax</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="averaging time to adjust tax based on income">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>2.28422196055125</eqn>
				</element>
				<range min="1" max="3"/>
				<units>year</units>
			</aux>
			<aux name="initial smoothed total public tax income">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>2635.2</eqn>
				<range min="2200" max="2900"/>
				<units>b$/year</units>
			</aux>
			<aux name="central bank\ngoal inflation">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>
inflation_goal_policy</eqn>
				<units>1/year</units>
			</aux>
			<aux name="inflation\ntarget\ndiscrepancy">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>inflation-central_bank_goal_inflation</eqn>
				<units>1/year</units>
			</aux>
			<stock name="Central Bank\nSafe Interest">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>initial_safe_interest</eqn>
				<inflow>change_in_safe_interest</inflow>
				<units>1/year</units>
			</stock>
			<flow name="change in\nsafe interest">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(central_bank_interest_rate_reactivity*interest_rate_policy_discrepancy-Central_Bank_Safe_Interest+baseline_interest)/central_bank_adjustment_time</eqn>
				<units>1/year/Year</units>
			</flow>
			<aux name="central bank\ninterest rate\nreactivity">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>1</eqn>
				</element>
				<range min="0.8" max="1.2"/>
				<units>dmnl</units>
			</aux>
			<aux name="central bank\nadjustment time">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>1.5</eqn>
				</element>
				<range min="0.5" max="2"/>
				<units>Years</units>
			</aux>
			<aux name="baseline\ninterest">
				<doc>${Assumption}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.02</eqn>
				<range min="0.01" max="0.03"/>
				<units>1/year</units>
			</aux>
			<aux name="inflation" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>1/year</units>
			</aux>
			<aux name="unemployment\ntarget discrepancy">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>central_bank_goal_unemployment-unemployment_rate_1</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="interest rate\npolicy discrepancy">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MAX(-baseline_interest, inflation_target_discrepancy*inflation_weight+yearly_unemployment_target_discrepancy*unemployment_weight)</eqn>
				<units>1/year</units>
			</aux>
			<aux name="central bank goal\nunemployment">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn> unemployment_goal_policy</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="unemployment\nweight">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.33</eqn>
				</element>
				<range min="0.2" max="0.4"/>
				<units>dmnl</units>
			</aux>
			<aux name="inflation\nweight">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>1.33</eqn>
				</element>
				<range min="1.2" max="1.4"/>
				<units>dmnl</units>
			</aux>
			<aux name="unemployment rate 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="yearly\nunemployment target\ndiscrepancy">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>unemployment_target_discrepancy/time_to_measure_unemployment</eqn>
				<units>1/year</units>
			</aux>
			<aux name="time to measure\nunemployment">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1</eqn>
				<range min="0.5" max="1.5"/>
				<units>year</units>
			</aux>
			<aux name="required last\nresort lending" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$</units>
			</aux>
			<flow name="bailouts" access="output">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>bank_bailouts</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="solvency support adjustment time">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1</eqn>
				<range min="0.5" max="1.5"/>
				<units>years</units>
			</aux>
			<aux name="unemployment goal policy" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>.05</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="inflation goal policy" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.02</eqn>
				<units>1/year</units>
			</aux>
