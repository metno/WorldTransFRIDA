				</alias>
				<alias font_style="italic" label_side="left" uid="300" x="4215.59" y="1449.06" width="18" height="18">
					<of>&quot;wages_in_2021c$&quot;</of>
				</alias>
				<alias font_style="italic" label_side="right" uid="303" x="4337.09" y="1380.73" width="18" height="18">
					<of>&quot;gross_income_in_2021c$&quot;</of>
				</alias>
				<alias font_style="italic" font_weight="bold" label_side="top" uid="391" x="4075.76" y="1246.31" width="18" height="18">
					<of>Population_1</of>
				</alias>
				<alias font_style="italic" label_side="top" uid="396" x="4368.64" y="1081.91" width="18" height="18">
					<of>net_worker_income</of>
				</alias>
				<alias font_style="italic" label_side="top" uid="397" x="4368.64" y="1135.91" width="18" height="18">
					<of>transfers</of>
				</alias>
				<alias color="black" background="#FFD479" font_style="italic" font_color="black" label_side="left" uid="498" x="635.287" y="977.791" width="18" height="18">
					<of>time_to_adjust_government_public_investment_tax_rate</of>
				</alias>
				<alias color="black" background="#FFD479" font_style="italic" font_color="black" label_side="left" label_angle="225" uid="508" x="638.693" y="1471.34" width="18" height="18">
					<of>time_to_adjust_government_public_investment_tax_rate</of>
				</alias>
				<alias color="black" background="#FFD479" font_style="italic" font_color="black" label_side="left" label_angle="225" uid="512" x="736.534" y="1832.65" width="18" height="18">
					<of>time_to_adjust_government_public_investment_tax_rate</of>
				</alias>
			</view>
		</views>
	</model>
	<model name="Employment">
		<variables>
			<aux name="initial unemployment rate">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.0614856366954347</eqn>
				</element>
				<range min="0.03" max="0.1"/>
				<units>dmnl</units>
			</aux>
			<aux name="passing 15">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>AGECOUNT(Aged_1_to_20_years, 14, 15)</eqn>
				<units>Mp</units>
			</aux>
			<aux name="Initial Wage Rate">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>5695.75062986852</eqn>
				</element>
				<range min="2000" max="10000"/>
				<units>$/p</units>
			</aux>
			<flow name="employment decline">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>firing</eqn>
				<non_negative/>
				<units>Mp/year</units>
			</flow>
			<flow name="wage\nchange">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Wage_Rate*fractional_wage_growth</eqn>
				<units>$/p/year</units>
			</flow>
			<flow name="employment growth">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>hiring
{desired_additional_hires*effect_of_labour_balance_on_hiring</eqn>
				<non_negative/>
				<units>Mp/year</units>
			</flow>
			<flow name="aging out\nof employed">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>aging_out*percentage_of_working_age_that_are_employed/UNIT_one_year</eqn>
				<non_negative/>
				<units>Mp/year</units>
			</flow>
			<flow name="employed\ndeaths">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>working_age_deaths*percentage_of_working_age_that_are_employed</eqn>
				<non_negative/>
				<units>Mp/year</units>
			</flow>
			<flow name="unemployed\ndeaths">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>working_age_deaths*percentage_of_working_age_that_are_unemployed</eqn>
				<non_negative/>
				<units>Mp/year</units>
			</flow>
			<stock name="Wage Rate" access="output" isee:autocreated="true">
				<doc>${Calibrated Output}
https://rshiny.ilo.org/dataexplorer17/?id=SDG_1041_NOC_RT_A&amp;ref_area=X01</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Initial_Wage_Rate</eqn>
				<inflow>wage_change</inflow>
				<units>$/p</units>
			</stock>
			<stock name="Employed" access="output" isee:autocreated="true">
				<doc>${Calibrated Output}
https://rshiny.ilo.org/dataexplorer15/?id=EMP_2EMP_SEX_AGE_NB_A&amp;ref_area=X01&amp;sex=SEX_T&amp;classif1=AGE_YTHADULT_YGE15&amp;timefrom=1991</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(working_age_population-non_active_working_age)*(1-initial_unemployment_rate)</eqn>
				<inflow>employment_growth</inflow>
				<outflow>employment_decline</outflow>
				<outflow>aging_out_of_employed</outflow>
				<outflow>employed_deaths</outflow>
				<units>Mp</units>
			</stock>
			<aux name="profit firing\nthreshold">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>private_safe_bank_assets*average_private_debt_safe_interest*profit_threshold_multiplier</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="missed\nprofits">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MAX(0, profit_firing_threshold-non_bank_profits_1)</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="firing from\nmissed profits">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(MAX(0, (missed_profits/wage_rate_in_billions_per_million_people)*effect_of_missed_profits), time_to_fire_from_missed_profits)</eqn>
				<isee:delay_aux/>
				<units>Mp/year</units>
			</aux>
			<aux name="firing from\ndefaults">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(total_defaults_for_firing_impact*hiring_to_investment_ratio/wage_rate_in_billions_per_million_people, time_for_defaults_to_affect_firing)</eqn>
				<units>Mp/year</units>
			</aux>
			<aux name="UNIT dollars per billion">
				<doc>${Unit}
</doc>
				<eqn>1000000000</eqn>
				<units>$/B$</units>
			</aux>
			<aux name="wage rate\nin billions per\nmillion people">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Wage_Rate/UNIT_dollars_per_billion*UNIT_persons_per_million_people</eqn>
				<units>B$/Mp</units>
			</aux>
			<aux name="desired\nadditional hires">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(planned_investment*hiring_to_investment_ratio)/wage_rate_in_billions_per_million_people</eqn>
				<units>Mp/year</units>
			</aux>
			<aux name="UNIT one year">
				<doc>${Unit}
</doc>
				<eqn>1</eqn>
				<units>year</units>
			</aux>
			<aux name="UNIT persons per\nmillion people">
				<doc>${Unit}
</doc>
				<eqn>1000000</eqn>
				<units>p/Mp</units>
			</aux>
			<aux name="annual\naggregate wages" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>wage_rate_in_billions_per_million_people*Employed/UNIT_one_year</eqn>
				<units>b$/year</units>
			</aux>
			<flow name="aging out of\nunemployed">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>aging_out*percentage_of_working_age_that_are_unemployed/UNIT_one_year</eqn>
				<non_negative/>
				<units>Mp/year</units>
			</flow>
			<flow name="new labour\nforce entrants">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>aging_in*labour_force_participation_rate/UNIT_one_year</eqn>
				<non_negative/>
				<units>Mp/year</units>
			</flow>
			<stock name="Unemployed" access="output" isee:autocreated="true">
				<doc>${Calibrated Output}
https://rshiny.ilo.org/dataexplorer16/?id=UNE_2UNE_SEX_AGE_NB_A&amp;ref_area=X01&amp;sex=SEX_T&amp;classif1=AGE_YTHADULT_YGE15&amp;timefrom=1991</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(working_age_population-non_active_working_age)*initial_unemployment_rate</eqn>
				<inflow>employment_decline</inflow>
				<inflow>new_labour_force_entrants</inflow>
				<inflow>Seeking_work</inflow>
				<outflow>employment_growth</outflow>
				<outflow>unemployed_deaths</outflow>
				<outflow>aging_out_of_unemployed</outflow>
				<units>Mp</units>
			</stock>
			<aux name="desired fractional\nwage growth from supply and demand">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>max_change_in_fractional_wage_growth*effect_of_labour_balance_on_fractional_wage_growth_rate

{(max_change_in_fractional_wage_growth*effect_of_labour_balance_on_fractional_wage_growth_rate)</eqn>
				<units>dmnl/year</units>
			</aux>
			<aux name="unemployment rate" access="output" isee:autocreated="true">
				<doc>${Calibrated Output}
https://rshiny.ilo.org/dataexplorer32/?id=UNE_2EAP_SEX_AGE_RT_A&amp;ref_area=X01&amp;sex=SEX_T&amp;classif1=AGE_YTHADULT_YGE15&amp;timefrom=1991</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Unemployed/(Unemployed+Employed)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="profit threshold\nmultiplier">
				<doc>${Assumption}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1</eqn>
				<range min="0.5" max="2"/>
				<units>dmnl</units>
			</aux>
			<aux name="deaths 15 to 20 years">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Aged_15_to_20 / Aged_1_to_20_years_1 * deaths_1_to_20_years_1</eqn>
				<units>Mp/year</units>
			</aux>
			<aux name="aging in">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>passing_15</eqn>
				<units>Mp</units>
			</aux>
			<aux name="aging out">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Passing_66*UNIT_one_year</eqn>
				<units>Mp</units>
			</aux>
			<aux name="working age\ndeaths">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>deaths_20_to_40_years+deaths_40_to_60_years+deaths_15_to_20_years+deaths_60_to_65_years</eqn>
				<units>Mp/year</units>
			</aux>
			<aux name="Check">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Employed+Unemployed+non_active_working_age)
/(working_age_population)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="participating population">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Employed+Unemployed</eqn>
				<units>Mp</units>
			</aux>
			<aux name="percentage\nof working age that\nare employed">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Employed/working_age_population</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="percentage\nof working age that\nare unemployed">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Unemployed/working_age_population</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="working\nage population">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Aged_20_to_40_years_1+Aged_40_to_60_years_1+Aged_15_to_20+Aged_60_to_65_years_1</eqn>
				<units>Mp</units>
			</aux>
			<aux name="Aged 15 to 20">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>AGECOUNT(Aged_1_to_20_years_1, 14, 19)</eqn>
				<units>Mp</units>
			</aux>
			<aux name="labour force\nparticipation rate" access="output" isee:autocreated="true">
				<doc>https://rshiny.ilo.org/dataexplorer20/?id=EAP_2WAP_SEX_AGE_RT_A&amp;ref_area=X01&amp;sex=SEX_T&amp;classif1=AGE_AGGREGATE_TOTAL&amp;timefrom=1991</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>labour_force_participation_fixed/100</eqn>
				<units>dmnl</units>
			</aux>
			<stock name="non active working age">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>working_age_population*(1-labour_force_participation_rate)</eqn>
				<inflow>new_potential_labour_force_entrants</inflow>
				<outflow>aging_out_of_potential</outflow>
				<outflow>potential_labour_deaths</outflow>
				<outflow>Seeking_work</outflow>
				<units>Mp</units>
			</stock>
			<flow name="new\npotential labour\nforce entrants">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>aging_in*(1-labour_force_participation_rate)/UNIT_one_year</eqn>
				<non_negative/>
				<units>Mp/year</units>
			</flow>
			<flow name="potential\nlabour deaths">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>working_age_deaths*percentage_of_working_age_that_are_non_active</eqn>
				<non_negative/>
				<units>Mp/year</units>
			</flow>
			<flow name="aging out\nof potential">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>aging_out*percentage_of_working_age_that_are_non_active/UNIT_one_year</eqn>
				<non_negative/>
				<units>Mp/year</units>
			</flow>
			<flow name="Seeking work">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>participation_gap/time_for_labour_participation_to_change</eqn>
				<units>Mp/year</units>
			</flow>
			<aux name="time for labour\nparticipation to change">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1</eqn>
				<units>Years</units>
			</aux>
			<aux name="percentage\nof working age that\nare non active">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>non_active_working_age/working_age_population</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="indicated\nparticipation">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>working_age_population*labour_force_participation_rate</eqn>
				<units>Mp</units>
			</aux>
			<aux name="participation\ngap">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>indicated_participation-participating_labourers</eqn>
				<units>Mp</units>
			</aux>
			<aux name="participating\nlabourers">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Unemployed+Employed</eqn>
				<units>Mp</units>
			</aux>
			<aux name="rent to\ninvestment ratio">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.25</eqn>
				</element>
				<range min="0.15" max="0.35"/>
				<units>dmnl</units>
			</aux>
			<aux name="rent" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>planned_investment*rent_to_investment_ratio</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="labour balance">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Unemployed/desired_additional_hires/time_seeking_employees</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="time seeking\nemployees">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>1.41675579163574</eqn>
				</element>
				<range min="1" max="3"/>
				<units>year</units>
			</aux>
			<aux name="max change in\nfractional wage growth">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.0689877237455</eqn>
				</element>
				<range min="0" max="0.9"/>
				<units>1/year</units>
			</aux>
			<aux name="labour force\nparticipation fixed">
				<doc>${Internal Calibration Parameter}
https://rshiny.ilo.org/dataexplorer20/?id=EAP_2WAP_SEX_AGE_RT_A&amp;ref_area=X01&amp;sex=SEX_T&amp;classif1=AGE_AGGREGATE_TOTAL&amp;timefrom=1991</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>63.9386214645122</eqn>
				</element>
				<range min="61.8" max="66"/>
				<units>dmnl</units>
			</aux>
			<aux name="percentage of working age that are active">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1-percentage_of_working_age_that_are_non_active</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="hiring to\ninvestment\nratio">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.454718325853551</eqn>
				</element>
				<range min="0.1" max="0.75"/>
				<units>dmnl</units>
			</aux>
			<aux name="sloshing around in\nthe firms checking">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>planned_investment*slosh_to_investment_ratio</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="slosh to\ninvestment ratio">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1-rent_to_investment_ratio-hiring_to_investment_ratio</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="effect of labour\nbalance on fractional wage growth rate">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>labour_balance</eqn>
				<gf>
					<xscale min="0" max="2"/>
					<yscale min="-1" max="1"/>
					<ypts>1,0.778,0.59,0.429,0.307,0.207,0.126,0.077,0.038,0.015,0,-0.005,-0.01,-0.019,-0.027,-0.034,-0.042,-0.054,-0.069,-0.092,-0.123</ypts>
				</gf>
				<units>dmnl</units>
			</aux>
			<aux name="fraction of pop that is working age">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>working_age_population/Population_1</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="planned\ninvestment">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1((total_investment_1), 1)</eqn>
				<isee:delay_aux/>
				<units>b$/year</units>
			</aux>
			<stock name="Wage Index" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Cumulative_inflation</eqn>
				<inflow>change_in_wage_index</inflow>
				<units>dmnl</units>
			</stock>
			<flow name="change in wage index">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>fractional_wage_growth*Wage_Index</eqn>
				<units>dmnl/year</units>
			</flow>
			<aux name="wage growth\nrate gap">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Cumulative_inflation-Wage_Index</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Urgency with which wage growth is demanded">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>2</eqn>
				</element>
				<range min="1" max="3"/>
				<units>year</units>
			</aux>
			<aux name="desired fractional wage\ngrowth from inflation">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MAX(wage_growth_rate_gap/Urgency_with_which_wage_growth_is_demanded,  0)</eqn>
				<units>dmnl/year</units>
			</aux>
			<aux name="initial recent\nwage growth rate">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.013839525</eqn>
				<units>dmnl/year</units>
			</aux>
			<aux name="initial average wage rate">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>INIT(Wage_Rate)*(1-initial_recent_wage_growth_rate*UNIT_one_year)</eqn>
				<units>$/p</units>
			</aux>
			<aux name="working age population 2" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>Mp</units>
			</aux>
			<stock name="Aged 20 to 40 years 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<conveyor/>
				<units>Mp</units>
			</stock>
			<stock name="Aged 40 to 60 years 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<conveyor/>
				<units>Mp</units>
			</stock>
			<stock name="Aged 60 to 65 years 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<conveyor/>
				<units>Mp</units>
			</stock>
			<aux name="Population 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>Mp</units>
			</aux>
			<stock name="Aged 1 to 20 years 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<conveyor/>
				<units>Mp</units>
			</stock>
			<aux name="deaths\n1 to 20 years 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>Mp/year</units>
			</aux>
			<aux name="deaths\n60 to 65 years" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>Mp/year</units>
			</aux>
			<aux name="deaths\n20 to 40 years" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>Mp/year</units>
			</aux>
			<aux name="deaths\n40 to 60 years" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>Mp/year</units>
			</aux>
			<aux name="total investment 1" access="output" throughput="true" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="non bank profits 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<stock name="Cumulative inflation" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0</eqn>
				<units>dmnl</units>
			</stock>
			<stock name="Aged 1 to 20 years" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<conveyor/>
				<units>Mp</units>
			</stock>
			<aux name="Passing 66" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0</eqn>
				<units>Mp/year</units>
			</aux>
			<aux name="fractional wage growth" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(MINSOFT(desired_fractional_wage_growth_from_supply_and_demand+agreed_wage_growth_from_inflation, cap_on_wage_growth, cap_on_wage_growth/10),  wage_adjustment_negotiation_time)</eqn>
				<isee:delay_aux/>
				<units>1/year</units>
			</aux>
			<aux name="wage adjustment negotiation time">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>1.999714633</eqn>
				</element>
				<range min="1" max="3"/>
				<units>year</units>
			</aux>
			<aux name="negotiation\neffectiveness">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>1</eqn>
				</element>
				<range min="0.5" max="1.5"/>
				<units>dmnl</units>
			</aux>
			<aux name="agreed wage growth from inflation">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>desired_fractional_wage_growth_from_inflation*negotiation_effectiveness</eqn>
				<units>dmnl/year</units>
			</aux>
			<aux name="Surface Temperature\n1986 to 2005 offset\nrelative to 1850 to 1900">
				<doc>${Assumption}
</doc>
				<eqn>0.688948529</eqn>
				<units>deg C</units>
			</aux>
			<aux name="Temperature effect on high exposure productivity">
				<doc>${Climate Impact Parameter,External Parameter}
Fitted slope for the direct temperature effect on high exposure productivity, based on Dasgupta et al. (2021). DOI: 10.1016/S2542-5196(21)00170-4</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>-6.13282138</eqn>
				</element>
				<range min="-25" max="4"/>
				<units>1/(deg C)</units>
			</aux>
			<aux name="Temperature squared effect\non high exposure productivity">
				<doc>${Climate Impact Parameter,External Parameter}
Fitted slope for the temperature squared effect on high exposure productivity, based on Dasgupta et al. (2021). DOI: 10.1016/S2542-5196(21)00170-4</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>-1.06197873</eqn>
				</element>
				<range min="-1.5" max="1"/>
				<units>1/(deg C^2)</units>
			</aux>
			<aux name="effect of climate on\nhigh exposure labour">
				<doc>DOI: 10.1016/S2542-5196(21)00170-4</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF (switch_labor_damage =0) AND TIME &gt; today THEN
previous_effect_of_climate_on_high_exposure_labour
ELSE
1 + UNIT_percent*(Temperature_effect_on_high_exposure_productivity*(Surface_Temperature_Anomaly_1 - Surface_Temperature_1986_to_2005_offset_relative_to_1850_to_1900) + Temperature_squared_effect_on_high_exposure_productivity*(Surface_Temperature_Anomaly_1 - Surface_Temperature_1986_to_2005_offset_relative_to_1850_to_1900)^2)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Temperature effect on\nlow exposure productivity">
				<doc>${Climate Impact Parameter,External Parameter}
Fitted slope for the direct temperature effect on low exposure productivity, based on Dasgupta et al. (2021). DOI: 10.1016/S2542-5196(21)00170-4</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>-2.08262027</eqn>
				</element>
				<range min="-16" max="5"/>
				<units>1/(deg C)</units>
			</aux>
			<aux name="Temperature squared effect on low exposure productivity">
				<doc>${Climate Impact Parameter,External Parameter}
Fitted slope for the temperature squared effect on low exposure productivity, based on Dasgupta et al. (2021). DOI: 10.1016/S2542-5196(21)00170-4</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>-1.56936859</eqn>
				</element>
				<range min="-2" max="0.1"/>
				<units>1/(deg C^2)</units>
			</aux>
			<aux name="effect of climate\non low exposure\nlabour">
				<doc>DOI: 10.1016/S2542-5196(21)00170-4</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF (switch_labor_damage =0) AND TIME &gt; today THEN
previous_effect_of_climate_on_low_exposure_labour
ELSE
1 + UNIT_percent*(Temperature_effect_on_low_exposure_productivity*(Surface_Temperature_Anomaly_1 - Surface_Temperature_1986_to_2005_offset_relative_to_1850_to_1900) + Temperature_squared_effect_on_low_exposure_productivity*(Surface_Temperature_Anomaly_1 - Surface_Temperature_1986_to_2005_offset_relative_to_1850_to_1900)^2)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="raw share of\nemployment\nin agriculture">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MAX(0, 
share_of_employment_in_agriculture_intercept+
EXP(share_of_employment_in_agriculture_slope*real_GDP_per_person)
)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="raw share of\nemployment\nin industry">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MAX(0, 
share_of_employment_in_industry_intercept+share_of_employment_in_industry_slope*real_GDP_per_person
)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="raw share of\nemployment\nin services">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MAX(0, 
share_of_employment_in_services_intercept+share_of_employment_in_services_slope*real_GDP_per_person
)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="share of\nemployment in agriculture intercept">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>62.901759597299</eqn>
				</element>
				<range min="-100" max="100"/>
				<units>dmnl</units>
			</aux>
			<aux name="share of\nemployment in\nagriculture slope">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>-15.3331166860372</eqn>
				<range min="-50" max="1"/>
				<units>Million*Person*Years/bc$</units>
			</aux>
			<aux name="share of\nemployment in industry intercept">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>-2.58133183549477</eqn>
				</element>
				<range min="-100" max="100"/>
				<units>dmnl</units>
			</aux>
			<aux name="share of\nemployment in\nindustry slope">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>2.9310559170307</eqn>
				</element>
				<range min="0" max="10"/>
				<units>Million*Person*Years/bc$</units>
			</aux>
			<aux name="share of\nemployment in services intercept">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>-30.7387076354652</eqn>
				</element>
				<range min="-100" max="100"/>
				<units>dmnl</units>
			</aux>
			<aux name="share of\nemployment in\nservices slope">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>7.49845788086441</eqn>
				</element>
				<range min="0" max="10"/>
				<units>Million*Person*Years/bc$</units>
			</aux>
			<aux name="share of\nemployment\nin agriculture">
				<doc>${Calibrated Output}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>raw_share_of_employment_in_agriculture/(raw_share_of_employment_in_agriculture+raw_share_of_employment_in_industry+raw_share_of_employment_in_services)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="share of\nemployment\nin industry">
				<doc>${Calibrated Output}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>raw_share_of_employment_in_industry/(raw_share_of_employment_in_agriculture+raw_share_of_employment_in_industry+raw_share_of_employment_in_services)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="share of\nemployment\nin services">
				<doc>${Calibrated Output}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>raw_share_of_employment_in_services/(raw_share_of_employment_in_agriculture+raw_share_of_employment_in_industry+raw_share_of_employment_in_services)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="UNIT Employment to\nLabour Supply">
				<doc>${Unit}
</doc>
				<eqn>1</eqn>
				<units>MLabour/Mp</units>
			</aux>
			<aux name="Raw Labour Supply">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Employed*UNIT_Employment_to_Labour_Supply</eqn>
				<units>MLabour</units>
			</aux>
			<aux name="Raw Labour\nSupply agriculture">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Raw_Labour_Supply*share_of_employment_in_agriculture</eqn>
				<units>MLabour</units>
			</aux>
			<aux name="Raw Labour\nSupply industry">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Raw_Labour_Supply*share_of_employment_in_industry</eqn>
				<units>MLabour</units>
			</aux>
			<aux name="Raw Labour\nSupply services">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Raw_Labour_Supply*share_of_employment_in_services</eqn>
				<units>MLabour</units>
			</aux>
			<aux name="Labour Supply\nagriculture with Climate Impacts">
				<doc>${Climate Impact Parameter}
Mapping of raw labour supply into difference exposure levels to climate change, based on Dasgupta et al. (2021). DOI: 10.1016/S2542-5196(21)00170-4</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Raw_Labour_Supply_agriculture*
(
labour_exposure_shares_in_agriculture[No_Exposure]*
1
+
labour_exposure_shares_in_agriculture[Low_Exposure]*
effect_of_climate_on_low_exposure_labour
+
labour_exposure_shares_in_agriculture[High_Exposure]*
effect_of_climate_on_high_exposure_labour
)</eqn>
				<units>MLabour</units>
			</aux>
			<aux name="Labour Supply\nindustry with\nClimate Impacts">
				<doc>${Climate Impact Parameter}
Mapping of raw labour supply into difference exposure levels to climate change, based on Dasgupta et al. (2021). DOI: 10.1016/S2542-5196(21)00170-4</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Raw_Labour_Supply_industry*
(
labour_exposure_shares_in_industry[No_Exposure]*
1
+
labour_exposure_shares_in_industry[Low_Exposure]*
effect_of_climate_on_low_exposure_labour
+
labour_exposure_shares_in_industry[High_Exposure]*
effect_of_climate_on_high_exposure_labour
)</eqn>
				<units>MLabour</units>
			</aux>
			<aux name="Labour Supply\nservices with\nClimate Impacts">
				<doc>${Climate Impact Parameter}
Mapping of raw labour supply into difference exposure levels to climate change, based on Dasgupta et al. (2021). DOI: 10.1016/S2542-5196(21)00170-4</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Raw_Labour_Supply_services*
(
labour_exposure_shares_in_services[No_Exposure]*
1
+
labour_exposure_shares_in_services[Low_Exposure]*
effect_of_climate_on_low_exposure_labour
+
labour_exposure_shares_in_services[High_Exposure]*
effect_of_climate_on_high_exposure_labour
)</eqn>
				<units>MLabour</units>
			</aux>
			<aux name="Labour Supply with Climate Impacts">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Labour_Supply_agriculture_with_Climate_Impacts+Labour_Supply_industry_with_Climate_Impacts+Labour_Supply_services_with_Climate_Impacts</eqn>
				<units>MLabour</units>
			</aux>
			<aux name="labour exposure shares in agriculture">
				<doc>${Assumption}
Fractional exposure levels to temperature for agriculture related labour. Assumptions are based on Dasgupta et al. (2021). DOI: 10.1016/S2542-5196(21)00170-4</doc>
				<dimensions>
					<dim name="labouExposureLevel"/>
				</dimensions>
				<element subscript="No_Exposure">
					<eqn>0</eqn>
				</element>
				<element subscript="Low_Exposure">
					<eqn>0.1</eqn>
				</element>
				<element subscript="High_Exposure">
					<eqn>0.9</eqn>
				</element>
				<units>dmnl</units>
			</aux>
			<aux name="labour exposure\nshares in industry">
				<doc>${Assumption}
Fractional exposure levels to temperature for industrial labour. Assumptions are based on Dasgupta et al. (2021). DOI: 10.1016/S2542-5196(21)00170-4</doc>
				<dimensions>
					<dim name="labouExposureLevel"/>
				</dimensions>
				<element subscript="No_Exposure">
					<eqn>0.25</eqn>
				</element>
				<element subscript="Low_Exposure">
					<eqn>0.5</eqn>
				</element>
				<element subscript="High_Exposure">
					<eqn>0.25</eqn>
				</element>
				<units>dmnl</units>
			</aux>
			<aux name="labour exposure shares\nin services">
				<doc>${Assumption}
Fractional exposure levels to temperature for service related labour. Assumptions are based on Dasgupta et al. (2021). DOI: 10.1016/S2542-5196(21)00170-4</doc>
				<dimensions>
					<dim name="labouExposureLevel"/>
				</dimensions>
				<element subscript="No_Exposure">
					<eqn>0.75</eqn>
				</element>
				<element subscript="Low_Exposure">
					<eqn>0.25</eqn>
				</element>
				<element subscript="High_Exposure">
					<eqn>0</eqn>
				</element>
				<units>dmnl</units>
			</aux>
			<aux name="Surface Temperature Anomaly 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>deg C</units>
			</aux>
			<aux name="realised\nproductivity" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Productivity*climate_impact_on_productivity</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="climate impact\non productivity">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>climate_impact_of_heat_on_productivity * Productivity_reduction_factor_from_coastal_flooding</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="fraction fired from\nproductivity gains">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(realised_productivity_growth*fraction_of_productivity_gains_translating_to_firing, time_for_productivity_to_affect_firing)</eqn>
				<isee:delay_aux/>
				<units>dmnl/year</units>
			</aux>
			<aux name="fraction of\nproductivity gains translating to firing">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.5</eqn>
				</element>
				<range min="0.25" max="0.75"/>
				<units>dmnl</units>
			</aux>
			<aux name="exploratory\nloan failure" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="realised\nproductivity\ngrowth" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>TREND(realised_productivity, 1, initial_productivity_growth)</eqn>
				<units>dmnl/Year</units>
			</aux>
			<aux name="initial\nproductivity\ngrowth">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.0258317400509399</eqn>
				<range min="0.01" max="0.03"/>
				<units>dmnl/Year</units>
			</aux>
			<stock name="Productivity">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1</eqn>
				<inflow>change_in_productivity</inflow>
				<units>dmnl</units>
			</stock>
			<flow name="change in\nproductivity">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>productivity_under_development/average_development_completion_time</eqn>
				<non_negative/>
				<units>dmnl/Years</units>
			</flow>
			<stock name="productivity\nunder development">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Productivity*indicated_productivity_growth*average_development_completion_time</eqn>
				<inflow>productivity_starting_development</inflow>
				<outflow>change_in_productivity</outflow>
				<units>dmnl</units>
			</stock>
			<flow name="productivity\nstarting development">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Productivity * indicated_productivity_growth</eqn>
				<non_negative/>
				<units>dmnl/Years</units>
			</flow>
			<aux name="average\ndevelopment\ncompletion time">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>5</eqn>
				</element>
				<range min="4" max="6"/>
				<units>years</units>
			</aux>
			<aux name="threshold\nunemployment\nrate">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.0991787525880569</eqn>
				</element>
				<range min="0.04" max="0.15"/>
				<units>dmnl</units>
			</aux>
			<aux name="effect of labour\nsupply on hiring">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MIN(1, unemployment_rate / threshold_unemployment_rate)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="sensitivity\nof hiring to\nunemployment\nrate">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>2.28968050025845</eqn>
				</element>
				<range min="0.1" max="5"/>
				<units>dmnl</units>
			</aux>
			<aux name="safe loans\nfinancing innovation" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="exploratory\nbank investment" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="GDP" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="non bank innovation\ninvestment share of GDP">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(safe_loans_financing_innovation + CB_safe_loans_affected_innovation)/GDP</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="productivity yield of\nnon bank innovation">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.132668695</eqn>
				</element>
				<range min="0.05" max="0.25"/>
				<units>1/year</units>
			</aux>
			<aux name="indicated productivity growth\nfrom non bank innovation">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>non_bank_innovation_investment_share_of_GDP*productivity_yield_of_non_bank_innovation</eqn>
				<units>1/year</units>
			</aux>
			<aux name="exploratory bank investment share of GDP">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>exploratory_bank_investment/GDP</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="indicated productivity growth from bank exploration">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>exploratory_bank_investment_share_of_GDP*productivity_yield_of_exploratory_investment</eqn>
				<units>1/year</units>
			</aux>
			<aux name="productivity yield of exploratory investment">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>1.947328313</eqn>
				</element>
				<range min="0.9473283132336" max="2.9473283132336"/>
				<units>1/year</units>
			</aux>
			<aux name="time for\nproductivity\nto affect firing">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>5</eqn>
				<range min="3" max="7"/>
				<units>years</units>
			</aux>
			<aux name="time for defaults\nto affect firing">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>1</eqn>
				</element>
				<range min="0.5" max="1.5"/>
				<units>year</units>
			</aux>
			<aux name="hiring">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MIN(Unemployed[Run]*max_fraction_hireable
+ firing,
desired_additional_hires*effect_of_labour_supply_on_hiring^sensitivity_of_hiring_to_unemployment_rate)

+ desired_additional_hires_due_to_CB_public_investment
+ desired_additional_hires_due_to_government_public_investment</eqn>
				<units>Mp/year</units>
			</aux>
			<aux name="firing">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MIN(max_firing_rate*Employed, firing_from_defaults+firing_from_missed_profits+firing_from_productivity_gains)</eqn>
				<units>Mp/year</units>
			</aux>
			<aux name="time to fire from missed profits">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1</eqn>
				<range min="0.5" max="1.5"/>
				<units>years</units>
			</aux>
			<aux name="ratio of missed profit\nto threshold">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MAX(1, profit_firing_threshold/non_bank_profits_1)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="sensitivity of firing to profit discrepancy">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.5</eqn>
				<range min="0.25" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="effect of missed profits">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MIN(1, (ratio_of_missed_profit_to_threshold^sensitivity_of_firing_to_profit_discrepancy)-1)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="real GDP per person" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>bc$/Mp/year</units>
			</aux>
			<aux name="total defaults for firing impact">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>exploratory_loan_failure + total_non_exploratory_defaults + exploratory_loan_defaults_from_from_interest + actual_safe_investment_failure+safe_loan_defaults_1 
+ CB_total_loan_defaults
+CB_safe_loan_defaults
+CB_actual_safe_investment_failure</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="today" access="input">
				<eqn>2025</eqn>
				<units>year</units>
			</aux>
			<aux name="Productivity reduction factor from coastal flooding" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>1</units>
			</aux>
			<aux name="climate impact of heat on productivity">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Labour_Supply_with_Climate_Impacts/Raw_Labour_Supply</eqn>
				<units>1</units>
			</aux>
			<aux name="switch labor damage" access="input">
				<eqn>1</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="previous effect of climate\non low exposure\nlabour">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>PREVIOUS(effect_of_climate_on_low_exposure_labour, 1)</eqn>
				<isee:delay_aux/>
				<units>dmnl</units>
			</aux>
			<aux name="previous effect of climate on\nhigh exposure labour">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>PREVIOUS(effect_of_climate_on_high_exposure_labour, 1)</eqn>
				<isee:delay_aux/>
				<units>dmnl</units>
			</aux>
			<aux name="indicated productivity growth">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>indicated_productivity_growth_from_bank_exploration+indicated_productivity_growth_from_non_bank_innovation</eqn>
				<units>1/year</units>
			</aux>
			<aux name="UNIT percent 1" access="input">
				<eqn>100</eqn>
				<units>%</units>
			</aux>
			<aux name="unemployment percentage">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>unemployment_rate*UNIT_percent_1</eqn>
				<units>%</units>
			</aux>
			<aux name="average private debt safe interest" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>1/year</units>
			</aux>
			<aux name="exploratory loan\ndefaults from\nfrom interest" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="actual safe\ninvestment failure" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="firing from\nproductivity gains">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>fraction_fired_from_productivity_gains*Employed</eqn>
				<units>Mp/year</units>
			</aux>
			<aux name="UNIT percent">
				<doc>${Unit}
</doc>
				<eqn>0.01</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="total non exploratory defaults" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="max firing rate">
				<doc>${Assumption}
Interface explosion stopper</doc>
				<eqn>1</eqn>
				<units>dmnl/year</units>
			</aux>
			<aux name="private\nsafe bank assets" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$</units>
			</aux>
			<aux name="safe loan\ndefaults 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="cap on wage growth">
				<eqn>1</eqn>
				<units>1/year</units>
			</aux>
			<aux name="max fraction\nhireable">
				<eqn>1</eqn>
				<units>1/year</units>
			</aux>
			<aux name="Central Bank investment" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="CB total loan defaults" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="CB safe loan\ndefaults" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="CB actual safe\ninvestment failure" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="CB safe loans\naffected innovation" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="desired additional hires\ndue to CB public investment">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Central_Bank_investment * hiring_to_investment_ratio/wage_rate_in_billions_per_million_people</eqn>
				<units>Mp/year</units>
			</aux>
			<aux name="extra government run\npublic investment" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="desired additional hires\ndue to government public investment">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>extra_government_run_public_investment * hiring_to_investment_ratio/wage_rate_in_billions_per_million_people</eqn>
				<units>Mp/year</units>
			</aux>
			<group name="Impact of Public Investment\nPolicy to Hiring" run="false">
				<format scale_by="auto"/>
				<entity name="Central_Bank_investment"/>
				<entity name="desired_additional_hires_due_to_CB_public_investment"/>
				<entity name="desired_additional_hires_due_to_government_public_investment"/>
				<entity name="extra_government_run_public_investment"/>
			</group>
			<group name="CB Policy impacts to firing" run="false">
				<format scale_by="auto"/>
				<entity name="CB_actual_safe_investment_failure"/>
				<entity name="CB_safe_loan_defaults"/>
				<entity name="CB_total_loan_defaults"/>
			</group>
		</variables>
