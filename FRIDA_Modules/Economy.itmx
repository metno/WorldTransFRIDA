			</aux>
			<aux name="public investment\npolicy p factor">
				<doc>${Assumption}
This is effectively a controller gain. It tunes aggressiveness rather than representing a directly observed institution. Keep a moderate range around 1.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1</eqn>
				<range min="0.5" max="2"/>
				<units>dmnl</units>
			</aux>
