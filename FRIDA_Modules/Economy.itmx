	</model>
	<model name="Finance">
		<variables>
			<aux name="risky\ninterest" access="output" isee:autocreated="true">
				<doc>This is the price faced by risky borrowers.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>average_private_debt_safe_interest+(Risk_Premium)</eqn>
				<units>1/year</units>
			</aux>
			<stock name="Risk\nPremium">
				<doc>Risk premium is the extra interest rate banks charge on risky loans on top of a safe benchmark rate to compensate for expected defaults and uncertainty.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>initial_risk_premium</eqn>
				<inflow>change_in_risk_premium</inflow>
				<non_negative/>
				<units>1/year</units>
			</stock>
			<flow name="change in\nrisk premium">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(indicated_risk_premium-Risk_Premium)/renegotiation_time</eqn>
				<units>1/year/years</units>
			</flow>
			<flow name="bad loans\ndefaults">
				<doc>Total “maturation-type” clearance of bad loans happens over loan_maturation_time</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Bad_Loans-bad_loan_defaults_from_from_interest*DT - converting_to_good_because_of_reduced_interest_rates*DT)/loan_maturation_time</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<flow name="loans\nturning safe">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Good_Loans - good_loan_defaults_from_from_interest*DT ) /loan_maturation_time</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<flow name="bad\ninvestments">
				<doc>new investment that fail this year</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>normal_investment*failure_rate</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<flow name="good\ninvestments">
				<doc>new investment that are not failing this year.

(1-failure rate) means a survived portions</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>normal_investment*(1-failure_rate)</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<stock name="Good\nLoans">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>initial_good_loans</eqn>
				<inflow>good_investments</inflow>
				<inflow>converting_to_good_because_of_reduced_interest_rates</inflow>
				<outflow>loans_turning_safe</outflow>
				<outflow>good_loan_defaults_from_from_interest</outflow>
				<non_negative/>
				<units>b$</units>
			</stock>
			<stock name="Bad\nLoans">
				<doc>Investment that fail</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>initial_bad_loans</eqn>
				<inflow>bad_investments</inflow>
				<outflow>bad_loans_defaults</outflow>
				<outflow>converting_to_good_because_of_reduced_interest_rates</outflow>
				<outflow>bad_loan_defaults_from_from_interest</outflow>
				<non_negative/>
				<units>b$</units>
			</stock>
			<stock name="Safe\nLoans">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Initial_safe_assets-initial_government_debt)
- (Initial_safe_assets-initial_government_debt) * initial_fraction_of_safe_loans_financing_innovation
- (Initial_safe_assets-initial_government_debt) * initial_fraction_of_safe_loans_that_are_exploratory


{(Initial_safe_assets-Government.initial_government_debt)*(1-initial_fraction_of_safe_loans_that_will_fail)*(1-initial_fraction_of_safe_loans_that_are_exploratory)</eqn>
				<inflow>loans_turning_safe</inflow>
				<outflow>safe_loans_affected_innovation</outflow>
				<outflow>safe_loan_defaults</outflow>
				<non_negative/>
				<units>b$</units>
			</stock>
			<aux name="loan maturation\ntime">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>11.560506434293</eqn>
				</element>
				<range min="3" max="30"/>
				<units>Years</units>
			</aux>
			<flow name="change in non energy\nbank\ninvestment">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Non_Energy_Bank_Investment*bank_investment_growth_rate</eqn>
				<units>b$/year/years</units>
			</flow>
			<stock name="Non Energy\nBank\nInvestment">
				<doc>FRIDA does NOT have a separate “energy bank investment” stock because energy capacity and energy system investments are handled in the Energy sector, not through bank balance sheets.

Bank lending and investment affects non-energy parts of the economy (firms, capital formation, production capacity) via the Non-Energy Bank Investment stock.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>initial_non_energy_bank_investment</eqn>
				<inflow>change_in_non_energy_bank_investment</inflow>
				<units>b$/year</units>
			</stock>
			<stock name="lending standards">
				<doc>Lending standards is the actual stock variable representing how tight or loose bank credit conditions are at a given moment. This stock increases from change in lending standard, with an initial value of 1, so the model starts from a normalized baseline credit stance. This variable matters because it is the implemented constraint on lending behavior, not just a desired signal, and it feeds into the wider macro-financial system. When lending standards rise, banks become more restrictive, which reduces bank investment growth and can also increase firm failures through refinancing pressure. So this is one of the main transmission variables through which climate-driven financial stress spreads into investment, output, and employment.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1</eqn>
				<inflow>change_in_lending_standards</inflow>
				<units>dmnl</units>
			</stock>
			<flow name="change in\nlending\nstandards">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(indicated_lending_standards-lending_standards)/time_to_change_lending_standards</eqn>
				<units>Per Year</units>
			</flow>
			<aux name="max change in lending\nstandards">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.227265506831574</eqn>
				</element>
				<range min="0" max="1"/>
				<units>dmnl</units>
			</aux>
			<aux name="indicated\nlending standards">
				<doc>Indicated lending standards is the level of lending standards banks would like to have, given current default conditions and prudential signals, before implementation delay is accounted for. It is included because FRIDA separates the desired bank stance from the actual implemented lending stance, which is good system-dynamics practice whenever institutions adjust gradually. This variable is shaped by the effects of risky-default conditions and safe-default conditions, so it synthesizes the bank sector’s desired prudential response before smoothing. That means it represents the immediate policy signal inside banks: how tight credit should be right now if they could adjust instantly. </doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(lending_standards*effect_of_safe_default_rate_on_lending_standards)+(max_change_in_lending_standards*effect_of_risky_default_rate_on_lending_standards)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="time to change\nlending standards">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>1.14041208323877</eqn>
				</element>
				<range min="0.5" max="2"/>
				<units>year</units>
			</aux>
			<aux name="bank investment\ngrowth rate">
				<doc>It represents the actual bank investment growth. It accounts for (1) indicated bank investment growth due to long term solvency and reference bank investment growth, and (2) effect of lending standard on bank investment growth rate.

(1) with the indicated bank investment growth, we can know what is our baseline lending expansion trend, given solvency and long-run expectations.

(2) with the effect of lending standards, we can know given credit conditions, risk appetite, and short-term stress, whether we tighten or loosen lending beyond the structural signal.

FRIDA needs both layers because banks do not decide credit growth in one step.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>indicated_bank_investment_growth_rate*effect_of_lending_standards_on_bank_investment_growth_rate</eqn>
				<units>dmnl/year</units>
			</aux>
			<aux name="perceived\ndefaults of risky assets\nfor interest rate">
				<doc>It is the amount of risky-loan defaults that lenders think are “real credit risk,” after accounting for the fact that some losses are covered by insurance and some insurance payouts do not fully reassure markets.

This variable is the bank/market’s perceived net credit loss signal that is used specifically to adjust the risk premium (risky interest rate).</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(total_risky_asset_defaults-
(insurance_payouts + climate_induced_bankruptcies + government_insurance_payout)
*fraction_of_insurance_payouts_not_influencing_risk_premium, reporting_delay)</eqn>
				<isee:delay_aux/>
				<units>b$/year</units>
			</aux>
			<aux name="reporting\ndelay">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.475468387137114</eqn>
				</element>
				<range min="0.125" max="1.5"/>
				<units>year</units>
			</aux>
			<aux name="measured\ndefault rate of risky assets for interest rate">
				<doc>This normalizes defaults:
$10B defaults is small if assets are $1T but huge if assets are $50B
Banks price rates, not volumes.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(perceived_defaults_of_risky_assets_for_interest_rate/risky_bank_assets)</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="failure rate">
				<doc>It is the final percentage of firms that fail (go bankrupt) in each period, based on climate damage, investment weakness, and baseline failures.
It is a central variable because firm failures can:
- destroy bank assets → reduce solvency
- reduce GDP
- reduce employment
- amplify the climate–finance doom loop</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MIN(1, MAX(failure_rate_floor,  indicated_failure_rate+(max_change_in_failure_rate*effect_of_lending_standards_on_failure_rate)))</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="normal\nfailure rate">
				<doc>${Internal Calibration Parameter}
It is a baseline rate at which firms fail in a healthy economy, without any climate-related damages.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.0366772752025615</eqn>
				</element>
				<range min="0.01" max="0.08"/>
				<units>dmnl</units>
			</aux>
			<aux name="effect of lending\nstandards on\nbank investment\ngrowth rate">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(INIT(lending_standards)/lending_standards)^elasticity_of_desired_bank_growth_rate_to_changes_in_lending_standards</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="elasticity of\ndesired bank growth\nrate to changes in lending\nstandards">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>2.98312748185925</eqn>
				</element>
				<range min="0" max="10"/>
				<units>dmnl</units>
			</aux>
			<aux name="indicated bank\ninvestment growth rate">
				<doc>It represent the trend banks would follow if there were two tactical adjustment like lending standard. 

&quot;Given long-term investment reference (which also coming from long-term lending growth) AND the bank’s solvency condition (equity ratio gap), what growth rate should the bank use before considering short-term lending standards?&quot;

</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>reference_bank_investment_growth_rate*effect_of_equity_gap_on_indicated_bank_investment_growth_rate</eqn>
				<units>dmnl/year</units>
			</aux>
			<aux name="max change\nin failure rate">
				<doc>${Internal Calibration Parameter}
This is the maximum amount by which bank behavior is allowed to adjust the failure rate up or down. Banks can worsen firm failures by up to 7 percentage points. They cannot create catastrophic spikes beyond this limit
This prevents numerical instability and unrealistic cascades</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.0758533243476001</eqn>
				</element>
				<range min="0.02" max="0.5"/>
				<units>dmnl</units>
			</aux>
			<aux name="indicated\nrisk premium">
				<doc>It explains what the risk premium should be right now, given defaults.
It combines baseline (initial risk premium), effect of current default conditions. 
This is a desired level, not what actually happens instantly.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MINSOFT(initial_risk_premium*effect_of_risky_defaults_rate_on_risk_premium,  max_indicated_risk_premium, tolerance_of_the_cap_on_indicated_risk_premium)</eqn>
				<units>1/year</units>
			</aux>
			<aux name="effect of risky defaults\nrate on risk premium">
				<doc>“How aggressively do lenders reprice risk when defaults deviate from normal?”
Higher elasticity → more nervous markets.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(measured_default_rate_of_risky_assets_for_interest_rate/reference_default_rate)^elasticity_of_bankruptcy_rate_on_risk_premium</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="elasticity of bankruptcy\nrate on risk premium">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>2.96025826515849</eqn>
				</element>
				<range min="2.5" max="5"/>
				<units>dmnl</units>
			</aux>
			<aux name="initial risk premium">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.0284093110372649</eqn>
				</element>
				<range min="0.01" max="0.05"/>
				<units>1/year</units>
			</aux>
			<aux name="climate adjusted\nfailure rate">
				<doc>This is the current failure rate, given today’s climate conditions.
“If loans were issued today, what would be the probability of failure under today’s climate stress?”</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>normal_failure_rate*effect_of_STA_on_failure_rate</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="initial\nnon energy\nbank investment">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>3000</eqn>
				<range min="1000" max="5000"/>
				<units>b$/year</units>
			</aux>
			<aux name="initial good loans">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>8240.06768880644</eqn>
				<range min="7500" max="8500"/>
				<units>b$</units>
			</aux>
			<aux name="initial bad loans">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>202.031071557794</eqn>
				<range min="180" max="300"/>
				<units>b$</units>
			</aux>
			<aux name="Initial safe assets">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>72569.1999314293</eqn>
				<range min="60000" max="100000"/>
				<units>b$</units>
			</aux>
			<aux name="risky bank assets" access="output">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Good_Loans+Bad_Loans</eqn>
				<units>b$</units>
			</aux>
			<aux name="private\nsafe bank assets" access="output">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Safe_Loans+safe_loans_for_financing_innovation</eqn>
				<units>b$</units>
			</aux>
			<aux name="Bank\nAssets" isee:derived_units="true" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Safe_Loans
+Bad_Loans
+Good_Loans
+Exploratory_Loans
+safe_loans_for_financing_innovation
+Government_Debt
+Central_Bank_Deposits
+&quot;Firm-owned_Central_Bank_Deposits&quot;</eqn>
				<units>b$</units>
			</aux>
			<aux name="Bank\nLiabilities">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Worker_Savings_1+owner_savings_1+Firms_Checking_Accounts + Insurance_Deposits</eqn>
				<units>b$</units>
			</aux>
			<aux name="net bank\nassets" access="output">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Bank_Assets - Bank_Liabilities</eqn>
				<units>b$</units>
			</aux>
			<aux name="assets to\nliability ratio" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Bank_Assets/Bank_Liabilities</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="total investment" access="output" isee:autocreated="true">
				<doc>${Calibrated Output}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>private_investment_1+public_investment</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="public investment" access="output" throughput="true" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Investment\ngrowth rate">
				<doc>Adding CB investments as an additional investment stream. When CB investments happen, the model should “see” higher investment activity. This is treated as combined growth signal from bank investment and CB investment</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>TREND(Bank_Investment 
+ government_run_public_investment
+ Central_Bank_investment, 1, initial_bank_investment_growth_rate)</eqn>
				<units>1/year</units>
			</aux>
			<aux name="investment to GDP growth ratio">
				<doc>The economy becomes fragile when investment does not keep pace with GDP growth.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Investment_growth_rate//nominal_GDP_growth_rate</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="effect of investment to\ngdp ratio on failure rate">
				<doc>This variable measures how much the firm failure rate increases when investment grows more slowly relative to GDP. If GDP is growing but investment is not keeping up, firms cannot replace depreciating capital, productivity growth slows, margins shrink, and more firms fail.

MAX 0 shift upward so the final effect never drops below 1. This means weak investment can increase failure rates,
but strong investment does not decrease failure rates.

</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MAX(0, 1+sensitivity_of_failure_rate_to_investment_to_gdp_ratio*(investment_to_GDP_growth_ratio/INIT(investment_to_GDP_growth_ratio)-1))</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="sensitivity of failure rate to\ninvestment to gdp ratio">
				<doc>${Internal Calibration Parameter}
This determines how strongly firm failures respond to investment shortfall.
A higher sensitivity means even a small drop in investment/GDP ratio → big increase in failure rate

This 0.17 value means a 10% drop in investment relative to GDP → raises the failure rate by about 1.7%.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.170408256374284</eqn>
				</element>
				<range min="0.1" max="0.5"/>
				<units>dmnl</units>
			</aux>
			<stock name="Government\nDebt" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>B$</units>
			</stock>
			<aux name="effect of STA\non failure rate">
				<doc>This variable captures how rising global temperature (STA — Surface Temperature Anomaly) increases the firm failure rate, gradually.

So:
STA = 0 → effect = 1 (no additional failures)
STA = 1°C → effect = 1 + sensitivity
STA = 2°C → effect = 1 + 2*sensitivity
STA = 3°C → effect = 1 + 3*sensitivity</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF (switch_economy_damage=0) AND TIME &gt; today THEN
PREVIOUS(SELF, 1)
ELSE
1+sensitivity_of_effect_of_sta_on_failure_rate*(Surface_Temperature_Anomaly)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="sensitivity of effect\nof sta on failure rate">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.566684064319974</eqn>
				</element>
				<range min="0.1" max="1.1"/>
				<units>1/deg C</units>
			</aux>
			<aux name="Surface Temperature Anomaly" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>deg C</units>
			</aux>
			<aux name="private investment 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<stock name="Worker\nSavings 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$</units>
			</stock>
			<stock name="owner\nsavings 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$</units>
			</stock>
			<stock name="Firms\nChecking\nAccounts" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$</units>
			</stock>
			<flow name="safe loans\naffected innovation" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Safe_Loans-safe_loan_defaults*DT)*rate_of_converting_safe_loans_to_safe_loans_for_financing_innovation</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<stock name="Exploratory\nLoans">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Initial_safe_assets-initial_government_debt)*initial_fraction_of_safe_loans_that_are_exploratory</eqn>
				<inflow>exploratory_bank_investment</inflow>
				<outflow>exploratory_loan_failure</outflow>
				<outflow>exploratory_loan_defaults_from_from_interest</outflow>
				<units>b$</units>
			</stock>
			<flow name="exploratory\nbank investment" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Bank_Investment*investment_fraction_to_exploration</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="normal\ninvestment" access="output" isee:autocreated="true">
				<doc>Normal investment is the total bank investment (energy and non energy investment) excluding Exploratory investment.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Bank_Investment-exploratory_bank_investment</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="exploratory\ninterest" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>risky_interest*exploratory_premium</eqn>
				<units>1/year</units>
			</aux>
			<aux name="exploratory\npremium" access="output" isee:autocreated="true">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>2</eqn>
				</element>
				<range min="2" max="4"/>
				<units>dmnl</units>
			</aux>
			<aux name="exploratory\nbank assets" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Exploratory_Loans</eqn>
				<units>b$</units>
			</aux>
			<flow name="exploratory\nloan failure" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Exploratory_Loans-exploratory_loan_defaults_from_from_interest*DT)*exploratory_loans_failure_rate</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="growth rate\nof GDP growth">
				<doc>This takes the derivative (rate of change) of the above smoothed GDP growth trend.
This tells the model not only how fast GDP is growing,
but whether GDP growth itself is increasing or decreasing.

This is important because exploratory loans are very sensitive to economic slowdowns.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>DERIVN(GDP_growth_rate_over_the_last_year, 1)</eqn>
				<units>1/year^2</units>
			</aux>
			<aux name="effect of GDP growth on\nexploratory loan failure">
				<doc>This is important because exploratory loans are very sensitive to economic slowdowns.

If GDP growth derivative is negative (GDP growth slowing):
e.g., DERIVN = –0.02
MIN(0, –0.02) = –0.02
–(–0.02) = +0.02

If GDP growth derivative is positive or zero:
MIN(0, positive) = 0 
Thus, the input to the effect is always positive when GDP is weakening, and zero when GDP is stable or improving.

It means, when GDP growth slows down, exploratory loans start to fail more often, and the rate of failure increases faster when GDP growth is falling sharply</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(-MIN(0, normalized_growth_rate_of_GDP_growth))^sensitivity_of_exploratory_loan_failure_to_GDP_growth</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="sensitivity of exploratory\nloan failure to GDP growth">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>1.04850929725399</eqn>
				</element>
				<range min="0.5" max="1.5"/>
				<units>dmnl</units>
			</aux>
			<aux name="exploratory\nloans failure rate">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>effect_of_GDP_growth_on_exploratory_loan_failure*scale_of_exploratory_loan_failure</eqn>
				<units>1/year</units>
			</aux>
			<aux name="scale of exploratory loan failure">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>7.50780807793014</eqn>
				</element>
				<range min="6" max="9"/>
				<units>1/year</units>
			</aux>
			<aux name="normal growth rate of GDP growth rate">
				<doc>${Assumption}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1</eqn>
				<range min="0.5" max="1.5"/>
				<units>1/year^2</units>
			</aux>
			<stock name="safe loans\nfor financing\ninnovation">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Initial_safe_assets-initial_government_debt) * initial_fraction_of_safe_loans_financing_innovation</eqn>
				<inflow>safe_loans_affected_innovation</inflow>
				<outflow>actual_safe_investment_failure</outflow>
				<non_negative/>
				<units>b$</units>
			</stock>
			<flow name="actual safe\ninvestment failure" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>safe_loans_for_financing_innovation/time_for_safe_loans_that_will_fail_to_actually_fail</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="time for safe loans that will fail to actually fail">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>13.751943326343</eqn>
				</element>
				<range min="3" max="30"/>
				<units>years</units>
			</aux>
			<aux name="normal bank profit\npayment fraction">
				<doc>${Assumption}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1</eqn>
				<range min="0" max="2"/>
				<units>dmnl</units>
			</aux>
			<aux name="annual bank profit\npayment" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MAX(0, net_bank_assets*effect_of_net_bank_assets_fractional_growth_on_bank_profit_payment)</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="net bank assets\nwhen positive">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MAX(0, net_bank_assets)</eqn>
				<units>b$</units>
			</aux>
			<aux name="net bank assets\nfractional growth">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>TREND(net_bank_assets_when_positive, 1, initial_net_bank_asset_fractional_growth)</eqn>
				<units>1/year</units>
			</aux>
			<aux name="effect of net bank assets\nfractional growth on\nbank profit payment">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>normal_bank_profit_payment_fraction*(SMTH1(MAX(0, net_bank_assets_fractional_growth), 1)*sensitivity_of_bank_profit_payment_to_net_asset_growth)</eqn>
				<isee:delay_aux/>
				<units>1/year</units>
			</aux>
			<aux name="sensitivity of bank profit payment to net asset growth">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>1.1</eqn>
				</element>
				<range min="0.5" max="1.5"/>
				<units>dmnl</units>
			</aux>
			<aux name="initial net bank asset\nfractional growth">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.155</eqn>
				<range min="0.1" max="0.22"/>
				<units>1/year</units>
			</aux>
			<flow name="increase in bank exploration orientation">
				<doc>Banks increase their risk appetite when the macroeconomic signals are strong specifically when investment growth &gt; GDP growth.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>effect_investment_and_GDP_difference_on_bank_exploration*(max_bank_exploration_orientation-Bank_Exploration_Orientation)/max_bank_exploration_orientation</eqn>
				<non_negative/>
				<units>1/year</units>
			</flow>
			<flow name="decline in\nbank exploration\norientation">
				<doc>Banks pull back from exploratory activities when profits decline or when financial stress increases.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(effect_profit_decline_on_bank_exploration)*Bank_Exploration_Orientation</eqn>
				<non_negative/>
				<units>1/year</units>
			</flow>
			<aux name="annual bank negative\nprofit fractional growth">
				<doc>annual_bank_negative_profit_fractional_growth measures how quickly bank profits are declining; when profits fall, this signal increases the decline in Bank_Exploration_Orientation, causing banks to reduce risky exploratory lending in response to weakening net asset positions.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MAX(0, -TREND(annual_bank_profit_payment, 1, initial_annual_bank_negative_profit_fractional_growth))</eqn>
				<units>1/year</units>
			</aux>
			<aux name="initial\nannual bank negative\nprofit fractional growth">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.14</eqn>
				<range min="0.05" max="0.35"/>
				<units>1/year</units>
			</aux>
			<aux name="initial fraction of safe\nloans financing innovation">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.03</eqn>
				<range min="0.01" max="0.05"/>
				<units>dmnl</units>
			</aux>
			<aux name="initial fraction of safe\nloans that are exploratory">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.02</eqn>
				<range min="0.001" max="0.05"/>
				<units>dmnl</units>
			</aux>
			<stock name="Bank\nExploration\nOrientation">
				<doc>It represents how willing banks are to pursue high-risk, exploratory loans (e.g., very innovative, uncertain, or emerging technologies).
It is a normalized dimensionless variable (0 to 1) where
0 → banks are fully conservative, avoid risky exploration.
1 → banks are aggressively exploring high-risk/high-return opportunities.

This orientation directly controls how much of total bank investment goes into exploratory (risky) loans.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.5</eqn>
				<inflow>increase_in_bank_exploration_orientation</inflow>
				<outflow>decline_in_bank_exploration_orientation</outflow>
				<units>dmnl</units>
			</stock>
			<aux name="max\nbank exploration\norientation">
				<doc>${Assumption}
</doc>
				<eqn>1</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="effect investment\nand GDP difference\non bank exploration">
				<doc>When investment grows faster than GDP (investment &gt; GDP real), banks interpret this as expansionary conditions and become more willing to explore.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MAX(0, nominal_investment_and_real_GDP_growth_difference)*sensitivity_of_investment_and_GDP_difference</eqn>
				<units>1/year</units>
			</aux>
			<aux name="sensitivity of investment and GDP difference">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>2.217074111</eqn>
				</element>
				<range min="1" max="3"/>
				<units>dmnl</units>
			</aux>
			<aux name="bank desired asset to\nliability ratio">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1.1 {1.08 value from main}</eqn>
				<range min="1.01" max="1.21"/>
				<units>dmnl</units>
			</aux>
			<aux name="required government solvency\nsupport lending" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MAX(0, bailout_ratio_gap*Bank_Liabilities)</eqn>
				<units>b$</units>
			</aux>
			<aux name="bailout ratio gap">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>government_bailout_assets_to_liabilities_threshold-assets_to_liability_ratio</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="effect profit decline\non bank exploration">
				<doc>Banks are moderately sensitive to worsening profitability; exploration declines proportionally.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>annual_bank_negative_profit_fractional_growth*sensitivity_of_bank_exploration_to_profit_decline</eqn>
				<units>1/year</units>
			</aux>
			<aux name="sensitivity\nof bank exploration\nto profit decline">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.501962557</eqn>
				<range min="0.2" max="0.8"/>
				<units>dmnl</units>
			</aux>
			<aux name="investment fraction to\nexploration">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>converted_normal_exploration_fraction*effect_of_bank_exploration_orientation_exploratory_investment_fraction</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="normal exploration rate">
				<doc>${Assumption}
In a normal economy (with no stress and no excitement), banks typically allocate about 3.7% of their lending toward exploratory/high-risk loans.

</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.0369117820963221</eqn>
				<range min="0.01" max="0.05"/>
				<units>dmnl</units>
			</aux>
			<aux name="effect of bank\nexploration orientation\nexploratory investment\nfraction">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Bank_Exploration_Orientation</eqn>
				<gf>
					<xscale min="0" max="1"/>
					<yscale min="0.4" max="2"/>
					<ypts>0.4,0.56,0.72,0.88,1.04,1.2,1.36,1.52,1.68,1.84,2</ypts>
				</gf>
				<units>dmnl</units>
			</aux>
			<aux name="converted\nnormal\nexploration fraction">
				<doc>It is the corrected baseline fraction of lending that ensures that when the bank is in “normal exploration mode,” the true exploration share equals the intended normal exploration rate.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>normal_exploration_rate/exploration_effect_midpoint</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="exploration\neffect midpoint">
				<doc>${Internal Calibration Parameter}
In a normal economy (with no stress and no excitement), banks typically allocate about 3.7% of their lending toward exploratory/high-risk loans.

The midpoint (usually corresponding to orientation = 0.5) is not equal to 1. When orientation = 0.5 (normal attitude),
the effect multiplier ≈ 1.2113, not 1.
That means at normal risk-attitude, banks scale exploratory investment UP by a factor of 1.2113.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1.21134805959858</eqn>
				<range min="0.8" max="1.6"/>
				<units>dmnl</units>
			</aux>
			<aux name="normalized growth\nrate of GDP growth">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>growth_rate_of_GDP_growth/normal_growth_rate_of_GDP_growth_rate</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="GDP growth rate\nover the last year">
				<doc>This is a smoothed version of last year’s GDP growth rate.
GDP growth can be volatile month to month.
Banks do not react to the “instant” GDP growth number.
They respond to the recent trend, not the noise.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(nominal_GDP_growth_rate, 1)</eqn>
				<units>dmnl/year</units>
			</aux>
			<aux name="today" access="input">
				<eqn>2025</eqn>
				<units>year</units>
			</aux>
			<aux name="nominal GDP\ngrowth rate" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>1/year</units>
			</aux>
			<aux name="initial bank investment growth rate">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.0836275699207085</eqn>
				</element>
				<range min="0" max="0.2"/>
				<units>1/year</units>
			</aux>
			<aux name="reference bank investment\ngrowth rate">
				<doc>A very long-run smoothed benchmark of how fast banks typically/ normaly increase investment over decades.
It is the “trend” or “expected structural pace” of credit expansion.

With 80 years of bank reference formation time, banks&apos; deep expectations about long-run lending growth shouldn’t change because of: 5-year cycles, temporary recessions, crises, climate shocks</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(bank_investment_growth_rate, bank_reference_formation_time, initial_bank_investment_growth_rate)</eqn>
				<isee:delay_aux/>
				<units>1/year</units>
			</aux>
			<aux name="bank reference\nformation time">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>80</eqn>
				</element>
				<range min="20" max="100"/>
				<units>years</units>
			</aux>
			<aux name="switch economy damage" access="input">
				<eqn>1</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="private debt to gdp ratio">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Private_Debt/Nominal_GDP</eqn>
				<units>year</units>
			</aux>
			<aux name="Private Debt">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Bank_Assets</eqn>
				<units>B$</units>
			</aux>
			<aux name="renegotiation time">
				<doc>${Assumption,Internal Calibration Parameter}
Average time it takes contracts to reset, rates to be repriced, refinancing to occur.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>1</eqn>
				</element>
				<range min="1" max="1.5"/>
				<units>year</units>
			</aux>
			<aux name="average private debt safe interest" access="output" isee:autocreated="true">
				<doc>It represents how much income the insurance reserve generates each year from being held in safe assets rather than sitting idle. This is important because it makes the insurance fund financially sustainable over time and links insurance capacity to macro-financial conditions, especially the safe interest environment.SMTH1( … , average_time_private_refinances_debt ) introduces a delay / smoothing, meaning private borrowers and lenders do not instantly adjust to policy rate changes. </doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(safe_interest, average_time_private_refinances_debt)</eqn>
				<units>1/year</units>
			</aux>
			<aux name="average time private refinances debt">
				<doc>${Assumption,Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>3</eqn>
				</element>
				<range min="2" max="4"/>
				<units>years</units>
			</aux>
			<aux name="safe\ninterest" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>1/year</units>
			</aux>
			<aux name="Nominal GDP" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<flow name="good loan\ndefaults from\nfrom interest">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Good_Loans*default_rate_from_interest_rate_increase</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="default rate from\ninterest rate increase">
				<doc>This is the additional loan default rate caused by rising interest rates. It 

The equation embodies three realities:
(1) Borrower stress begins only when interest rises above origination interest.
(2) The stress grows nonlinearly (exponent).
(3) Defaults from interest hikes cannot exceed a realistic limit (soft cap).</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MINSOFT(((sensitivity_of_defaults_to_changes_in_risky_interest*
MAX(0,extra_risky_interest_above_interest_at_origination*time_to_measure_changes_in_risky_interest))^exponential_effect_of_interest_on_defaults)/time_to_measure_changes_in_risky_interest, maximum_default_rate_from_interest_rate_increases, tolerance_of_the_cap_on_default_rate_from_interest_rate_increases)</eqn>
				<units>1/year</units>
			</aux>
			<aux name="risky interest at loan\norigination time">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(risky_interest, average_time_private_refinances_debt)</eqn>
				<units>1/year</units>
			</aux>
			<aux name="extra risky interest\nabove interest\nat origination">
				<doc>This measures how much today’s risky interest rate exceeds the interest rate that borrowers originally agreed to.
If this is negative or zero, borrowers are not exposed to extra interest burden.
If positive → borrowers face higher repayment burden, which raises defaults.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>risky_interest-risky_interest_at_loan_origination_time</eqn>
				<units>1/year</units>
			</aux>
			<aux name="sensitivity of\ndefaults\nto changes in\nrisky interest">
				<doc>${Internal Calibration Parameter}
This parameter determines how strongly borrowers respond when interest increases.
High sensitivity → even small interest increases create many defaults
Low sensitivity → borrowers are more resilient
It is a scaling factor before the exponential effect</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>11.89928999</eqn>
				</element>
				<range min="10" max="13.3"/>
				<units>dmnl</units>
			</aux>
			<aux name="exponential effect\nof interest\non defaults">
				<doc>${Internal Calibration Parameter}
This exponent controls nonlinearity.
Why exponent?
Because empirical credit data shows:
A small interest increase → small default increase
A big interest increase → disproportionately large default increase. So this exponent captures this non-linear jump in risk.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>9.049245183</eqn>
				<range min="8" max="12"/>
				<units>dmnl</units>
			</aux>
			<aux name="time to measure\nchanges in\nrisky interest">
				<doc>${Unit}
This is to keep the units consistent with the exponential form of the equation</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>1</eqn>
				</element>
				<range min="0.8" max="1.2"/>
				<units>year</units>
			</aux>
			<flow name="converting to good\nbecause of reduced interest\nrates">
				<doc>In the bank investment loan, when interest rates fall, some borderline bad loans become serviceable again.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Bad_Loans*conversion_rate_from_interest_rate_decrease</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="conversion rate from\ninterest rate decrease">
				<doc>If extra risky interest above interest at origination is positive, interest rates have increased since the loan was issued.
If this is negative, interest rates have decreased since origination.
In this variable, we focus on the negative case.

If interest decreased, then:
extra_risky_interest_above_interest_at_origination &lt; 0
multiply by –1 → positive
MAX(0, positive) → positive
So this logic captures the magnitude of interest rate decreases.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MINSOFT(((sensitivity_of_defaults_to_changes_in_risky_interest*
MAX(0,-1*extra_risky_interest_above_interest_at_origination*time_to_measure_changes_in_risky_interest))^exponential_effect_of_interest_on_defaults)
/time_to_measure_changes_in_risky_interest, maximum_default_rate_from_interest_rate_increases, tolerance_of_the_cap_on_default_rate_from_interest_rate_increases)</eqn>
				<units>1/year</units>
			</aux>
			<flow name="bad loan\ndefaults from\nfrom interest">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Bad_Loans*default_rate_from_interest_rate_increase</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<flow name="exploratory loan\ndefaults from\nfrom interest" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Exploratory_Loans*default_rate_from_interest_rate_increase</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="risky asset interest\ndefaults">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>good_loan_defaults_from_from_interest + bad_loan_defaults_from_from_interest</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="total risky asset defaults" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>bad_loans_defaults
+ risky_asset_interest_defaults</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="nominal GDP\ngrowth rate 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>1/year</units>
			</aux>
			<aux name="max indicated\nrisk premium">
				<doc>Upper bound on how high spreads can go.
Markets panic, but not infinitely.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>max_risk_premium_increase_rate+Risk_Premium</eqn>
				<units>1/year</units>
			</aux>
			<aux name="max risk premium\nincrease rate">
				<doc>${External Parameter}
Limits how fast spreads can rise.
Prevents instantaneous spikes.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.015</eqn>
				<range min="0.01" max="0.15"/>
				<units>1/year</units>
			</aux>
			<aux name="maximum default\nrate from interest rate increases">
				<doc>${Assumption}
maximum value to prevent unrealistic spikes where all loans default immediately.


In real financial systems not all loans default instantly, even when interest spikes.
Some have fixed rates.
Some refinance.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>.15</eqn>
				<range min="0.1" max="0.5"/>
				<units>1/year</units>
			</aux>
			<aux name="tolerance of the cap\non default rate\nfrom interest rate\nincreases">
				<doc>${External Parameter}
tolerance_of_the_cap lets the cap be smoothly applied rather than abruptly.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.06</eqn>
				<range min="0.01" max="0.11"/>
				<units>1/year</units>
			</aux>
			<aux name="tolerance of the cap on\nindicated risk premium">
				<doc>${Assumption}
Softens the cap (smooth clipping instead of hard cutoff).
This avoids numerical and behavioral discontinuities.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.01</eqn>
				<range min="0.005" max="0.015"/>
				<units>1/year</units>
			</aux>
			<aux name="Nominal Gross Energy Investment">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>All_Energy_Investments*&quot;inflation_adjustment_b$_per_bc$_2&quot;/&quot;UNIT_c$_per_Bc$&quot;</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="inflation adjustment b$ per bc$ 2" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/bc$</units>
			</aux>
			<aux name="UNIT c$ per Bc$">
				<doc>${Unit}
</doc>
				<eqn>1000000000</eqn>
				<units>c$/bc$</units>
			</aux>
			<aux name="Bank Investment">
				<doc>This is a backward-looking historical measure of how the stock of investment itself has been growing over time.
It looks at how Bank Investment has changed in the past.

NOTE:
The different with bank investment growth rate is that bank investment growth rate is a forward-looking behavioral decision made by banks based on: solvency (equity gap → indicated rate) and short-term lending standards </doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Nominal_Gross_Energy_Investment+Non_Energy_Bank_Investment</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="private investment" access="output" isee:autocreated="true">
				<doc>In FRIDA, private investment is driven by bank investment, because firms borrow from banks, banks decide how much to invest/loan.
This is consistent with stock-flow consistent macro models and Schumpeterian finance-driven growth.

Private investment does not jump immediately when bank investment changes.
It changes smoothly over 1 year. 

Private investment feeds into circular flow firm as an inflow. It is the investment flow that the economy sees. Therefore, adding CB investment in this variable aims to allow other part of economy &apos;sees&apos; this impact of investment (e.g. employment).</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(Bank_Investment, 1, initial_non_energy_bank_investment)</eqn>
				<isee:delay_aux/>
				<units>b$/year</units>
			</aux>
			<aux name="stranded capital" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>c$/Year</units>
			</aux>
			<aux name="All Energy Investments" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>c$/Year</units>
			</aux>
			<aux name="stranded energy\ncapital">
				<doc>It is the value of fossil-energy-related capital that has lost economic value due to climate policy or energy transition.

Examples of stranded capital:
- Coal plants shut down early
- Oil/gas reserves that cannot be extracted
- Fossil infrastructure that becomes uneconomic</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>stranded_capital*&quot;inflation_adjustment_b$_per_bc$_2&quot;/&quot;UNIT_c$_per_Bc$&quot;</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="stranded energy\nrelated capital">
				<doc>This captures second-order losses where stranded fossil assets don’t just lose value themselves.
They also pull down the value of related assets, such as:
- pipelines
- fossil transport fleets
- fossil-dependent industrial supply chains

This variable multiplies the stranded capital by a factor (effect_of_stranded_energy_capital_on_other_assets), which represents:
“For every $1 of fossil stranded capital, how much additional asset value is lost elsewhere in the system?”

For example, if the factor = 0.5:
$100B stranded fossil assets create
$50B additional losses in related sectors.
This is realistic: entire value chains collapse when fossil infrastructure is stranded.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>stranded_energy_capital*effect_of_stranded_energy_capital_on_other_assets</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="effect of stranded energy\ncapital on other\nassets">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>relative_stranded_energy_capital^sensitivity_of_effect_of_stranded_energy_capital_on_other_assets</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="reference stranded\nenergy capital">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(MAX(minimum_reference_stranded_energy_capital[Run], stranded_energy_capital), stranded_energy_capital_reference_formation_time)</eqn>
				<isee:delay_aux/>
				<units>b$/year</units>
			</aux>
			<aux name="stranded energy capital reference formation time">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>50</eqn>
				<range min="10" max="110"/>
				<units>years</units>
			</aux>
			<aux name="relative stranded\nenergy capital">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>stranded_energy_capital//reference_stranded_energy_capital</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="sensitivity of effect of stranded energy\ncapital on other\nassets">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>2.15638540234467</eqn>
				<range min="1" max="5"/>
				<units>dmnl</units>
			</aux>
			<aux name="minimum reference stranded\nenergy capital">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1.5</eqn>
				<range min="0.5" max="2.5"/>
				<units>b$/year</units>
			</aux>
			<stock name="Wage Rate 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>$/p</units>
			</stock>
			<stock name="Inflation Rate 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>1/year</units>
			</stock>
			<aux name="private consumption 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="real GDP growth rate 2" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>dmnl/year</units>
			</aux>
			<aux name="Real GDP in 2021c$ 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="unemployment rate" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="stranded capital\nrelated defaults">
				<doc>The number of safe loans that default because of stranded assets is the minimum of:
(a) The maximum possible defaults banks can suffer: A fraction of safe loans is exposed to the fossil sector, maximized by safe loans default caused by stranded capital.
(b) The actual economic loss due to stranded assets.

MIN function because banks cannot lose more safe loans than are exposed to fossil risks AND banks cannot lose more than the real stranded asset losses.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MIN(Safe_Loans*max_safe_loan_defaults_caused_by_stranded_capital, stranded_energy_capital + stranded_energy_related_capital)</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Regulatory Tier 1\ncapital to assets">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>net_bank_assets/Bank_Assets</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Non performing loans net\nof provisions to capital">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>total_defaults</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Non performing loans\nto total gross loans">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>total_defaults/(Bank_Assets-Government_Debt_1)</eqn>
				<units>1/year</units>
			</aux>
			<stock name="Government\nDebt 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>B$</units>
			</stock>
			<aux name="Return on assets to\nshort term liabilities">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(firms_paying_interest+government_interest_payments)/Bank_Assets</eqn>
				<units>1/year</units>
			</aux>
			<aux name="total defaults">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>total_risky_asset_defaults + exploratory_loan_failure + exploratory_loan_defaults_from_from_interest</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="firms paying\ninterest" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>B$/year</units>
			</aux>
			<aux name="government\ninterest payments" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="government bailout assets to liabilities threshold">
				<doc>${Assumption}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1.04</eqn>
				<range min="1.02" max="1.06"/>
				<units>dmnl</units>
			</aux>
			<aux name="equity ratio gap">
				<doc>Signals whether banks feel safe or unsafe, and therefore whether they expand or contract lending.

If desired &gt; actual A/L ratio → gap is positive
→ bank is under-solvent relative to target
→ bank wants to become safer → reduces lending

If desired &lt; actual A/L ratio → gap is negative
→ bank is more than safe relative to target
→ bank can expand lending</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>bank_desired_asset_to_liability_ratio-assets_to_liability_ratio</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="effect of equity ratio gap on investment growth when above target">
				<doc>This node represents lending expansion effect
If banks are overcapitalized → investment growth is stimulated.
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>EXPBOUND(equity_gap_above_min_effect, equity_gap_zero_effect_y, equity_ratio_gap, equity_ratio_gap_effect_above_exponent, -equity_gap_effect_max_x_magnitude,  equity_gap_effect_zero_effect_x)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="equity gap above min effect">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.433728485607813</eqn>
				<range min="-50" max="0.5"/>
				<units>dmnl</units>
			</aux>
			<aux name="equity ratio gap\neffect above exponent">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>-1.13226853323907</eqn>
				<range min="-10" max="-1"/>
				<units>dmnl</units>
			</aux>
			<aux name="effect of equity ratio gap on investment growth when below target">
				<doc>This node represents lending contraction effect.
If banks are undercapitalized → investment growth is restricted.
Purpose: This is how solvency problems propagate into the real economy.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>EXPBOUND(equity_gap_zero_effect_y, equity_gap_below_max_effect, equity_ratio_gap, equity_ratio_gap_effect_below_exponent, equity_gap_effect_zero_effect_x, equity_gap_effect_max_x_magnitude)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="equity gap below max effect">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>3.10546015389887</eqn>
				<range min="1.2" max="10"/>
				<units>dmnl</units>
			</aux>
			<aux name="equity ratio gap\neffect below exponent">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1.07079537366798</eqn>
				<range min="1" max="10"/>
				<units>dmnl</units>
			</aux>
			<aux name="effect of equity gap on indicated\nbank investment growth rate">
				<doc>This is the behavioral driver that then feeds into the indicated bank investment growth. It tells us “How much should banks increase or decrease their investment growth because of their solvency (equity ratio) situation?”

- 1 when banks feel perfectly solvent (no pressure to adjust investment or lending)
- less than 1 when banks feel unsafe (need to contract investment or lending)


</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>effect_of_equity_ratio_gap_on_investment_growth_when_above_target*effect_of_equity_ratio_gap_on_investment_growth_when_below_target</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="max safe loan defaults\ncaused by stranded capital">
				<doc>${Assumption,No Sensi}
To control extreme policy only</doc>
				<eqn>1</eqn>
				<units>1/year</units>
			</aux>
			<aux name="equity gap effect\nzero effect x">
				<doc>${Assumption,No Sensi}
0 is no effect normalization.

Defines the value of equity ratio gap where the effect on investment growth is zero (i.e., neutral position). When banks are exactly at target solvency → no pressure to shrink or expand lending.</doc>
				<eqn>0</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="equity gap effect\nmax x magnitude">
				<doc>${Internal Calibration Parameter}
Defines the maximum deviation of the effect function.
This restricts how strong banks can react when gap is extreme (e.g., cannot cut lending infinitely).</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.169777247127836</eqn>
				<range min="0.05" max="0.2"/>
				<units>dmnl</units>
			</aux>
			<aux name="equity gap zero effect y">
				<doc>${Assumption,No Sensi}
1 to 1 normalization

Defines the value of equity ratio gap where the effect on investment growth is zero (i.e., neutral position). When banks are exactly at target solvency → no pressure to shrink or expand lending.</doc>
				<eqn>1</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="effect of lending\nstandards on failure rate">
				<doc>This is a behavioral multiplier based on short-term credit conditions.

If banks tighten lending standards, this multiplier increases → more firms fail
If banks loosen lending, this multiplier decreases → fewer failures.

Banks tightening lending increases defaults because firms cannot refinance working capital, repay debts, or roll over liabilities.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>LOGISTICBOUND(effect_of_lending_standards_on_failure_rate_range/2, -effect_of_lending_standards_on_failure_rate_range/2, lending_standards, 1,  effect_of_lending_standards_on_failure_rate_curvature)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="effect of lending standards on failure rate range">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>2.95036620976155</eqn>
				<range min="0.5" max="10"/>
				<units>dmnl</units>
			</aux>
			<aux name="effect of lending\nstandards on failure rate curvature">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>5.91542891023683</eqn>
				<range min="1" max="10"/>
				<units>dmnl</units>
			</aux>
			<aux name="effect of risky default rate\non lending standards">
				<doc>It tells given how risky-loan defaults are behaving relative to their normal level, how much should banks tighten (or loosen) lending standards.  It is designed to be centered around 0 change at baseline, and capped, so banks cannot tighten/loosen infinitely.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>LOGISTICBOUND(-effect_of_default_rate_on_lending_standards_range/2, effect_of_default_rate_on_lending_standards_range/2, measured_default_rate_of_risky_assets_for_lending_standards/INIT(measured_default_rate_of_risky_assets_for_lending_standards), 1,  effect_of_default_rate_on_lending_standards_curvature)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="effect of default rate\non lending standards range">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1.94742064616041</eqn>
				<range min="0.5" max="5"/>
				<units>dmnl</units>
			</aux>
			<aux name="effect of default rate\non lending standards curvature">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>4.00407024369583</eqn>
				<range min="1" max="10"/>
				<units>dmnl</units>
			</aux>
			<aux name="initial nominal GDP growth rate" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.029992375</eqn>
				<units>dmnl/year</units>
			</aux>
			<aux name="indicated failure rate">
				<doc>This is the baseline failure rate BEFORE banks tighten lending. It is the climate-adjusted or economic-conditions-adjusted default rate.

It already includes:
- normal failure rate (economic turnover)
- effect of STA (temperature-induced failures)
- effect of investment-to-GDP ratio (weak investment → more failures)</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>climate_adjusted_failure_rate*effect_of_investment_to_gdp_ratio_on_failure_rate</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="failure rate floor">
				<doc>${Assumption}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.002</eqn>
				<range min="0.001" max="0.003"/>
				<units>dmnl</units>
			</aux>
			<aux name="reference default rate">
				<doc>“What default rate is considered normal?”
This anchors pricing behavior.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(measured_default_rate_of_risky_assets_for_interest_rate, bank_reference_formation_time)</eqn>
				<isee:delay_aux/>
				<units>dmnl/year</units>
			</aux>
			<aux name="perceived defaults\nof safe assets not caused\nby energy transition">
				<doc>What banks believe are “normal” credit losses on safe assets, after filtering out losses that are clearly attributable to the energy transition (stranded assets).

It is perceived, not actual → it reflects reported, interpreted losses.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(safe_loan_defaults+actual_safe_investment_failure-stranded_capital_related_defaults, reporting_delay)</eqn>
				<isee:delay_aux/>
				<units>b$/year</units>
			</aux>
			<aux name="measured default rate\nof safe assets">
				<doc>This is the fraction of the “safe” loan portfolio that banks perceive as defaulting.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>perceived_defaults_of_safe_assets_not_caused_by_energy_transition/private_safe_bank_assets</eqn>
				<units>dmnl/year</units>
			</aux>
			<aux name="effect of safe default rate\non lending standards">
				<doc>It represents how much banks tighten or loosen lending standards in response to defaults on assets they believe are “safe.

It is a multiplier applied to lending standards.
Value = 1 → no change in lending standards
Value &gt; 1 → banks tighten lending
Value &lt; 1 → banks loosen lending


Safe-loan defaults are treated as a clear prudential trigger. FRIDA uses a straightforward proportional rule rather than a bounded logistic response, effectively saying if even safe assets are defaulting more than normal, banks adjust standards directly.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>1+ sensitivity_of_effect_of_safe_default_rate_on_lending_standards*(measured_default_rate_of_safe_assets/safe_asset_default_rate_threshold-1)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="sensitivity of\neffect of safe default rate\non lending standards">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.150971040563369</eqn>
				<range min="0.01" max="0.2"/>
				<units>dmnl</units>
			</aux>
			<aux name="safe asset default rate threshold">
				<doc>${Internal Calibration Parameter}
This is the reference level of default that banks consider “normal” for safe assets.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.015</eqn>
				<range min="0" max="0.05"/>
				<units>1/year</units>
			</aux>
			<stock name="Firms Innovation Orientation 2" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>dmnl</units>
			</stock>
			<aux name="normal rate of converting safe\nloans to safe loans for\nfinancing innovation">
				<doc>${Internal Calibration Parameter}
This is a baseline conversion speed.
It answers: “If firms were fully innovation-oriented, how fast could banks normally shift safe lending toward innovation?”

It reflects:
- institutional capacity,
- regulatory acceptance,
- banking routines,
- market familiarity with innovation finance.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.03</eqn>
				<range min="0.02" max="0.04"/>
				<units>dmnl/year</units>
			</aux>
			<aux name="rate of converting safe\nloans to safe loans for\nfinancing innovation">
				<doc>It represents the rate at which banks reallocate existing safe loans toward financing innovation, scaled by firms’ innovation orientation, ensuring that innovation finance expands only when both banking capacity and firm-level innovation demand are present.

MAX(0, …) ensures the rate is never negative.
Banks cannot “un-convert” loans via this channel. The flow only exists when innovation demand exists.
If innovation orientation is zero or negative → conversion rate = 0.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MAX(0, normal_rate_of_converting_safe_loans_to_safe_loans_for_financing_innovation*Firms_Innovation_Orientation_2)</eqn>
				<units>dmnl/year</units>
			</aux>
			<aux name="nominal investment and\nreal GDP growth difference">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Investment_growth_rate-real_GDP_growth_rate</eqn>
				<units>1/year</units>
			</aux>
			<aux name="real GDP growth rate" access="output" throughput="true" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>dmnl/year</units>
			</aux>
			<flow name="safe loan\ndefaults" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(1-fraction_of_CB_safe_loans) *
total_safe_loans_defaults</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<stock name="Insurance Deposits" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0</eqn>
				<non_negative/>
				<units>b$</units>
			</stock>
			<aux name="total climate caused\nrisky defaults" access="output" isee:autocreated="true">
				<doc>It represents the total annual volume of risky-loan defaults in the economy that are specifically attributable to climate damage, and it is the loss base from which policy interventions are calculated.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>bad_loans_defaults*fraction_of_defaults_that_are_caused_by_climate</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="fraction of\ndefaults that are caused\nby climate">
				<doc>It addresses if the risk embedded in these loans when they were issued, what share was already climate-related.

This avoids falsely attributing normal business failures, macroeconomic failures to climate change.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(climate_adjusted_failure_rate_when_default_originated-normal_failure_rate)/climate_adjusted_failure_rate_when_default_originated</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="climate adjusted failure\nrate when default originated">
				<doc>It represents the historical failure environment embedded in the current loan portfolio.
&quot;What failure rate was in effect when the loans that are defaulting today were originally issued?&quot;

Loans that default today were not created today because they were created many years ago, under different climate and economic conditions. It allows default dynamics to depend on the worsening of conditions relative to origination rather than instantaneous climate risk. Because loans last many years, today’s defaults come from loans issued under past climate conditions.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(climate_adjusted_failure_rate, loan_maturation_time)</eqn>
				<isee:delay_aux/>
				<units>dmnl</units>
			</aux>
			<aux name="insurance payouts" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="perceived\ndefaults of risky assets\nfor lending standards">
				<doc>This variable is the amount of risky-asset defaults that banks perceive when deciding whether to tighten or loosen lending standards. Its equation is SMTH1(total risky asset defaults - (private insurance payouts + Central Bank insurance payout +government insurance payout), reporting delay), so it takes actual risky defaults, subtracts insurance coverage, and then smooths the result through a reporting delay. This matters because banks do not react to raw defaults instantly or perfectly; they react to a delayed and partially insured loss signal. The variable is therefore the behavioral credit-stress input used for prudential tightening, rather than a direct accounting measure of defaults. </doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>SMTH1(total_risky_asset_defaults -
(insurance_payouts +climate_induced_bankruptcies + government_insurance_payout),
 reporting_delay)</eqn>
				<isee:delay_aux/>
				<units>b$/year</units>
			</aux>
			<aux name="measured\ndefault rate of risky assets\nfor lending standards">
				<doc>From the bank’s point of view, what fraction of our risky assets appears to be defaulting, after accounting for insurance and with reporting delays. So this is a rate (share), not a volume.
Banks use perceived default rate to decide whether to tighten or loosen lending standards.This variable converts the perceived volume of risky defaults into a default rate that can be used in the lending-standards rule. In other words, instead of reacting to defaults in absolute b$/year, banks react to a normalized measure of how severe risky defaults are relative to the relevant risky-asset base. I</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(perceived_defaults_of_risky_assets_for_lending_standards/risky_bank_assets)</eqn>
				<units>Per Year</units>
			</aux>
			<aux name="fraction of insurance\npayouts not influencing\nrisk premium">
				<doc>Only 50% of insurance payouts reduce the risk-premium-relevant perception of defaults. This is a behavioral realism assumption: insurance dampens stress, but does not eliminate perceived risk.</doc>
				<eqn>.5</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="climate induced\nbankruptcies" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<stock name="Central Bank Deposits" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$</units>
			</stock>
			<aux name="government insurance payout" access="output" throughput="true" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Central Bank investment" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0</eqn>
				<units>b$/year</units>
			</aux>
			<stock name="CB Good Loans">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>initial_CB_good_loans</eqn>
				<inflow>CB_good_investment</inflow>
				<inflow>CB_converting_to_good_because_of_reduced_interest_rates</inflow>
				<outflow>CB_loans_turning_safe</outflow>
				<outflow>CB_good_loan_defaults_from_from_interest</outflow>
				<non_negative/>
				<units>b$</units>
			</stock>
			<aux name="initial CB good loans">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0</eqn>
				<range min="7500" max="8500"/>
				<units>b$</units>
			</aux>
			<flow name="CB good investment">
				<doc>new investment that are not failing this year.

(1-failure rate) means a survived portions. 
The failure rate here is using the same variable as used in regular good investment flow because the question in this variant is not “are CB projects inherently better?” It is “what happens if the CB expands investment even when private finance would be cautious?”</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Central_Bank_investment_1*(1-failure_rate)</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="Central Bank investment 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0</eqn>
				<units>b$/year</units>
			</aux>
			<stock name="CB Bad\nLoans">
				<doc>Investment that fail</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>initial_CB_bad_loans</eqn>
				<inflow>CB_bad_investment</inflow>
				<outflow>CB_bad_loans_defaults</outflow>
				<outflow>CB_bad_loan_defaults_from_from_interest</outflow>
				<outflow>CB_converting_to_good_because_of_reduced_interest_rates</outflow>
				<non_negative/>
				<units>b$</units>
			</stock>
			<aux name="initial CB bad loans">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0</eqn>
				<range min="7500" max="8500"/>
				<units>b$</units>
			</aux>
			<flow name="CB bad investment">
				<doc>new investment that fail this year.

The failure rate here is using the same variable as used in regular good investment flow because the question in this variant is not “are CB projects inherently better?” It is “what happens if the CB expands investment even when private finance would be cautious?”

</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Central_Bank_investment_1*failure_rate</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<flow name="CB bad loans\ndefaults">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(CB_Bad_Loans-CB_bad_loan_defaults_from_from_interest*DT - CB_converting_to_good_because_of_reduced_interest_rates*DT)/loan_maturation_time</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<flow name="CB bad loan\ndefaults from from interest">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>CB_Bad_Loans*default_rate_from_interest_rate_increase</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<flow name="CB converting to good\nbecause of reduced interest\nrates">
				<doc>In the bank investment loan, when interest rates fall, some borderline bad loans become serviceable again.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>CB_Bad_Loans*conversion_rate_from_interest_rate_decrease</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="CB total risky asset defaults" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>CB_bad_loans_defaults + 
CB_bad_loan_defaults_from_from_interest + 
CB_good_loan_defaults_from_from_interest</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="firms interest payment\nto CB investment loans" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>CB_safe_assets_interest + CB_risky_assets_interest</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="risky\ninterest 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>1/year</units>
			</aux>
			<flow name="CB loans\nturning safe">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(CB_Good_Loans- CB_good_loan_defaults_from_from_interest*DT ) /loan_maturation_time</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<stock name="CB Safe\nLoans">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0</eqn>
				<inflow>CB_loans_turning_safe</inflow>
				<outflow>CB_safe_loans_affected_innovation</outflow>
				<outflow>CB_safe_loan_defaults</outflow>
				<non_negative/>
				<units>b$</units>
			</stock>
			<flow name="CB safe loans\naffected innovation" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(CB_Safe_Loans-CB_safe_loan_defaults*DT)*rate_of_converting_CB_safe_loans_to_CB_safe_loans_for_financing_innovation</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<stock name="CB safe loans\nfor financing\ninnovation">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0</eqn>
				<inflow>CB_safe_loans_affected_innovation</inflow>
				<outflow>CB_actual_safe_investment_failure</outflow>
				<non_negative/>
				<units>b$</units>
			</stock>
			<flow name="CB actual safe\ninvestment failure" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>CB_safe_loans_for_financing_innovation/time_for_safe_loans_that_will_fail_to_actually_fail</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="rate of converting CB safe\nloans to CB safe loans for\nfinancing innovation">
				<doc>It represents the rate at which banks reallocate existing safe loans toward financing innovation, scaled by firms’ innovation orientation, ensuring that innovation finance expands only when both banking capacity and firm-level innovation demand are present.

MAX(0, …) ensures the rate is never negative.
Banks cannot “un-convert” loans via this channel. The flow only exists when innovation demand exists.
If innovation orientation is zero or negative → conversion rate = 0.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>MAX(0, normal_rate_of_converting_safe_loans_to_safe_loans_for_financing_innovation*Firms_Innovation_Orientation_2)</eqn>
				<units>dmnl/year</units>
			</aux>
			<flow name="CB safe loan\ndefaults" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>fraction_of_CB_safe_loans*total_safe_loans_defaults</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<flow name="CB good loan\ndefaults from\nfrom interest">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>CB_Good_Loans*default_rate_from_interest_rate_increase</eqn>
				<non_negative/>
				<units>b$/year</units>
			</flow>
			<aux name="CB risky assets interest">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(CB_Good_Loans + CB_Bad_Loans) * risky_interest_1</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="CB safe assets interest">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(CB_safe_loans_for_financing_innovation + CB_Safe_Loans) 
*
average_private_debt_safe_interest</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="total safe loans defaults">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Total_nominal_loss_of_assets_from_SLR + stranded_capital_related_defaults</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="total safe loans">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>CB_Safe_Loans + Safe_Loans</eqn>
				<units>B$</units>
			</aux>
			<aux name="fraction of CB safe loans">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>CB_Safe_Loans/total_safe_loans</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="Total nominal loss of assets from SLR" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<group name="Central Bank Investment - Policy Sector" run="false">
				<format scale_by="auto"/>
				<entity name="CB_actual_safe_investment_failure"/>
				<entity name="CB_bad_investment"/>
				<entity name="CB_bad_loan_defaults_from_from_interest"/>
				<entity name="CB_Bad_Loans"/>
				<entity name="CB_bad_loans_defaults"/>
				<entity name="CB_converting_to_good_because_of_reduced_interest_rates"/>
				<entity name="CB_good_investment"/>
				<entity name="CB_good_loan_defaults_from_from_interest"/>
				<entity name="CB_Good_Loans"/>
				<entity name="CB_loans_turning_safe"/>
				<entity name="CB_risky_assets_interest"/>
				<entity name="CB_safe_assets_interest"/>
				<entity name="CB_safe_loan_defaults"/>
				<entity name="CB_Safe_Loans"/>
				<entity name="CB_safe_loans_affected_innovation"/>
				<entity name="CB_safe_loans_for_financing_innovation"/>
				<entity name="CB_total_risky_asset_defaults"/>
				<entity name="Central_Bank_investment_1"/>
				<entity name="firms_interest_payment_to_CB_investment_loans"/>
				<entity name="initial_CB_bad_loans"/>
				<entity name="initial_CB_good_loans"/>
				<entity name="rate_of_converting_CB_safe_loans_to_CB_safe_loans_for_financing_innovation"/>
				<entity name="risky_interest_1"/>
			</group>
			<group name="Safe Loan Defaults Sector" run="false">
				<format scale_by="auto"/>
				<entity name="fraction_of_CB_safe_loans"/>
				<entity name="total_safe_loans"/>
				<entity name="total_safe_loans_defaults"/>
			</group>
			<aux name="total investments with CB public investments" access="output" isee:autocreated="true">
				<doc>${Calibrated Output}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Central_Bank_investment_2 + total_investment</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Central Bank investment 2" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="initial government debt" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>29286.762206</eqn>
				<units>B$</units>
			</aux>
			<stock name="Firm-owned\nCentral Bank\nDeposits" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$</units>
			</stock>
			<aux name="government run\npublic investment" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<group name="Public Investment impact\nto investment growth" run="false">
				<format scale_by="auto"/>
				<entity name="Central_Bank_investment"/>
				<entity name="government_run_public_investment"/>
				<entity name="Investment_growth_rate"/>
			</group>
			<group name="Impact of Insurance Policy\nto the perceived risky assets defaults" run="false">
				<format scale_by="auto"/>
				<entity name="climate_induced_bankruptcies"/>
				<entity name="government_insurance_payout"/>
				<entity name="insurance_payouts"/>
				<entity name="perceived_defaults_of_risky_assets_for_lending_standards"/>
			</group>
		</variables>
		<views>
			<style color="black" background="white" font_style="normal" font_weight="normal" text_decoration="none" text_align="center" vertical_text_align="center" font_color="black" font_family="Arial" font_size="10pt" padding="2" border_color="black" border_width="thin" border_style="none">
				<text_box color="black" background="white" text_align="left" vertical_text_align="top" font_size="12pt"/>
				<isee:loop_indicator color="black" background="white" text_align="left" vertical_text_align="top" font_size="12pt"/>
				<numeric_display color="white" background="white" font_size="12pt" border_width="thin" border_style="solid" isee:transparent="false" isee:show_divider="true" isee:show_bounding_box="true" label_side="left"/>
				<graph color="black" background="white" font_size="12pt" axis_color="#666666" grid_color="#C8C8C8" isee:graph_area_color="white" legend_position="bottom" isee:transparent="false" isee:hide_border="false" axis_title_font_style="normal" axis_title_font_weight="normal" axis_title_text_decoration="none" axis_title_text_align="center" axis_title_vertical_text_align="center" axis_title_font_color="black" axis_title_font_family="Arial" axis_title_font_size="12pt" axis_title_text_padding="2" axis_title_text_border_color="black" axis_title_text_border_width="thin" axis_title_text_border_style="none" axis_label_font_style="normal" axis_label_font_weight="normal" axis_label_text_decoration="none" axis_label_text_align="center" axis_label_vertical_text_align="center" axis_label_font_color="black" axis_label_font_family="Arial" axis_label_font_size="9pt" axis_label_text_padding="2" axis_label_text_border_color="black" axis_label_text_border_width="thin" axis_label_text_border_style="none">
					<isee:series_styles>
						<isee:series_style color="blue" thickness="1"/>
