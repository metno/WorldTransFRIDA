				</style>
				<stock font_style="italic" font_weight="bold" label_side="left" x="175.5" y="866" name="Firms\nChecking\nAccounts 1"/>
				<stock x="695" y="527" name="Firms Innovation Orientation"/>
				<flow x="601.75" y="528" name="change in firms\ninnovation\norientation">
					<pts>
						<pt x="519" y="528"/>
						<pt x="672.5" y="528"/>
					</pts>
