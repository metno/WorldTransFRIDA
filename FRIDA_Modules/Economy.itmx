				<alias color="black" font_style="italic" font_weight="bold" font_color="black" uid="714" x="3124.02" y="929.939" width="45" height="35">
					<of>Firms_Innovation_Orientation_2</of>
				</alias>
				<alias color="black" background="#00F900" font_style="italic" font_color="black" uid="725" x="3261.08" y="1415.33" width="18" height="18">
					<of>average_private_debt_safe_interest</of>
				</alias>
				<alias font_style="italic" label_side="center" uid="732" x="3759.38" y="1520.69" width="83.2842" height="44.5979">
					<of>Safe_Loans</of>
				</alias>
				<alias font_style="italic" uid="730" x="3664.7" y="1719.17" width="51.2074" height="23.8492">
					<of>CB_Safe_Loans</of>
				</alias>
				<alias color="black" background="#00F900" font_style="italic" font_color="black" label_side="right" uid="737" x="3064.24" y="1244.89" width="18" height="18">
					<shape type="circle" radius="18"/>
					<of>total_safe_loans_defaults</of>
				</alias>
				<alias color="black" background="#00F900" font_style="italic" font_color="black" label_side="right" uid="739" x="3063.87" y="1291.3" width="18.7324" height="18.7324">
					<shape type="circle" radius="18"/>
					<of>fraction_of_CB_safe_loans</of>
				</alias>
				<alias color="blue" background="white" font_style="italic" label_side="right" label_angle="315" uid="742" x="2632.49" y="2170.9" width="18" height="18">
					<shape type="circle" radius="18"/>
					<of>fraction_of_CB_safe_loans</of>
				</alias>
				<alias font_style="italic" font_weight="bold" label_side="right" uid="710" x="4005.53" y="1692.41" width="18" height="18">
					<of>Total_nominal_loss_of_assets_from_SLR</of>
				</alias>
				<alias color="blue" background="white" font_style="italic" label_side="right" uid="741" x="2660.51" y="2143.23" width="18" height="18">
					<shape type="circle" radius="18"/>
					<of>total_safe_loans_defaults</of>
				</alias>
				<alias color="black" background="#00F900" font_style="italic" font_color="black" label_side="top" uid="746" x="3274.74" y="1031.43" width="18" height="18">
					<of>normal_rate_of_converting_safe_loans_to_safe_loans_for_financing_innovation</of>
				</alias>
				<alias color="black" background="#00F900" font_style="italic" font_color="black" label_side="top" uid="748" x="3481.03" y="1064.84" width="18" height="18">
					<of>time_for_safe_loans_that_will_fail_to_actually_fail</of>
				</alias>
			</view>
		</views>
	</model>
	<model name="GDP">
		<variables>
			<aux name="initial nominal GDP growth rate" access="output" isee:autocreated="true">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0.0414868952469566</eqn>
				<range min="0" max="0.1"/>
				<units>dmnl/year</units>
			</aux>
			<aux name="Nominal GDP" access="output">
				<doc>${Calibrated Output}
Nominal GDP is the value of all final goods and services produced, measured in current dollars (the dollar value of that year).

This reflects current-year prices, showing the total economic activity in money terms (private consumption, total investment, and government consumption)</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>private_consumption_1 + Investment_1 + Government_Spending_1</eqn>
				<format scale_by="auto"/>
				<units>b$/year</units>
			</aux>
			<aux name="time to measure\nGDP growth\nrate">
				<doc>${Assumption}
</doc>
				<eqn>1</eqn>
				<units>years</units>
			</aux>
			<aux name="nominal GDP\ngrowth rate" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Nominal_GDP-Average_GDP)/(time_to_measure_GDP_growth_rate*Average_GDP)</eqn>
				<units>1/year</units>
			</aux>
			<stock name="Average\nGDP">
				<doc>Average GDP is a smoothed stock, a running average of GDP over time.

Many behaviors depend on trend GDP, not instantaneous GDP Smoothing removes noise from year-to-year shocks.

Nominal GDP = “What is happening this year?”
Average GDP = “What is happening on average over the past few years?”
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>initial_average_GDP</eqn>
				<inflow>change_in_average_GDP</inflow>
				<non_negative/>
				<units>b$/year</units>
			</stock>
			<flow name="change in\naverage GDP">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>(Nominal_GDP-Average_GDP)/time_to_measure_GDP_growth_rate</eqn>
				<units>b$/year/years</units>
			</flow>
			<aux name="initial average GDP">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>INIT(Nominal_GDP/(initial_nominal_GDP_growth_rate*time_to_measure_GDP_growth_rate + 1))</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Government Spending 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Investment 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="private consumption 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Real GDP in 2021c$" access="output" isee:autocreated="true">
				<doc>${Calibrated Output}
Real GDP remove inflation, here uses 2021 dollars as the reference (base year), allowing us to compare actual economic output over time, independent of inflation.

It reflects how much the economy actually produces, measured in the purchasing power of 2021.</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Nominal_GDP/&quot;inflation_adjustment_b$_per_bc$&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="real GDP growth rate" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>TREND(&quot;Real_GDP_in_2021c$&quot;, time_to_measure_GDP_growth_rate, initial_real_GDP_growth_rate)</eqn>
				<units>dmnl/year</units>
			</aux>
			<aux name="inflation adjustment b$ per bc$" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/bc$</units>
			</aux>
			<aux name="private investment" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="public\ninvestment" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Nominal GDP Check">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Private_Consumption_excluding_Government_Transfers+private_investment+Government_Spending_including_Transfers</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Government Spending including Transfers">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Government_Spending_1+public_investment+government_transfers_1</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="government transfers 1" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="Private Consumption excluding Government Transfers">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>private_consumption_1-government_transfers_1</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="owner consumption" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="worker consumption" access="input">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>{Enter equation for use when not hooked up to other models}</eqn>
				<units>b$/year</units>
			</aux>
			<aux name="owner consumption in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>owner_consumption/&quot;inflation_adjustment_b$_per_bc$&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="worker consumption excluding transfers in 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>worker_consumption/&quot;inflation_adjustment_b$_per_bc$&quot;-&quot;government_transfers_in_2021c$&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="government transfers\nin 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>government_transfers_1/&quot;inflation_adjustment_b$_per_bc$&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="public investment\nin 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>public_investment/&quot;inflation_adjustment_b$_per_bc$&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="private investment in\nin 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>private_investment/&quot;inflation_adjustment_b$_per_bc$&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="government consumption\nin 2021c$">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>Government_Spending_1/&quot;inflation_adjustment_b$_per_bc$&quot;</eqn>
				<units>bc$/year</units>
			</aux>
			<aux name="initial real\nGDP growth rate">
				<doc>${Internal Calibration Parameter}
</doc>
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<element subscript="1">
					<eqn>0.0236863127624338</eqn>
				</element>
				<range min="0" max="0.05"/>
				<units>dmnl/year</units>
			</aux>
			<aux name="average real gdp growth rate in calibration period">
				<doc>${External Parameter}
Calculated from data</doc>
				<eqn>0.031542333</eqn>
				<units>1/year</units>
			</aux>
			<aux name="average nominal gdp growth rate in the calibration period">
				<doc>${External Parameter}
Calculated from data</doc>
				<eqn>0.057338479</eqn>
				<units>1/year</units>
			</aux>
			<stock name="nominal gdp growth rate deviation\nfrom average in\ncalibration period summed">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0</eqn>
				<inflow>accumulating_nominal_gdp_growth_rate_deviation_from_average_in_calibration_period</inflow>
				<units>dmnl</units>
			</stock>
			<stock name="real gdp growth rate deviation\nfrom average in\ncalibration period summed">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>0</eqn>
				<inflow>accumulating_real_gdp_growth_rate_deviation_from_average_in_calibration_period</inflow>
				<units>dmnl</units>
			</stock>
			<flow name="accumulating nominal gdp growth rate deviation\nfrom average in\ncalibration period">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF TIME &gt;= nominal_gdp_calibration_data_start_year THEN
ABS(average_nominal_gdp_growth_rate_in_the_calibration_period-nominal_GDP_growth_rate)
ELSE
0</eqn>
				<non_negative/>
				<units>1/year</units>
			</flow>
			<aux name="real gdp calibration\ndata start year">
				<doc>${External Parameter}
Calculated from data</doc>
				<eqn>1980</eqn>
				<units>year</units>
			</aux>
			<aux name="nominal gdp calibration data start year">
				<doc>${External Parameter}
Calculated from data</doc>
				<eqn>1990</eqn>
				<units>year</units>
			</aux>
			<flow name="accumulating real gdp growth rate deviation\nfrom average in\ncalibration period">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF TIME &gt;= real_gdp_calibration_data_start_year THEN
ABS(average_real_gdp_growth_rate_in_calibration_period-real_GDP_growth_rate)
ELSE
0</eqn>
				<non_negative/>
				<units>1/year</units>
			</flow>
			<aux name="start year" access="input">
				<eqn>2</eqn>
				<units>Year</units>
			</aux>
			<aux name="negative growth threshold">
				<doc>${External Parameter}
</doc>
				<eqn>0</eqn>
				<units>1/year</units>
			</aux>
			<aux name="recession threshold time">
				<doc>${External Parameter}
</doc>
				<eqn>.5</eqn>
				<units>year</units>
			</aux>
			<aux name="future recession counter">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>PREVIOUS(SELF, 0) + 
(current_recession_time_counter = 0 AND PREVIOUS(current_recession_time_counter, 0) &gt;= recession_threshold_time)</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="current recession time counter">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF TIME &gt; start_year AND real_GDP_growth_rate &lt; negative_growth_threshold THEN
PREVIOUS(SELF, 0) + DT
ELSE 0</eqn>
				<units>Year</units>
			</aux>
			<aux name="future time in recession">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF TIME &gt; start_year THEN 
PREVIOUS(SELF, 0) + (real_GDP_growth_rate &lt; 0) * DT
ELSE 
0</eqn>
				<units>Year</units>
			</aux>
			<aux name="historical\nnominal GDP growth rate\nexplosion stopper">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>IF TIME &lt;= start_year AND
(nominal_GDP_growth_rate &gt; .3 OR nominal_GDP_growth_rate &lt; -0.3) 
THEN
5/0
ELSE
0</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="real GDP growth rate\nprevious year" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>DELAY(real_GDP_growth_rate, 1, 0)</eqn>
				<units>1/year</units>
			</aux>
			<aux name="nominal GDP growth rate\nprevious year" access="output" isee:autocreated="true">
				<dimensions>
					<dim name="Run"/>
				</dimensions>
				<eqn>DELAY(nominal_GDP_growth_rate, 1, 0)</eqn>
				<units>1/year</units>
			</aux>
		</variables>
		<views>
