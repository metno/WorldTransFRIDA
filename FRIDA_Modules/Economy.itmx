	</model>
	<macro name="INFLATION_IMPACT_GROWTH_RATE">
		<eqn>trend in input</eqn>
		<parm>input</parm>
		<parm>averaging time</parm>
		<parm default="0">initial</parm>
		<variables>
			<stock name="Average Input">
				<eqn>input/(initial*averaging_time + 1)</eqn>
				<inflow>change_in_average</inflow>
				<non_negative/>
			</stock>
			<flow name="change in average">
				<eqn>(reference_input-Average_Input)/averaging_time</eqn>
			</flow>
			<aux name="trend in input" access="output">
				<eqn>(reference_input-Average_Input)/(averaging_time*Average_Input)</eqn>
				<units>1/time</units>
			</aux>
			<aux name="averaging time" access="input">
				<eqn>5</eqn>
			</aux>
			<aux name="input" access="input">
				<eqn>5</eqn>
			</aux>
			<stock name="reference input">
				<eqn>input</eqn>
				<inflow>change_in_reference_input</inflow>
				<non_negative/>
			</stock>
			<flow name="change in reference input">
				<eqn>(input-reference_input)/(averaging_time/2)</eqn>
			</flow>
			<aux name="initial" access="input">
				<eqn>0</eqn>
				<units>1/time</units>
			</aux>
		</variables>
		<view isee:show_pages="false" background="white" page_width="768" page_height="588" isee:popup_graphs_are_comparative="true" isee:enable_non_negative_highlights="false" type="stock_flow">
			<style color="black" background="white" font_style="normal" font_weight="normal" text_decoration="none" text_align="center" vertical_text_align="center" font_color="black" font_family="Arial" font_size="10pt" padding="2" border_color="black" border_width="thin" border_style="none">
				<stock color="blue" background="white" font_color="blue" font_size="11pt" label_side="top">
					<shape type="rectangle" width="45" height="35"/>
				</stock>
				<flow color="blue" background="white" font_color="blue" font_size="11pt" label_side="bottom">
