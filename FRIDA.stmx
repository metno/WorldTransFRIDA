			<isee:parameter name="Food_Demand.elasticity_of_crops_used_for_seed_or_lost_to_GDP_per_person[1]" scaling="100"/>
			<isee:parameter name="Food_Demand.elasticity_of_crops_used_for_non_energy_other_to_GDP_per_person[1]" scaling="100"/>
