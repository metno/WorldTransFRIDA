	<isee:multiplayer_settings include_chat="true" allow_observers="false" advance_time_increment="1" max_advance_time_in_ms="0" model_stops_when_players_drop="false" observer_start_page="home_page" enabled="false"/>
	<isee:time_formats default_format="Builtin">
		<isee:time_format name="Builtin" type="adaptive"/>
	</isee:time_formats>
	<isee:number_format_extenders/>
	<default_format scale_by="1"/>
	<data>
		<import isee:overwrite="false" isee:timevarying="true" resource="r../Data/frida_input_data.csv"/>
		<import frequency="on_demand" isee:overwrite="false" resource="r../Data/frida_iam_inputs_100_from_30000_1980_inits_params.csv"/>
	</data>
	<isee:sensi_specs_list active_index="0">
		<isee:sensi_specs name="Climate Sensitivity" method="grid">
			<isee:variable starting_value="1" ending_value="100" type="incremental" min="1" max="100" seed="12345" name="Climate_Units.selected_climate_case[1]" num_samples="100"/>
		</isee:sensi_specs>
	</isee:sensi_specs_list>
	<isee:optimizer_specs_list active_index="7">
		<isee:optimizer_specs name="Demographics Calibration" method="Powell" use_additional_starts_file="false" additional_starts="0" report_interval="1" confidence_range="0" maxiter="0">
			<isee:parameter name="Demographics.infant_mortality_alpha[1]" scaling="100000"/>
			<isee:parameter name="Demographics.infant_mortality_gamma[1]" scaling="100000"/>
			<isee:parameter name='Demographics."1_to_20_mortality_alpha"[1]'/>
			<isee:parameter name='Demographics."1_to_20_mortality_gamma"[1]'/>
			<isee:parameter name='Demographics."20_to_40_mortality_alpha"[1]'/>
			<isee:parameter name='Demographics."20_to_40_mortality_gamma"[1]'/>
			<isee:parameter name='Demographics."40_to_60_mortality_alpha"[1]'/>
			<isee:parameter name='Demographics."40_to_60_mortality_gamma"[1]'/>
			<isee:parameter name='Demographics."60_to_65_mortality_alpha"[1]'/>
			<isee:parameter name='Demographics."60_to_65_mortality_gamma"[1]'/>
			<isee:parameter name='Demographics."65_to_75_mortality_alpha"[1]'/>
			<isee:parameter name='Demographics."65_to_75_mortality_gamma"[1]'/>
			<isee:parameter name="Demographics.Over_75_mortality_alpha[1]"/>
			<isee:parameter name="Demographics.Over_75_mortality_gamma[1]"/>
			<isee:parameter name="Demographics.averaging_time[1]"/>
			<isee:parameter name="Demographics.effect_of_GDP_on_female_population_literacy_percentage_scale_factor[1]" scaling="100"/>
			<isee:parameter name="Demographics.effect_of_GDP_on_female_population_literacy_percentage_constant[1]" scaling="100"/>
			<isee:parameter name="Demographics.sensitivity_of_fertility_to_literacy[1]" scaling="1000"/>
			<isee:parameter name="Demographics.initial_fertility[1]" scaling="100"/>
			<isee:parameter name="Demographics.time_to_change_fertility[1]" scaling="100"/>
			<isee:parameter name="Demographics.initial_average_relative_real_gdp_per_person[1]" scaling="100"/>
			<isee:payoff name="Population Payoff" action="min"/>
		</isee:optimizer_specs>
		<isee:optimizer_specs name="Emissions Calibration" method="Powell" use_additional_starts_file="false" additional_starts="0" report_interval="1" confidence_range="0" maxiter="0">
			<isee:parameter name="Emissions.rate_of_decline_in_MtN2O_emission_per_PCal_animal_products[1]" scaling="100"/>
			<isee:parameter name="Emissions.MtN2O_emission_per_PCal_animal_products_1980[1]" scaling="100"/>
			<isee:parameter name="Emissions.baseline_Food_and_Land_use_CH4_emissions[1]"/>
			<isee:parameter name="Emissions.MtCH4_emission_per_PCal_animal_products_1980[1]" scaling="100"/>
			<isee:parameter name="Emissions.rate_of_decline_in_MtCH4_emission_per_PCal_animal_products[1]" scaling="1000"/>
			<isee:parameter name="Emissions.baseline_Food_and_Land_Use_N2O_emissions[1]" scaling="0.01"/>
			<isee:parameter name="Emissions.tN2O_emission_per_tN_fertilizer_1980[1]" scaling="100"/>
			<isee:parameter name="Emissions.rate_of_decline_in_tN2O_emission_per_tN_fertilizer[1]" scaling="1000"/>
			<isee:parameter name="Emissions.baseline_HFC134a_eq_per_person[1]" scaling="1000"/>
			<isee:parameter name="Emissions.sensitivity_of_HFC134a_eq_per_person_to_relative_CDD[1]" scaling="10"/>
			<isee:parameter name="Emissions.effective_CDD_logistic_speed[1]" scaling="10"/>
			<isee:parameter name="Emissions.baseline_non_fossil_CH4_per_person[1]" scaling="1000"/>
			<isee:parameter name="Emissions.baseline_N2O_per_person[1]" scaling="10000"/>
			<isee:parameter name="Emissions.sensitivity_of_Other_N2O_per_person_to_GDP_per_capita[1]" scaling="100"/>
			<isee:parameter name="Concrete.CO2_INTENSITY_OF_INFRASTRUCTURE_CONCRETE[1]" scaling="1000"/>
			<isee:parameter name="Concrete.CO2_INTENSITY_OF_RS_BUILDINGS_CONCRETE[1]" scaling="1000"/>
			<isee:parameter name="Emissions.Initial_Fossil_Energy_N2O_Intensity[1, *]"/>
			<isee:parameter name="Emissions.rate_of_change_in_energy_related_N2O_emissions[1, *]" scaling="1000"/>
			<isee:parameter name="Emissions.Initial_Fossil_Energy_Sulfur_Intensity[1, *]"/>
			<isee:parameter name="Emissions.desulphurisation_rate_of_energy_related_emissions[1, *]" scaling="1000"/>
			<isee:parameter name="Emissions.Initial_Fossil_Energy_CH4_Intensity[1, *]"/>
			<isee:parameter name="Emissions.rate_of_change_in_energy_related_CH4_emissions[1, *]" scaling="1000"/>
			<isee:payoff name="Emissions Payoff" action="min"/>
		</isee:optimizer_specs>
		<isee:optimizer_specs name="Literacy calibration" method="Powell" use_additional_starts_file="false" additional_starts="0" report_interval="1" confidence_range="0">
			<isee:parameter name="Demographics.effect_of_GDP_on_female_population_literacy_percentage_constant[1]" scaling="10"/>
			<isee:parameter name="Demographics.effect_of_GDP_on_female_population_literacy_percentage_scale_factor[1]" scaling="10"/>
			<isee:payoff name="Literacy Payoff" action="min"/>
		</isee:optimizer_specs>
		<isee:optimizer_specs name="Behavioral Change Calibration" method="Powell" use_additional_starts_file="false" additional_starts="0" report_interval="1" confidence_range="0" maxiter="0">
			<isee:parameter name="Animal_Products_Demand.sensitivity_of_demand_to_relative_scarcity[1]" scaling="10"/>
			<isee:parameter name="Animal_Products_Demand.sensitivity_of_personal_norm_to_consumption_risk[1]" scaling="10"/>
			<isee:parameter name="Animal_Products_Demand.sensitivity_of_personal_norm_to_social_value[1]" scaling="10"/>
			<isee:parameter name="Animal_Products_Demand.time_horizon_for_long_term_perception[1]"/>
			<isee:parameter name="Animal_Products_Demand.time_horizon_for_short_term_perception[1]"/>
			<isee:parameter name="Animal_Products_Demand.time_to_adjust_consumption_pattern[1]" scaling="10"/>
			<isee:parameter name="Animal_Products_Demand.time_to_adjust_value_perception[1]"/>
