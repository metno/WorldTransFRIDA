				</graph>
				<table color="black" background="#E0E0E0" text_align="right" font_size="12pt" orientation="vertical" wrap_text="false" isee:auto_fit="true" isee:use_alternate_row_colors="false" isee:unlimited_table_length="false" blank_column_width="80" column_width="160" interval="1" report_balances="beginning" report_flows="instantaneous" header_font_style="normal" header_font_weight="normal" header_text_decoration="none" header_text_align="center" header_vertical_text_align="center" header_font_color="black" header_font_family="Arial" header_font_size="12pt" header_text_padding="2" header_text_border_color="black" header_text_border_width="thin" header_text_border_style="none"/>
			</style>
			<stock x="513" y="184" name="Average Input"/>
			<flow x="379.25" y="189" name="change in average">
				<pts>
					<pt x="256" y="189"/>
					<pt x="490.5" y="189"/>
				</pts>
			</flow>
			<aux x="537" y="341" name="trend in input"/>
			<aux font_weight="bold" x="417" y="277" name="averaging time"/>
			<aux font_weight="bold" x="125" y="509" name="input"/>
			<connector uid="2" angle="111.501">
				<from>averaging_time</from>
				<to>change_in_average</to>
			</connector>
			<connector uid="3" angle="138.814">
				<from>Average_Input</from>
				<to>change_in_average</to>
			</connector>
			<connector uid="4" angle="312.93">
				<from>Average_Input</from>
				<to>trend_in_input</to>
			</connector>
			<connector uid="6" angle="350.272">
				<from>averaging_time</from>
				<to>trend_in_input</to>
			</connector>
			<stock x="297" y="383" name="reference input"/>
			<flow x="204.25" y="386" name="change in reference input">
				<pts>
					<pt x="122" y="386"/>
					<pt x="274.5" y="386"/>
				</pts>
			</flow>
			<connector uid="7" angle="51.7662">
				<from>input</from>
				<to>change_in_reference_input</to>
			</connector>
			<connector uid="8" angle="11.5922">
				<from>reference_input</from>
				<to>trend_in_input</to>
			</connector>
			<connector uid="9" angle="71.9958">
				<from>reference_input</from>
				<to>change_in_average</to>
			</connector>
			<connector uid="10" angle="187.595">
				<from>averaging_time</from>
				<to>change_in_reference_input</to>
			</connector>
			<connector uid="11" angle="157.557">
				<from>reference_input</from>
				<to>change_in_reference_input</to>
			</connector>
			<aux font_weight="bold" x="646" y="89" name="initial"/>
		</view>
	</macro>
	<macro name="SIGN">
		<eqn>output</eqn>
		<parm>input</parm>
		<variables>
			<aux name="input" access="input">
				<eqn>0</eqn>
				<units>dmnl</units>
			</aux>
			<aux name="output" access="output">
				<eqn>IF input &lt; 0 THEN -1
ELSE 1</eqn>
				<units>dmnl</units>
			</aux>
		</variables>
		<view isee:show_pages="false" background="white" page_width="768" page_height="588" isee:popup_graphs_are_comparative="true" isee:enable_non_negative_highlights="false" type="stock_flow">
