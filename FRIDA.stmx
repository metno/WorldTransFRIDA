			<isee:parameter name="Animal_Products_Demand.time_to_perceive_average_consumption[1]" scaling="10"/>
			<isee:parameter name="Animal_Products_Demand.average_daily_demand_per_capita_in_1980[1]"/>
			<isee:parameter name="Animal_Products_Demand.initial_share_of_demand_from_consumption_domain[1]" scaling="10"/>
			<isee:parameter name="Climate_Risk_Perception.time_to_report_and_perceive_climate_information[1]"/>
			<isee:parameter name="Climate_Risk_Perception.time_to_perceive_climate_extremes_exposure[1]"/>
			<isee:parameter name="Climate_Risk_Perception.additional_time_horizon_of_reference_climate_extremes_exposure[1]"/>
			<isee:parameter name="Climate_Risk_Perception.time_to_perceive_SLR_flooding_exposure[1]"/>
			<isee:parameter name="Climate_Risk_Perception.additional_time_horizon_of_reference_SLR_flooding_exposure[1]"/>
			<isee:parameter name="Climate_Risk_Perception.sensitivity_to_climatic_events_exposure[1]" scaling="10"/>
			<isee:parameter name="Total_Food_Demand.sensitivity_of_demand_to_scarcity[1]" scaling="10"/>
			<isee:parameter name="Total_Food_Demand.sensitivity_of_personal_norm_to_climate_risk[1]" scaling="10"/>
			<isee:parameter name="Total_Food_Demand.sensitivity_of_personal_norm_to_consumption_risk[1]" scaling="10"/>
			<isee:parameter name="Total_Food_Demand.sensitivity_of_personal_norm_to_social_value[1]" scaling="10"/>
			<isee:parameter name="Total_Food_Demand.time_horizon_for_long_term_perception[1]"/>
			<isee:parameter name="Total_Food_Demand.time_horizon_for_short_term_perception[1]"/>
			<isee:parameter name="Total_Food_Demand.time_to_adjust_consumption_pattern[1]"/>
			<isee:parameter name="Total_Food_Demand.time_to_adjust_value_perception[1]"/>
			<isee:parameter name="Total_Food_Demand.time_to_observe_consequences[1]"/>
			<isee:parameter name="Total_Food_Demand.time_to_perceive_average_consumption[1]"/>
			<isee:parameter name="Total_Food_Demand.time_to_adjust_desired_demand_from_accessibility[1]"/>
			<isee:parameter name="Total_Food_Demand.average_daily_demand_per_capita_in_1980[1]" scaling="0.1"/>
			<isee:parameter name="Total_Food_Demand.elasticity_of_demand_to_GDP[1]" scaling="10"/>
			<isee:parameter name="Animal_Products_Demand.elasticity_of_demand_to_GDP[1]" scaling="10"/>
			<isee:parameter name="Total_Food_Demand.sensitivity_of_social_value_perception[1]" scaling="10"/>
			<isee:parameter name="Animal_Products_Demand.sensitivity_of_social_value_perception[1]" scaling="10"/>
			<isee:parameter name="Total_Food_Demand.growth_rate_of_socioeconomic_effect[1]"/>
			<isee:parameter name="Animal_Products_Demand.growth_rate_of_socioeconomic_effect[1]"/>
			<isee:parameter name="Animal_Products_Demand.normal_sensitivity_of_personal_norm_to_climate_risk[1]" scaling="10"/>
			<isee:parameter name="Climate_Risk_Perception.normal_sensitivity_to_climate_information[1]" scaling="10"/>
			<isee:parameter name="Climate_Risk_Perception.normal_additional_time_horizon_of_reference_temperature_anomaly[1]"/>
			<isee:payoff name="Behavioral Change Payoff" action="min"/>
		</isee:optimizer_specs>
		<isee:optimizer_specs name="Energy Demand" method="Powell" use_additional_starts_file="false" additional_starts="0" report_interval="1" confidence_range="0" init_step="0.001">
			<isee:payoff name="Energy Demand" action="min"/>
		</isee:optimizer_specs>
		<isee:optimizer_specs name="Carbon Balance Calibration" method="Powell" use_additional_starts_file="false" additional_starts="0" report_interval="1" confidence_range="0" maxiter="0">
			<isee:parameter name="Land_Use.normal_average_cutting_time[1]" scaling="0.1"/>
			<isee:parameter name="Land_Use.normal_average_time_cropland_in_use[1]" scaling="0.1"/>
			<isee:parameter name="Grass.GtC_per_PCal_of_grazing_multiplier[1]" scaling="1000"/>
			<isee:parameter name="Terrestrial_Carbon_Balance.Global_peatland_carbon_uptake_rate[1]" scaling="100"/>
			<isee:payoff name="Carbon Balance Payoff" action="min"/>
			<isee:payoff name="Land Use and Agriculture Payoff" action="min" inactive="true"/>
		</isee:optimizer_specs>
		<isee:optimizer_specs name="Concrete Calibration" method="Powell" use_additional_starts_file="false" additional_starts="0" report_interval="1" confidence_range="0" maxiter="0">
			<isee:parameter name="Concrete.TIME_TO_ADJUST_DESIRED_FLOOR_AREA[1]" scaling="10"/>
			<isee:parameter name="Concrete.TIME_TO_ADJUST_DESIRED_INFRASTRUCTURE_AREA[1]" scaling="10"/>
			<isee:parameter name="Concrete.UFA_alpha[1]" scaling="10"/>
			<isee:parameter name="Concrete.UFA_intercept[1]"/>
			<isee:parameter name="Concrete.INIT_CONCRETE_IN_NEW_BUILDINGS[1]" scaling="0.01"/>
			<isee:parameter name="Concrete.INIT_CONCRETE_IN_NEW_INFRASTRUCTURE[1]" scaling="0.01"/>
			<isee:parameter name="Concrete.INIT_CONCRETE_IN_OLD_BUILDINGS[1]" scaling="0.01"/>
			<isee:parameter name="Concrete.INIT_CONCRETE_IN_OLD_INFRASTRUCTURE[1]" scaling="0.01"/>
			<isee:parameter name="Concrete.BASE_AVERAGE_LIFETIME_OF_BUILDINGS[1]" scaling="0.1"/>
			<isee:parameter name="Concrete.BASE_AVERAGE_LIFETIME_OF_INFRASTRUCTURE[1]" scaling="0.1"/>
			<isee:parameter name="Concrete.GAP_ADJUSTMENT_TIME_FOR_BUILDINGS[1]" scaling="10"/>
			<isee:parameter name="Concrete.GAP_ADJUSTMENT_TIME_FOR_INFRASTRUCTURE[1]" scaling="10"/>
			<isee:parameter name="Concrete.NORMAL_CONCRETE_DETERIORATION_RATE[1]" scaling="100"/>
			<isee:parameter name="Concrete.INFRA_ALPHA[1]" scaling="0.01"/>
			<isee:parameter name="Concrete.INFRA_BETA[1]" scaling="10"/>
			<isee:parameter name="Concrete.INFRA_GAMMA[1]" scaling="10"/>
			<isee:parameter name="Concrete.CO2_INTENSITY_OF_RS_BUILDINGS_CONCRETE[1]" scaling="10"/>
			<isee:parameter name="Concrete.CO2_INTENSITY_OF_INFRASTRUCTURE_CONCRETE[1]" scaling="10"/>
			<isee:payoff name="Concrete Payoff" action="min"/>
		</isee:optimizer_specs>
		<isee:optimizer_specs name="Land Use and Agriculture Calibration" method="Powell" use_additional_starts_file="false" additional_starts="0" report_interval="1" confidence_range="0" maxiter="0">
			<isee:parameter name="Animal_Products.elasticity_of_aquatic_animal_product_share_to_GDP_per_person[1]" scaling="100"/>
			<isee:parameter name="Animal_Products.aquatic_animal_product_share_1980[1]" scaling="10000"/>
			<isee:parameter name="Animal_Products.average_animal_product_growth_efficiency[1]" scaling="10"/>
			<isee:parameter name="Animal_Products.Animal_Products_Yield_in_1980[1]" scaling="100"/>
			<isee:parameter name="Freshwater.non_agricultural_water_withdrawal_1980[1]" scaling="1e-8"/>
			<isee:parameter name="Freshwater.elasticity_of_non_agricultural_water_withdrawal_per_capita_to_GDP_per_person[1]" scaling="100"/>
			<isee:parameter name="Freshwater.sensitivity_of_effect_of_available_water_supply_on_land_irrigated[1]" scaling="10"/>
			<isee:parameter name="Freshwater.water_withdrawal_per_MHa_irrigated_1980[1]" scaling="1e-10"/>
			<isee:parameter name="Freshwater.rate_of_change_in_irrigation_efficiency[1]" scaling="1000000"/>
