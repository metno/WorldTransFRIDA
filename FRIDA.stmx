<?xml version="1.0" encoding="utf-8"?>
<xmile version="1.0" xmlns="http://docs.oasis-open.org/xmile/ns/XMILE/v1.0" xmlns:isee="http://iseesystems.com/XMILE">
	<header>
		<smile version="1.0" namespace="std, isee" uses_arrays="3" uses_conveyor="" uses_submodels=""/>
		<name>FRIDA</name>
		<uuid>fe807591-4e3d-4e2c-b464-70ec4fb12094</uuid>
		<vendor>isee systems, inc.</vendor>
		<product version="3.8.1" isee:build_number="3632" isee:saved_by_v1="true" lang="en">Stella Architect</product>
	</header>
	<sim_specs isee:sim_duration="0" isee:run_prefix="Run" isee:simulation_delay="0" isee:restore_on_start="false" isee:save_interval="1" method="RK4" time_units="Year" isee:instantaneous_flows="false" isee:ignore_module_errors="false" isee:strict_units="false" isee:loop_scores="false" isee:loop_exhaustive_allowed="1000">
		<start>1980</start>
		<stop>Simulation_End</stop>
		<dt reciprocal="true">8</dt>
	</sim_specs>
	<dimensions>
		<dim name="ClimateCase" size="100"/>
		<dim name="Coastal_Protection_level">
			<elem name="insufficient"/>
			<elem name="well_protected"/>
		</dim>
		<dim name="ColdMortalityImpactCase" size="11"/>
		<dim name="CropImpactsCase" size="11"/>
		<dim name="EnergySource">
			<elem name="Coal_fuel_extraction"/>
			<elem name="Coal_energy_conversion"/>
			<elem name="Oil_fuel_extraction"/>
			<elem name="Oil_energy_conversion"/>
			<elem name="Gas_fuel_extraction"/>
			<elem name="Gas_energy_conversion"/>
			<elem name="Hydropower"/>
			<elem name="Nuclear"/>
			<elem name="Bio"/>
			<elem name="Solar"/>
			<elem name="Wind"/>
		</dim>
		<dim name="EnergySupplyHydroDamage" size="11"/>
		<dim name="EnergySupplyThermoDamage" size="11"/>
		<dim name="ExtremesExposureImpactCase" size="11"/>
		<dim name="FossilFuelTypes">
			<elem name="Gas"/>
			<elem name="Oil"/>
			<elem name="Coal"/>
		</dim>
		<dim name="Future_Decades" size="9"/>
		<dim name="Historical_5yr_time_steps" size="9"/>
		<dim name="Historical_Decades" size="4"/>
		<dim name="HotMortalityImpactCase" size="11"/>
		<dim name="labouExposureLevel">
			<elem name="No_Exposure"/>
			<elem name="Low_Exposure"/>
			<elem name="High_Exposure"/>
		</dim>
		<dim name="PCTILE">
			<elem name="Low"/>
			<elem name="P25"/>
			<elem name="Median"/>
			<elem name="P75"/>
			<elem name="High"/>
		</dim>
		<dim name="PopCohortLen10" size="10"/>
		<dim name="PopCohortLen19" size="19"/>
		<dim name="PopCohortLen20" size="20"/>
		<dim name="PopCohortLen25" size="25"/>
		<dim name="PopCohortLen5" size="5"/>
		<dim name="Renewable_Age_Group" size="7"/>
		<dim name="Run" size="1"/>
	</dimensions>
	<isee:prefs saved_runs="10" keep="false" show_module_prefix="true" live_update_on_drag="true" show_restore_buttons="false" layer="model" isee:design="Deluxe Prev-Next Blue Green Pastel" isee:design_custom="false" interface_secure_mode="true" interface_scale_ui="true" interface_max_page_width="10000" interface_max_page_height="10000" interface_min_page_width="0" interface_min_page_height="0" rifp="true">
		<isee:ignored_words>
			<isee:ignored_word>WolrdTrans</isee:ignored_word>
			<isee:ignored_word>WorldTrans</isee:ignored_word>
			<isee:ignored_word>IAM</isee:ignored_word>
			<isee:ignored_word>FRIDA</isee:ignored_word>
			<isee:ignored_word>IAMs</isee:ignored_word>
			<isee:ignored_word>Sectorized</isee:ignored_word>
			<isee:ignored_word>INvestment</isee:ignored_word>
