			<isee:parameter name="Freshwater.initial_fraction_of_unsustainable_water_withdrawal[1]" scaling="100"/>
			<isee:parameter name="Land_Nutrients.elasticity_of_effect_of_animal_products_on_manure_fertilizer_use[1]" scaling="100"/>
			<isee:parameter name="Sea_Level.initial_sea_level_anomaly_from_LWS[1]" scaling="100"/>
